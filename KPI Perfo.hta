                                    </td>
                                    <td style="border:none; padding:0 0 0 10px; vertical-align:bottom; white-space:nowrap;">
                                        <button class="btn-toolbar" style="background:#dc2626; padding:0 14px;" onclick="ResetExtractIC()" title="Réinitialiser l'extraction de cet onglet (efface les IC)">Vider</button>
                                    </td>
                                    <td style="border:none; padding:0 0 0 10px; vertical-align:bottom; width:100%;">
                                        <span style="display:block; width:100%; padding:0 12px; height:38px; line-height:36px; border:1px solid #86efac; border-radius:6px; background:#dcfce3; color:#166534; font-size:13px; box-sizing:border-box; text-align:center; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">Dernière extraction : <b id="lastICExtractDate">-</b></span>
                                    </td>
                                </tr></table>
                            </div>
                        </div>
                        <div style="display:table-cell; width:50%; padding-left:8px; box-sizing:border-box; vertical-align:top;">
                            <div class="card" style="height:100%; margin-bottom:0; box-sizing:border-box;">
                                <table style="border:none; width:100%;"><tr>
                                    <td style="border:none; padding:0 14px 0 0; vertical-align:bottom; white-space:nowrap;">
                                        <label style="display:block; font-size:12px; font-weight:600; color:#475569; margin-bottom:5px;">Filtrer à partir du</label>
                                        <span class="date-wrap"><input type="text" id="icFiltreDateDebut" data-filter="ic" class="input-date" style="width:120px;" placeholder="JJ/MM/AAAA" onclick="showCalendar(this, event)" readonly="readonly"><button type="button" class="btn-clear-date" onclick="clearDate('icFiltreDateDebut', event)" title="Effacer">&times;</button></span>
                                    </td>
                                    <td style="border:none; padding:0 14px 0 0; vertical-align:bottom; white-space:nowrap;">
                                        <label style="display:block; font-size:12px; font-weight:600; color:#475569; margin-bottom:5px;">Filtrer jusqu'au</label>
                                        <span class="date-wrap"><input type="text" id="icFiltreDateFin" data-filter="ic" class="input-date" style="width:120px;" placeholder="JJ/MM/AAAA" onclick="showCalendar(this, event)" readonly="readonly"><button type="button" class="btn-clear-date" onclick="clearDate('icFiltreDateFin', event)" title="Effacer">&times;</button></span>
                                    </td>
                                    <td style="border:none; padding:0 14px 0 0; vertical-align:bottom; width:100%;">
                                        <label style="display:block; font-size:12px; font-weight:600; color:#475569; margin-bottom:5px;">Recherche</label>
                                        <input type="text" id="icFiltreRecherche" class="input-text" style="width:100%; box-sizing:border-box;" onkeyup="DebounceExtractSearch(RenderICTable)" placeholder="Tape pour filtrer">
                                    </td>
                                    <td style="border:none; padding:0 14px 0 0; vertical-align:bottom; white-space:nowrap;">
                                        <button class="btn-grey" style="font-weight:600; font-size:13px; height:38px; line-height:38px; padding:0 10px; border:none; border-radius:6px; cursor:pointer; color:#fff;" onclick="ResetICFiltres()">Réinitialiser</button>
                                    </td>
                                    <td style="border:none; padding:0; vertical-align:bottom; white-space:nowrap;">
                                        <label style="display:block; font-size:12px; font-weight:600; color:#475569; margin-bottom:5px;">Lignes</label>
                                        <input type="text" id="nbLignesIC" value="500" onkeyup="DebounceExtractSearch(RenderICTable)" title="Nombre de lignes à afficher" style="width:72px; height:38px; padding:0 8px; border:1px solid #c5d5de; border-radius:6px; background:#fff; color:#0C447C; font-weight:700; font-size:13px; text-align:center; box-sizing:border-box;">
                                    </td>
                                </tr></table>
                            </div>
                        </div>
                    </div>
                    <div id="icTable"><div class="msg-box msg-info">Aucune extraction réalisée.</div></div>
                </div><!-- /extractSubIC -->

                <div id="extractSubPL" style="display:none;">
                    <div style="display:table; width:100%; margin:0 0 20px 0;">
                        <div style="display:table-cell; width:50%; padding-right:8px; box-sizing:border-box; vertical-align:top;">
                            <div class="card" style="height:100%; margin-bottom:0; box-sizing:border-box;">
                                <table style="border:none; width:100%;"><tr>
                                    <td style="border:none; padding:0; vertical-align:bottom; white-space:nowrap;">
                                        <label style="display:block; font-size:12px; font-weight:600; color:#475569; margin-bottom:5px;">Fichier de planification</label>
                                        <button id="btnPlanif" class="btn-toolbar" style="min-width:190px;" onclick="ChargerPlanifCSV()">Charger un fichier CSV</button>
                                        <input type="file" id="planifFileInput" accept=".csv" style="display:none;" onchange="OnPlanifFileChosen(this)">
                                    </td>
                                    <td style="border:none; padding:0 0 0 10px; vertical-align:bottom; white-space:nowrap;">
                                        <button class="btn-toolbar" style="background:#dc2626; padding:0 14px;" onclick="ResetExtractPlanif()" title="Réinitialiser la planification (efface le CSV chargé)">Vider</button>
                                    </td>
                                    <td style="border:none; padding:0 0 0 10px; vertical-align:bottom; width:100%;">
                                        <span id="planifWeekBadge" style="display:block; width:100%; padding:0 12px; height:38px; line-height:36px; border:1px solid #86efac; border-radius:6px; background:#dcfce3; color:#166534; font-size:13px; box-sizing:border-box; text-align:center; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">Dernière semaine extraite : <b id="lastPlanifWeek">-</b></span>
                                    </td>
                                </tr></table>
                            </div>
                        </div>
                        <div style="display:table-cell; width:50%; padding-left:8px; box-sizing:border-box; vertical-align:top;">
                            <div class="card" style="height:100%; margin-bottom:0; box-sizing:border-box;">
                                <table style="border:none; width:100%;"><tr>
                                    <td style="border:none; padding:0 14px 0 0; vertical-align:bottom; white-space:nowrap;">
                                        <label style="display:block; font-size:12px; font-weight:600; color:#475569; margin-bottom:5px;">Filtrer à partir du</label>
                                        <span class="date-wrap"><input type="text" id="planifFiltreDateDebut" data-filter="planif" class="input-date" style="width:120px;" placeholder="JJ/MM/AAAA" onclick="showCalendar(this, event)" readonly="readonly"><button type="button" class="btn-clear-date" onclick="clearDate('planifFiltreDateDebut', event)" title="Effacer">&times;</button></span>
                                    </td>
                                    <td style="border:none; padding:0 14px 0 0; vertical-align:bottom; white-space:nowrap;">
                                        <label style="display:block; font-size:12px; font-weight:600; color:#475569; margin-bottom:5px;">Filtrer jusqu'au</label>
                                        <span class="date-wrap"><input type="text" id="planifFiltreDateFin" data-filter="planif" class="input-date" style="width:120px;" placeholder="JJ/MM/AAAA" onclick="showCalendar(this, event)" readonly="readonly"><button type="button" class="btn-clear-date" onclick="clearDate('planifFiltreDateFin', event)" title="Effacer">&times;</button></span>
                                    </td>
                                    <td style="border:none; padding:0 14px 0 0; vertical-align:bottom; width:100%;">
                                        <label style="display:block; font-size:12px; font-weight:600; color:#475569; margin-bottom:5px;">Recherche</label>
                                        <input type="text" id="planifFiltreRecherche" class="input-text" style="width:100%; box-sizing:border-box;" onkeyup="DebounceExtractSearch(RenderPlanif)" placeholder="OF/NC, MSN, sujet, statut, vacation">
                                    </td>
                                    <td style="border:none; padding:0 14px 0 0; vertical-align:bottom; white-space:nowrap;">
                                        <button class="btn-grey" style="font-weight:600; font-size:13px; height:38px; line-height:38px; padding:0 10px; border:none; border-radius:6px; cursor:pointer; color:#fff;" onclick="ResetPlanifFiltres()">Réinitialiser</button>
                                    </td>
                                    <td style="border:none; padding:0; vertical-align:bottom; white-space:nowrap;">
                                        <label style="display:block; font-size:12px; font-weight:600; color:#475569; margin-bottom:5px;">Lignes</label>
                                        <input type="text" id="nbLignesPlanif" value="500" onkeyup="DebounceExtractSearch(RenderPlanif)" title="Nombre de lignes à afficher" style="width:72px; height:38px; padding:0 8px; border:1px solid #c5d5de; border-radius:6px; background:#fff; color:#0C447C; font-weight:700; font-size:13px; text-align:center; box-sizing:border-box;">
                                    </td>
                                </tr></table>
                            </div>
                        </div>
                    </div>
                    <div id="planifTable"><div class="msg-box msg-info">Aucun fichier chargé. Clique sur « Charger un fichier CSV » pour importer le planning de la semaine.</div></div>
                </div><!-- /extractSubPL -->
            </div>

            <div id="pageParcours" class="page">
                <div id="weekSelectCard" class="card" style="padding:14px 25px;">
                    <span style="font-size:13px; font-weight:600; color:#475569; margin-right:12px; vertical-align:middle;">Filtrer par</span>
                    <span id="parcoursModeToggle" style="display:inline-block; vertical-align:middle; margin-right:16px;"></span>
                    <select id="weekSelect" onchange="SetParcoursWeek(this.value); this.blur();" style="vertical-align:middle; border:1px solid #c5d5de; padding:8px 12px; height:38px; border-radius:6px; font-family:inherit; font-size:14px; color:#1e293b; background:#fff; cursor:pointer; min-width:320px;"></select>
                    <select id="msnSelect" onchange="SetParcoursMsn(this.value); this.blur();" style="display:none; vertical-align:middle; border:1px solid #c5d5de; padding:8px 12px; height:38px; border-radius:6px; font-family:inherit; font-size:14px; color:#1e293b; background:#fff; cursor:pointer; min-width:200px;"></select>
                    <span id="weekCount" style="display:inline-block; vertical-align:middle; margin-left:14px; padding:8px 16px; height:38px; line-height:20px; border:1px solid #c5d5de; border-radius:6px; background:#f0f4f7; font-size:14px; font-weight:700; color:#006698; box-sizing:border-box;">-</span>
                    <button type="button" onclick="ExportParcoursPDF()" title="Exporter un récapitulatif PDF de la sélection actuelle" style="float:right; vertical-align:middle; height:38px; padding:0 16px; border:none; border-radius:6px; background:#0C447C; color:#fff; font-size:13px; font-weight:600; cursor:pointer;"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:middle; margin-right:6px;"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><path d="M7 10l5 5 5-5"/><path d="M12 15V3"/></svg>Exporter PDF</button>
                </div>
                <div id="parcoursContainer"><div class="msg-box msg-info">Aucune NC analysée pour l'instant.</div></div>
            </div>

            <div id="pageParametres" class="page">
                <div class="card" style="margin-bottom:16px; padding:16px 20px; overflow:hidden;">
                    <div style="float:right;">
                        <button id="btnParamsEdit" class="btn-toolbar btn-green" onclick="ParamsEdit()">Modifier</button>
                        <button id="btnParamsSave" class="btn-toolbar btn-green" style="display:none; margin-left:8px;" onclick="ParamsValider()">Valider</button>
                        <button id="btnParamsCancel" class="btn-toolbar btn-grey" style="display:none; margin-left:6px;" onclick="ParamsAnnuler()">Annuler</button>
                    </div>
                    <h3 style="margin:0; display:inline-block; vertical-align:middle; margin-right:28px;">Mode de calcul des durées</h3>
                    <div id="calcModePanel" style="display:inline-block; vertical-align:middle;"></div>
                </div>

                <div style="font-size:0; margin:0 -8px;">
                    <div style="display:inline-block; vertical-align:top; width:31%; padding:0 8px; box-sizing:border-box;">
                        <div class="card" style="padding:0; margin-bottom:0;">
                            <div class="card-title"><div class="param-ttl" style="color:#002d45;">Responsables</div></div>
                            <div style="padding:15px;"><div id="rolesContainer"><div class="msg-box msg-info">Lance d'abord un extract.</div></div></div>
                        </div>
                    </div>
                    <div style="display:inline-block; vertical-align:top; width:23%; padding:0 8px; box-sizing:border-box;">
                        <div class="card" style="padding:0; margin-bottom:0;">
                            <div class="card-title"><div class="param-ttl" style="color:#b45309;">Équipe ST</div></div>
                            <div style="padding:15px;"><div id="teamST"></div></div>
                        </div>
                    </div>
                    <div style="display:inline-block; vertical-align:top; width:23%; padding:0 8px; box-sizing:border-box;">
                        <div class="card" style="padding:0; margin-bottom:0;">
                            <div class="card-title"><div class="param-ttl" style="color:#1d4ed8;">Équipe TL</div></div>
                            <div style="padding:15px;"><div id="teamTL"></div></div>
                        </div>
                    </div>
                    <div style="display:inline-block; vertical-align:top; width:23%; padding:0 8px; box-sizing:border-box;">
                        <div class="card" style="padding:0; margin-bottom:0;">
                            <div class="card-title"><div class="param-ttl" style="color:#047857;">Équipe IQ</div></div>
                            <div style="padding:15px;"><div id="teamIQ"></div></div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</body>
</html>
