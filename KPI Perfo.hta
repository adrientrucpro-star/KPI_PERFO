<!DOCTYPE html>
<html>
<head>
    <meta http-equiv="x-ua-compatible" content="IE=10">
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title>KPI Perfo</title>
    <script src="https://cdn.jsdelivr.net/npm/highcharts@6.2.0/highcharts.js"></script>
    <hta:application id="oApp" applicationname="KPIPerfo" border="thin" maximizebutton="yes" minimizebutton="yes" scroll="no" windowstate="maximize" />

    <style>
        /* ====================== STYLE GENERAL ====================== */
        * { box-sizing: border-box; }
        body { font-family: 'Segoe UI', Arial, sans-serif; background-color: #f0f4f7; color: #1e293b; margin: 0; padding: 0; height: 100vh; overflow: hidden; }

        /* ====================== ECRAN DE CONNEXION ====================== */
        #loginScreen { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background-color: #002d45; background-image: -ms-linear-gradient(135deg, #00263a 0%, #014a6f 100%); z-index: 9999; }
        .login-center { display: table; width: 100%; height: 100%; }
        .login-cell { display: table-cell; vertical-align: middle; text-align: center; }
        .login-box { display: inline-block; min-width: 500px; max-width: 560px; background: #ffffff; border-radius: 14px; box-shadow: 0 18px 50px rgba(0,0,0,0.45); text-align: center; padding: 0 0 38px 0; overflow: hidden; }
        .login-accent { height: 6px; width: 100%; background: #006698; background-image: -ms-linear-gradient(left, #006698 0%, #0ea5e9 100%); }
        .login-box h1 { color: #002d45; font-size: 26px; margin: 34px 0 4px 0; letter-spacing: 2px; font-weight: 800; }
        .login-box .login-sub { color: #94a3b8; font-size: 12px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 26px; }
        .login-box .login-divider { height: 1px; background: #eef2f5; margin: 0 38px 26px 38px; }
        .spinner-lg { border: 4px solid #e2e8f0; border-top: 4px solid #0284c7; border-radius: 50%; width: 38px; height: 38px; margin: 22px auto 4px auto; animation: spin 1s linear infinite; }
        .login-status { font-weight: 700; color: #334155; font-size: 14px; padding: 0 30px; line-height: 1.5; }
        .login-icon { width: 64px; height: 64px; border-radius: 50%; margin: 4px auto 18px auto; line-height: 64px; }
        .login-icon-ok { background: #ecfdf5; }
        .login-icon-ko { background: #fef2f2; }
        .login-title-ok { color: #059669; font-size: 19px; font-weight: 800; margin: 0 0 22px 0; }
        .login-title-ko { color: #dc2626; font-size: 19px; font-weight: 800; margin: 0 0 12px 0; }
        .login-btn { display: inline-block; background: #006698; color: #fff; border: none; border-radius: 8px; padding: 13px 30px; font-size: 14px; font-weight: 700; cursor: pointer; letter-spacing: .3px; box-shadow: 0 4px 12px rgba(0,102,152,0.35); }
        .login-btn:hover { background: #00557f; }
        .login-contact { margin: 18px 28px 0 28px; padding: 16px; background: #f8fafc; border: 1px solid #eef2f5; border-radius: 10px; color: #475569; font-size: 13px; line-height: 1.6; }
        .login-contact .lc-name { font-weight: 700; color: #334155; }
        .login-contact .lc-mail { color: #006698; font-weight: 700; word-break: break-all; }

        /* ====================== SIDEBAR ====================== */
        #sidebar { width: 260px; background-color: #002d45; height: 100vh; color: #f8fafc; position: fixed; left: 0; top: 0; z-index: 100; box-shadow: 3px 0 10px rgba(0,0,0,0.25); }
        #sidebar-header { padding: 24px 20px; border-bottom: 1px solid rgba(255,255,255,0.08); text-align: center; }
        #sidebar-header .app-logo { font-size: 22px; font-weight: 800; letter-spacing: 2px; color: #ffffff; }
        #sidebar-header .app-sub { font-size: 11px; font-weight: 700; letter-spacing: 2px; color: #7aafc7; margin-top: 6px; }
        .nav-item { padding: 16px 25px; cursor: pointer; color: #8fb8cc; font-size: 14px; font-weight: 500; display: block; border-left: 3px solid transparent; }
        .subtab { background: none; border: none; border-bottom: 3px solid transparent; padding: 10px 18px; margin-right: 4px; font-size: 14px; font-weight: 600; color: #64748b; cursor: pointer; font-family: inherit; }
        .subtab.active { color: #006698; border-bottom-color: #006698; }
        .nav-item:hover { background-color: rgba(0,102,152,0.25); color: #ffffff; border-left-color: #006698; }
        .nav-item.active { background-color: #006698; color: #ffffff; font-weight: 600; border-left-color: #E4342D; }
        #sidebar-footer { position: absolute; bottom: 0; left: 0; width: 100%; padding: 16px 20px; font-size: 13px; color: #7aafc7; text-align: center; font-weight: 500; }

        /* ====================== CONTENU ====================== */
        #content { margin-left: 260px; padding: 25px 35px; overflow-y: auto; height: 100vh; }
        .page { display: none; }
        .page.active { display: block; }
        h2 { font-size: 22px; margin-top: 0; color: #002d45; margin-bottom: 24px; font-weight: 700; }
        .card { background: white; border-radius: 8px; box-shadow: 0 1px 4px rgba(0,45,69,0.08); border: 1px solid #dde6ec; margin-bottom: 20px; padding: 20px 25px; }
        .card h3 { margin: 0 0 16px 0; font-size: 15px; color: #334155; font-weight: 700; }
        .dashCardNC, .dashCardOF, .dashCardIC, .dashCardPL { box-sizing: border-box; overflow: hidden; margin-bottom: 0; height: 300px; }
        .dashCardNC > h3, .dashCardOF > h3, .dashCardIC > h3, .dashCardPL > h3 { height: 32px; line-height: 16px; margin: 0 0 8px 0; font-size: 14px; color: #334155; font-weight: 700; overflow: hidden; }
        .dashChartNC, .dashChartOF, .dashChartIC, .dashChartPL { width: 100%; height: calc(100% - 40px); }
        .btn-view { width: 28px; height: 26px; padding: 0; border: none; border-radius: 5px; cursor: pointer; vertical-align: middle; background-color: #0C447C; background-repeat: no-repeat; background-position: center; background-image: url("data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSIxNCIgaGVpZ2h0PSIxNCIgdmlld0JveD0iMCAwIDI0IDI0IiBmaWxsPSJub25lIiBzdHJva2U9IiNmZmZmZmYiIHN0cm9rZS13aWR0aD0iMiI+PHBhdGggZD0iTTEgMTJzNC03IDExLTcgMTEgNyAxMSA3LTQgNy0xMSA3LTExLTctMTEtN3oiLz48Y2lyY2xlIGN4PSIxMiIgY3k9IjEyIiByPSIzIi8+PC9zdmc+"); }
        .btn-view:hover { background-color: #0a3a6a; }

        /* ====================== BOUTONS / CHAMPS ====================== */
        .btn-toolbar { font-weight: 600; font-size: 13px; height: 38px; line-height: 38px; padding: 0 20px; border: none; border-radius: 6px; cursor: pointer; color: white; display: inline-block; vertical-align: bottom; text-align: center; box-sizing: border-box; background-color: #006698; }
        .btn-toolbar:hover { background-color: #00557f; }
        .date-wrap { position: relative; display: inline-block; }
        .date-wrap .input-date { padding-right: 24px; }
        .btn-clear-date { position: absolute; right: 2px; top: 0; height: 38px; line-height: 38px; border: none; background: none; color: #94a3b8; font-size: 18px; cursor: pointer; padding: 0 6px; }
        .btn-clear-date:hover { color: #ef4444; }
        .nc-switch { display: inline-block; vertical-align: middle; width: 46px; height: 24px; border-radius: 12px; background: #16a34a; position: relative; cursor: pointer; margin-left: 8px; transition: background .2s; }
        .nc-switch .knob { position: absolute; top: 2px; left: 24px; width: 20px; height: 20px; border-radius: 50%; background: #fff; box-shadow: 0 1px 2px rgba(0,0,0,0.3); transition: left .2s; }
        .nc-switch.off { background: #dc2626; }
        .nc-switch.off .knob { left: 2px; }
        .dashPeriodSelect::-ms-expand { display: none; }   /* IE10 : retire la flèche du menu déroulant des filtres */
        .dashPeriodSelect { text-align: center; text-align-last: center; -ms-text-align-last: center; }   /* centre la valeur affichée (IE10) */
        .dashPeriodSelect option { text-align: center; }
        .btn-green { background-color: #10b981; } .btn-green:hover { background-color: #059669; }
        .btn-grey { background-color: #64748b; } .btn-grey:hover { background-color: #475569; }
        .btn-disabled { background-color: #94a3b8 !important; cursor: wait !important; color: #f1f5f9 !important; }
        .input-date { border: 1px solid #c5d5de; padding: 8px 12px; height: 38px; border-radius: 6px; font-family: inherit; font-size: 14px; color: #1e293b; background-color: #fff; width: 120px; box-sizing: border-box; cursor: pointer; text-align: center; }
        .input-text { border: 1px solid #c5d5de; padding: 8px 12px; height: 38px; border-radius: 6px; font-family: inherit; font-size: 14px; color: #1e293b; background-color: #fff; box-sizing: border-box; }
        .input-text:focus { border-color: #006698; outline: none; background-color: #fffbeb; }

        .msg-box { padding: 16px 20px; border-radius: 6px; margin-top: 12px; font-size: 14px; }
        .msg-error { background-color: #fee2e2; color: #b91c1c; border: 1px solid #fca5a5; font-weight: bold; }
        .msg-info { background-color: #ffffff; color: #64748b; border: 1px dashed #c5d5de; text-align: center; font-style: italic; }

        #btnScrollTop { position: fixed; bottom: 28px; right: 34px; width: 46px; height: 46px; border-radius: 50%; background: #006698; color: #ffffff; border: none; cursor: pointer; box-shadow: 0 4px 14px rgba(0,45,69,0.4); display: none; z-index: 500; font-size: 24px; font-weight: 700; line-height: 44px; text-align: center; padding: 0; }
        #btnScrollTop:hover { background: #00557f; }

        .spinner { border: 3px solid rgba(255,255,255,0.3); border-top: 3px solid #ffffff; border-radius: 50%; width: 18px; height: 18px; animation: spin 1s linear infinite; display: inline-block; vertical-align: middle; }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }

        /* ====================== TABLEAU ====================== */
        table.data-table { width: 100%; border-collapse: collapse; background: white; border: 2px solid #c5d5de; font-size: 13px; table-layout: fixed; }
        table.data-table th { background-color: #dde6ec; color: #334155; font-weight: 600; border: 1px solid #94a3b8; padding: 9px 8px; text-align: center; overflow: hidden; text-overflow: ellipsis; }
        table.data-table td { border: 1px solid #c5d5de; padding: 8px; color: #334155; vertical-align: middle; transition: background-color 0.3s; }
        table.data-table tr:hover td { background-color: #f5f9fb; }
        .badge { display: inline-block; font-size: 11px; font-weight: 700; padding: 2px 7px; border-radius: 10px; margin-right: 3px; }

        table.data-table td.cell-input { padding: 0 !important; height: 38px; }
        .cell-wrap { position: relative; width: 100%; height: 36px; }   /* conteneur relatif (IE ne gère pas position:relative sur td) */
        .excel-input { width: 100%; height: 36px; padding: 0 10px; line-height: 36px; border: none; background: transparent; font-family: inherit; font-size: 13px; color: #1e293b; box-sizing: border-box; }
        .excel-input:focus { outline: none; }   /* pas de surbrillance de focus sur les cases (selects) des Paramètres */
        select.excel-input::-ms-value { background: transparent; color: #1e293b; }
        input::-ms-clear { display: none; width: 0; height: 0; }
        select.excel-input::-ms-expand { display: none; }   /* masque la flèche : clic dans la case ouvre la liste */
        input:-ms-input-placeholder, textarea:-ms-input-placeholder { color: #94a3b8; }
        .card-title { padding: 13px 15px; border-bottom: 1px solid #eef2f5; }
        .param-ttl { font-size: 16px; font-weight: 700; text-align: center; }

        /* ====================== DATEPICKER ====================== */
        .datepicker-popup { position: absolute; background: #fff; border: 1px solid #c5d5de; box-shadow: 0 4px 6px -1px rgba(0,45,69,0.12); border-radius: 6px; padding: 15px; z-index: 9999; width: 250px; }
        .dp-header { text-align: center; margin-bottom: 15px; font-weight: bold; color: #002d45; font-size: 14px; }
        .dp-header button { background: #f0f4f7; border: 1px solid #c5d5de; border-radius: 4px; cursor: pointer; padding: 2px 10px; font-weight: bold; }
        .dp-header button.prev { float: left; } .dp-header button.next { float: right; }
        .dp-table { width: 100%; border-collapse: collapse; text-align: center; font-size: 13px; }
        .dp-table th { color: #64748b; font-weight: 600; padding-bottom: 8px; border: none; }
        .dp-table td { padding: 2px; cursor: pointer; border: none !important; }
        .dp-table td span { display: block; padding: 4px 0; border-radius: 4px; }
        .dp-table td:hover span { background-color: #006698; color: #fff; font-weight: bold; }
    </style>

    <script language="VBScript">
        ' ==========================================================
        ' SAP PEA - PLOMBERIE COMMUNE (réutilisée d'IC Manager)
        ' Conservée pour l'automatisation QM13 (phase 2).
        ' ==========================================================
        Dim oSession   ' session SAP GUI active

        Sub PauseVBS(secondes)
            On Error Resume Next
            Dim oVoice, oStream
            Set oVoice = CreateObject("SAPI.SpVoice")
            Set oStream = CreateObject("SAPI.SpMemoryStream")
            Set oVoice.AudioOutputStream = oStream
            oVoice.Speak "<silence msec='" & (secondes * 1000) & "'/>", 9
            oVoice.WaitUntilDone (secondes * 1000 + 500)
            Set oStream = Nothing : Set oVoice = Nothing
            On Error GoTo 0
        End Sub

        Function GetSAPSession()
            On Error Resume Next
            Set GetSAPSession = Nothing
            Dim SapGuiAuto, appSAP, conn
            Set SapGuiAuto = GetObject("SAPGUI")
            If Err.Number <> 0 Then Exit Function
            Set appSAP = SapGuiAuto.GetScriptingEngine
            If appSAP.Children.Count = 0 Then Exit Function
            Set conn = appSAP.Children(0)
            If conn.Children.Count = 0 Then Exit Function
            Set GetSAPSession = conn.Children(0)
        End Function

        Function AttendreElementSAP(cheminID, maxSecondes)
            Dim tentatives, obj
            tentatives = 0 : AttendreElementSAP = False
            On Error Resume Next
            Do While tentatives < maxSecondes
                Set obj = oSession.FindById(cheminID, False)
                If Not obj Is Nothing Then AttendreElementSAP = True : On Error GoTo 0 : Exit Function
                Call PauseVBS(1)
                tentatives = tentatives + 1
            Loop
            On Error GoTo 0
        End Function

        Function VBS_OuvrirQM03(strAvis)
            On Error Resume Next
            Set oSession = GetSAPSession()
            If oSession Is Nothing Then
                VBS_OuvrirQM03 = "ERREUR : SAP inaccessible. Ouvre SAP Logon et connecte-toi."
                Exit Function
            End If
            oSession.FindById("wnd[0]").Maximize
            oSession.FindById("wnd[0]/tbar[0]/okcd").Text = "/nqm03"
            oSession.FindById("wnd[0]").SendVKey 0
            If Not AttendreElementSAP("wnd[0]/usr/ctxtRIWO00-QMNUM", 8) Then
                VBS_OuvrirQM03 = "ERREUR : l'écran QM03 n'a pas démarré."
                Exit Function
            End If
            oSession.FindById("wnd[0]/usr/ctxtRIWO00-QMNUM").Text = strAvis
            oSession.FindById("wnd[0]").SendVKey 0
            If Err.Number <> 0 Then
                VBS_OuvrirQM03 = "ERREUR : impossible d'ouvrir l'avis " & strAvis & "."
                Exit Function
            End If
            oSession.FindById("wnd[0]").Maximize
            Dim wshAct
            Set wshAct = CreateObject("WScript.Shell")
            wshAct.AppActivate oSession.FindById("wnd[0]").Text
            VBS_OuvrirQM03 = "OK"
            On Error GoTo 0
        End Function

        Function VBS_OuvrirCO03(strOF)
            On Error Resume Next
            Set oSession = GetSAPSession()
            If oSession Is Nothing Then
                VBS_OuvrirCO03 = "ERREUR : SAP inaccessible. Ouvre SAP Logon et connecte-toi."
                Exit Function
            End If
            oSession.FindById("wnd[0]").Maximize
            oSession.FindById("wnd[0]/tbar[0]/okcd").Text = "/nco03"
            oSession.FindById("wnd[0]").SendVKey 0
            If Not AttendreElementSAP("wnd[0]/usr/ctxtCAUFVD-AUFNR", 8) Then
                VBS_OuvrirCO03 = "ERREUR : l'écran CO03 n'a pas démarré."
                Exit Function
            End If
            oSession.FindById("wnd[0]/usr/ctxtCAUFVD-AUFNR").Text = strOF
            oSession.FindById("wnd[0]").SendVKey 0
            If Err.Number <> 0 Then
                VBS_OuvrirCO03 = "ERREUR : impossible d'ouvrir l'ordre " & strOF & "."
                Exit Function
            End If
            oSession.FindById("wnd[0]").Maximize
            Dim wshActOF
            Set wshActOF = CreateObject("WScript.Shell")
            wshActOF.AppActivate oSession.FindById("wnd[0]").Text
            VBS_OuvrirCO03 = "OK"
            On Error GoTo 0
        End Function

        Function VBS_ExtractQM13(strDateLow, strDateHigh)
            On Error Resume Next
            Dim wsh, fso, folderPath, exportPath, popupCheck, maxRetries, currentRetry, fileReady

            Set wsh = CreateObject("WScript.Shell")
            folderPath = wsh.ExpandEnvironmentStrings("%APPDATA%") & "\KPI_Perfo"
            Set fso = CreateObject("Scripting.FileSystemObject")
            If Not fso.FolderExists(folderPath) Then fso.CreateFolder(folderPath)
            exportPath = folderPath & "\EXPORT_NC.txt"
            If fso.FileExists(exportPath) Then fso.DeleteFile exportPath, True

            Set oSession = GetSAPSession()
            If oSession Is Nothing Then
                VBS_ExtractQM13 = "ERREUR : SAP inaccessible. Ouvre SAP Logon et connecte-toi."
                Exit Function
            End If

            oSession.FindById("wnd[0]").Maximize
            oSession.FindById("wnd[0]/tbar[0]/okcd").Text = "/nqm13"
            oSession.FindById("wnd[0]").SendVKey 0
            If Not AttendreElementSAP("wnd[0]/tbar[1]/btn[17]", 8) Then
                VBS_ExtractQM13 = "ERREUR : QM13 n'a pas démarré."
                Exit Function
            End If

            oSession.FindById("wnd[0]/tbar[1]/btn[17]").Press
            If AttendreElementSAP("wnd[1]/usr/txtV-LOW", 5) Then
                oSession.FindById("wnd[1]/usr/txtV-LOW").Text = "LAROCHE_NC"
                If Not (oSession.FindById("wnd[1]/usr/txtENAME-LOW", False) Is Nothing) Then oSession.FindById("wnd[1]/usr/txtENAME-LOW").Text = ""
                oSession.FindById("wnd[1]/tbar[0]/btn[8]").Press
            End If

            If Not AttendreElementSAP("wnd[0]/usr/ctxtQMDAT-LOW", 5) Then
                VBS_ExtractQM13 = "ERREUR : champ date introuvable."
                Exit Function
            End If
            oSession.FindById("wnd[0]/usr/ctxtQMDAT-LOW").Text = strDateLow
            If strDateHigh <> "" Then oSession.FindById("wnd[0]/usr/ctxtQMDAT-HIGH").Text = strDateHigh
            oSession.FindById("wnd[0]/tbar[1]/btn[8]").Press

            oSession.FindById("wnd[0]/mbar/menu[0]/menu[3]/menu[2]").Select
            Set popupCheck = oSession.FindById("wnd[1]", False)
            If popupCheck Is Nothing Then
                VBS_ExtractQM13 = "ERREUR : aucune NC à exporter pour cette période."
                Exit Function
            End If
            oSession.FindById("wnd[1]/usr/subSUBSCREEN_STEPLOOP:SAPLSPO5:0150/sub:SAPLSPO5:0150/radSPOPLI-SELFLAG[1,0]").Select
            oSession.FindById("wnd[1]/tbar[0]/btn[0]").Press
            oSession.FindById("wnd[1]/usr/ctxtDY_PATH").Text = folderPath
            oSession.FindById("wnd[1]/usr/ctxtDY_FILENAME").Text = "EXPORT_NC.txt"
            oSession.FindById("wnd[1]/tbar[0]/btn[0]").Press

            maxRetries = 40 : currentRetry = 0 : fileReady = False
            Do While Not fileReady And currentRetry < maxRetries
                If fso.FileExists(exportPath) Then
                    If fso.GetFile(exportPath).Size > 0 Then fileReady = True
                End If
                If Not fileReady Then
                    Call PauseVBS(1)
                    currentRetry = currentRetry + 1
                End If
            Loop

            oSession.EndTransaction
            If Not fileReady Then
                VBS_ExtractQM13 = "ERREUR : délai dépassé, fichier non généré."
                Exit Function
            End If
            VBS_ExtractQM13 = "OK"
            On Error GoTo 0
        End Function

        Function VBS_ExtractCOOIS(varNom, dateField, strLow, strHigh, fileName, doExpand)
            On Error Resume Next
            Dim wsh, fso, folderPath, exportPath, shellId, base, maxRetries, currentRetry, fileReady
            Set wsh = CreateObject("WScript.Shell")
            folderPath = wsh.ExpandEnvironmentStrings("%APPDATA%") & "\KPI_Perfo"
            Set fso = CreateObject("Scripting.FileSystemObject")
            If Not fso.FolderExists(folderPath) Then fso.CreateFolder(folderPath)
            exportPath = folderPath & "\" & fileName
            If fso.FileExists(exportPath) Then fso.DeleteFile exportPath, True

            Set oSession = GetSAPSession()
            If oSession Is Nothing Then
                VBS_ExtractCOOIS = "ERREUR : SAP inaccessible. Ouvre SAP Logon et connecte-toi."
                Exit Function
            End If
            oSession.FindById("wnd[0]").Maximize
            oSession.FindById("wnd[0]/tbar[0]/okcd").Text = "/ncoois"
            oSession.FindById("wnd[0]").SendVKey 0
            If Not AttendreElementSAP("wnd[0]/tbar[1]/btn[17]", 8) Then
                VBS_ExtractCOOIS = "ERREUR : COOIS n'a pas démarré."
                Exit Function
            End If
            oSession.FindById("wnd[0]/tbar[1]/btn[17]").Press
            If AttendreElementSAP("wnd[1]/usr/txtV-LOW", 5) Then
                oSession.FindById("wnd[1]/usr/txtV-LOW").Text = varNom
                If Not (oSession.FindById("wnd[1]/usr/txtENAME-LOW", False) Is Nothing) Then oSession.FindById("wnd[1]/usr/txtENAME-LOW").Text = ""
                oSession.FindById("wnd[1]/tbar[0]/btn[8]").Press
            End If
            base = "wnd[0]/usr/tabsTABSTRIP_SELBLOCK/tabpSEL_00/ssub%_SUBSCREEN_SELBLOCK:PPIO_ENTRY:1200/ctxt" & dateField
            If Not AttendreElementSAP(base & "-LOW", 5) Then
                VBS_ExtractCOOIS = "ERREUR : champ date introuvable (variante " & varNom & " ?)."
                Exit Function
            End If
            oSession.FindById(base & "-LOW").Text = strLow
            oSession.FindById(base & "-HIGH").Text = strHigh
            oSession.FindById("wnd[0]/tbar[1]/btn[8]").Press
            shellId = "wnd[0]/usr/cntlCUSTOM/shellcont/shell/shellcont/shell"
            If Not AttendreElementSAP(shellId, 8) Then
                VBS_ExtractCOOIS = "ERREUR : aucun OF pour cette période."
                Exit Function
            End If
            If doExpand Then oSession.FindById(shellId).PressToolbarButton "&NAVIGATION_PROFILE_TOOLBAR_EXPAND"
            oSession.FindById(shellId).PressToolbarContextButton "&MB_EXPORT"
            oSession.FindById(shellId).SelectContextMenuItem "&PC"
            If AttendreElementSAP("wnd[1]/usr/subSUBSCREEN_STEPLOOP:SAPLSPO5:0150/sub:SAPLSPO5:0150/radSPOPLI-SELFLAG[1,0]", 5) Then
                oSession.FindById("wnd[1]/usr/subSUBSCREEN_STEPLOOP:SAPLSPO5:0150/sub:SAPLSPO5:0150/radSPOPLI-SELFLAG[1,0]").Select
                oSession.FindById("wnd[1]/tbar[0]/btn[0]").Press
            End If
            oSession.FindById("wnd[1]/usr/ctxtDY_PATH").Text = folderPath
            oSession.FindById("wnd[1]/usr/ctxtDY_FILENAME").Text = fileName
            oSession.FindById("wnd[1]/tbar[0]/btn[0]").Press
            maxRetries = 40 : currentRetry = 0 : fileReady = False
            Do While Not fileReady And currentRetry < maxRetries
                If fso.FileExists(exportPath) Then
                    If fso.GetFile(exportPath).Size > 0 Then fileReady = True
                End If
                If Not fileReady Then Call PauseVBS(1) : currentRetry = currentRetry + 1
            Loop
            oSession.EndTransaction
            If Not fileReady Then
                VBS_ExtractCOOIS = "ERREUR : délai dépassé, fichier non généré."
                Exit Function
            End If
            VBS_ExtractCOOIS = "OK"
            On Error GoTo 0
        End Function
        Function VBS_ExtractOFCree(strLow, strHigh)   ' OFs créés (ST)
            VBS_ExtractOFCree = VBS_ExtractCOOIS("LAROCHE_ST", "S_ECKST", strLow, strHigh, "EXPORT_ST.txt", False)
        End Function
        Function VBS_ExtractOFClotUser(strLow, strHigh)   ' Clôture : user + date + heure (variante IQ1, multi-lignes) -> EXPORT_IQ1.txt
            ' doExpand=True : la variante IQ1 nécessite de déplier la barre d'outils ALV (&NAVIGATION_PROFILE_TOOLBAR_EXPAND) avant d'ouvrir le menu Export (cf. script SAP)
            VBS_ExtractOFClotUser = VBS_ExtractCOOIS("LAROCHE_IQ1", "S_TERST", strLow, strHigh, "EXPORT_IQ1.txt", True)
        End Function
        Function VBS_ExtractOFClotMSN(strLow, strHigh)   ' Clôture : OF + MSN (variante IQ2) -> EXPORT_IQ2.txt
            VBS_ExtractOFClotMSN = VBS_ExtractCOOIS("LAROCHE_IQ2", "S_TERST", strLow, strHigh, "EXPORT_IQ2.txt", False)
        End Function
        Function VBS_ExtractIC(strDateLow, strDateHigh)
            On Error Resume Next
            Dim wsh, fso, folderPath, exportPath, popupCheck, maxRetries, currentRetry, fileReady
            Set wsh = CreateObject("WScript.Shell")
            folderPath = wsh.ExpandEnvironmentStrings("%APPDATA%") & "\KPI_Perfo"
            Set fso = CreateObject("Scripting.FileSystemObject")
            If Not fso.FolderExists(folderPath) Then fso.CreateFolder(folderPath)
            exportPath = folderPath & "\EXPORT_IC.txt"
            If fso.FileExists(exportPath) Then fso.DeleteFile exportPath, True

            Set oSession = GetSAPSession()
            If oSession Is Nothing Then
                VBS_ExtractIC = "ERREUR : SAP inaccessible. Ouvre SAP Logon et connecte-toi."
                Exit Function
            End If
            oSession.FindById("wnd[0]").Maximize
            oSession.FindById("wnd[0]/tbar[0]/okcd").Text = "/nqm11"
            oSession.FindById("wnd[0]").SendVKey 0
            If Not AttendreElementSAP("wnd[0]/tbar[1]/btn[17]", 8) Then
                VBS_ExtractIC = "ERREUR : QM11 n'a pas démarré."
                Exit Function
            End If
            oSession.FindById("wnd[0]/tbar[1]/btn[17]").Press
            If AttendreElementSAP("wnd[1]/usr/txtV-LOW", 5) Then
                oSession.FindById("wnd[1]/usr/txtV-LOW").Text = "LAROCHE_IC2"
                If Not (oSession.FindById("wnd[1]/usr/txtENAME-LOW", False) Is Nothing) Then oSession.FindById("wnd[1]/usr/txtENAME-LOW").Text = ""
                oSession.FindById("wnd[1]/tbar[0]/btn[8]").Press
            End If
            If Not AttendreElementSAP("wnd[0]/usr/ctxtQMDAT-LOW", 5) Then
                VBS_ExtractIC = "ERREUR : champ date introuvable."
                Exit Function
            End If
            oSession.FindById("wnd[0]/usr/ctxtQMDAT-LOW").Text = strDateLow
            If strDateHigh <> "" Then oSession.FindById("wnd[0]/usr/ctxtQMDAT-HIGH").Text = strDateHigh
            oSession.FindById("wnd[0]/tbar[1]/btn[8]").Press
            oSession.FindById("wnd[0]/mbar/menu[0]/menu[3]/menu[2]").Select
            Set popupCheck = oSession.FindById("wnd[1]", False)
            If popupCheck Is Nothing Then
                VBS_ExtractIC = "ERREUR : aucune IC à exporter pour cette période."
                Exit Function
            End If
            oSession.FindById("wnd[1]/usr/subSUBSCREEN_STEPLOOP:SAPLSPO5:0150/sub:SAPLSPO5:0150/radSPOPLI-SELFLAG[1,0]").Select
            oSession.FindById("wnd[1]/tbar[0]/btn[0]").Press
            oSession.FindById("wnd[1]/usr/ctxtDY_PATH").Text = folderPath
            oSession.FindById("wnd[1]/usr/ctxtDY_FILENAME").Text = "EXPORT_IC.txt"
            oSession.FindById("wnd[1]/tbar[0]/btn[0]").Press
            maxRetries = 40 : currentRetry = 0 : fileReady = False
            Do While Not fileReady And currentRetry < maxRetries
                If fso.FileExists(exportPath) Then
                    If fso.GetFile(exportPath).Size > 0 Then fileReady = True
                End If
                If Not fileReady Then Call PauseVBS(1) : currentRetry = currentRetry + 1
            Loop
            oSession.EndTransaction
            If Not fileReady Then
                VBS_ExtractIC = "ERREUR : délai dépassé, fichier non généré."
                Exit Function
            End If
            VBS_ExtractIC = "OK"
            On Error GoTo 0
        End Function

        Function VBS_ExtractNCMSN(strDateLow, strDateHigh)
            On Error Resume Next
            Dim wsh, fso, folderPath, exportPath, popupCheck, maxRetries, currentRetry, fileReady
            Set wsh = CreateObject("WScript.Shell")
            folderPath = wsh.ExpandEnvironmentStrings("%APPDATA%") & "\KPI_Perfo"
            Set fso = CreateObject("Scripting.FileSystemObject")
            If Not fso.FolderExists(folderPath) Then fso.CreateFolder(folderPath)
            exportPath = folderPath & "\EXPORT_NC2.txt"
            If fso.FileExists(exportPath) Then fso.DeleteFile exportPath, True

            Set oSession = GetSAPSession()
            If oSession Is Nothing Then
                VBS_ExtractNCMSN = "ERREUR : SAP inaccessible. Ouvre SAP Logon et connecte-toi."
                Exit Function
            End If
            oSession.FindById("wnd[0]").Maximize
            oSession.FindById("wnd[0]/tbar[0]/okcd").Text = "/nqm11"
            oSession.FindById("wnd[0]").SendVKey 0
            If Not AttendreElementSAP("wnd[0]/tbar[1]/btn[17]", 8) Then
                VBS_ExtractNCMSN = "ERREUR : QM11 n'a pas démarré."
                Exit Function
            End If
            oSession.FindById("wnd[0]/tbar[1]/btn[17]").Press
            If AttendreElementSAP("wnd[1]/usr/txtV-LOW", 5) Then
                oSession.FindById("wnd[1]/usr/txtV-LOW").Text = "LAROCHE_NC2"
                If Not (oSession.FindById("wnd[1]/usr/txtENAME-LOW", False) Is Nothing) Then oSession.FindById("wnd[1]/usr/txtENAME-LOW").Text = ""
                oSession.FindById("wnd[1]/tbar[0]/btn[8]").Press
            End If
            If Not AttendreElementSAP("wnd[0]/usr/ctxtQMDAT-LOW", 5) Then
                VBS_ExtractNCMSN = "ERREUR : champ date introuvable."
                Exit Function
            End If
            oSession.FindById("wnd[0]/usr/ctxtQMDAT-LOW").Text = strDateLow
            If strDateHigh <> "" Then oSession.FindById("wnd[0]/usr/ctxtQMDAT-HIGH").Text = strDateHigh
            oSession.FindById("wnd[0]/tbar[1]/btn[8]").Press
            oSession.FindById("wnd[0]/mbar/menu[0]/menu[3]/menu[2]").Select
            Set popupCheck = oSession.FindById("wnd[1]", False)
            If popupCheck Is Nothing Then
                VBS_ExtractNCMSN = "ERREUR : aucune donnée MSN à exporter pour cette période."
                Exit Function
            End If
            oSession.FindById("wnd[1]/usr/subSUBSCREEN_STEPLOOP:SAPLSPO5:0150/sub:SAPLSPO5:0150/radSPOPLI-SELFLAG[1,0]").Select
            oSession.FindById("wnd[1]/tbar[0]/btn[0]").Press
            oSession.FindById("wnd[1]/usr/ctxtDY_PATH").Text = folderPath
            oSession.FindById("wnd[1]/usr/ctxtDY_FILENAME").Text = "EXPORT_NC2.txt"
            oSession.FindById("wnd[1]/tbar[0]/btn[0]").Press
            maxRetries = 40 : currentRetry = 0 : fileReady = False
            Do While Not fileReady And currentRetry < maxRetries
                If fso.FileExists(exportPath) Then
                    If fso.GetFile(exportPath).Size > 0 Then fileReady = True
                End If
                If Not fileReady Then Call PauseVBS(1) : currentRetry = currentRetry + 1
            Loop
            oSession.EndTransaction
            If Not fileReady Then
                VBS_ExtractNCMSN = "ERREUR : délai dépassé, fichier non généré."
                Exit Function
            End If
            VBS_ExtractNCMSN = "OK"
            On Error GoTo 0
        End Function
    </script>

    <script language="javascript">
    // ==========================================================
    // CONFIGURATION DE L'APPLICATION
    // ==========================================================
        var APP_NAME        = "KPI PERFO";
        var APP_SOUS_TITRE  = "ANALYSE NC, OF et IC";
        var VERSION_ACTUELLE = "1.4";
        var DOSSIER_DONNEES = "KPI_Perfo";               // %APPDATA%\KPI_Perfo\
        var CLOTURE_CODE = "APQ0";                       // défaut : code SAP de clôture qualité
        var CLOTURE_RESP = "70005848";                   // Responsable qualité dont l'APQ0 marque la clôture
        var DECISION_CODE = "DEC0";                      // défaut : code SAP de la décision technique
        var DECISION_RESP = "70009001;70005847";         // défaut : Responsables CT (décision)
        var SHARE_GIST_ID = "8a40ac55fc606b8ad0358b7b3e3c396a";
        var SHARE_FILE = "KPI_PERFO_DATA.json";
        var SHARE_TOKEN = "";
        function cfgVal(k, def) { return (appData.cfg && NettoyerChaine(appData.cfg[k]) !== "") ? NettoyerChaine(appData.cfg[k]) : def; }
        var LIEN_CONFIG_APP = "https://gist.githubusercontent.com/adrientrucexternal/9006613d5966adaa40d408cdb3bd1068/raw";
        var URL_TELECHARGEMENT_APP = "https://github.com/adrientrucpro-star/KPI_PERFO";

    // ==========================================================
    // DONNÉES GLOBALES
    // ==========================================================
        var appData = {};        // persisté : { roles:{}, seen:{}, rows:[], lastImport:"" }
        var ncList = [];         // NC agrégées (recalculé en mémoire)

        function compareVersions(a, b) {
            var pa = (""+a).split('.'), pb = (""+b).split('.');
            for (var i = 0; i < Math.max(pa.length, pb.length); i++) {
                var va = parseInt(pa[i] || 0, 10), vb = parseInt(pb[i] || 0, 10);
                if (va !== vb) return va - vb;
            }
            return 0;
        }
        function NettoyerChaine(s) { return (s == null) ? "" : (""+s).replace(/^\s+|\s+$/g, ""); }
        function nomSeul(full) {
            var s = NettoyerChaine(full); var sp = s.indexOf(' ');
            return sp === -1 ? s : s.substring(sp + 1);
        }
        function escapeHtml(t) {
            if (t == null) return "";
            return (""+t).replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;").replace(/'/g,"&#39;");
        }
        function AfficherErreur(msg) { alert(msg); }
        function AlerteExtract(msg) { AfficherErreur(msg); }

    // ==========================================================
    // PERSISTANCE JSON  (%APPDATA%\<DOSSIER_DONNEES>\APP_DATA.txt)
    // ==========================================================
        function getAppDataFilePath() {
            try {
                var sh = new ActiveXObject("WScript.Shell");
                var folder = sh.ExpandEnvironmentStrings("%APPDATA%") + "\\" + DOSSIER_DONNEES;
                var fso = new ActiveXObject("Scripting.FileSystemObject");
                if (!fso.FolderExists(folder)) fso.CreateFolder(folder);
                return folder + "\\APP_DATA.txt";
            } catch (e) { return ""; }
        }
        function LoadData() {
            try {
                var fso = new ActiveXObject("Scripting.FileSystemObject");
                var path = getAppDataFilePath();
                if (path && fso.FileExists(path)) {
                    var f = fso.OpenTextFile(path, 1, false, -1);
                    var c = f.ReadAll(); f.Close();
                    appData = (NettoyerChaine(c) !== "") ? JSON.parse(c) : {};
                } else { appData = {}; }
            } catch (e) { appData = {}; }
            if (!appData.roleDesig) appData.roleDesig = [];   // tableau 1 saisi manuellement : [{resp,nom}]
            if (!appData.respAutres) appData.respAutres = []; // responsables "autres" à analyser : [{resp,nom}]
            if (!appData.rows)   appData.rows   = [];
            if (!appData.teamST) appData.teamST = [];
            if (!appData.teamTL) appData.teamTL = [];
            if (!appData.teamIQ) appData.teamIQ = [];
            if (!appData.comments) appData.comments = {};   // commentaires par NC : { "<avis>": "texte" }
            if (!appData.selLine) appData.selLine = {};      // ligne "Départ" sélectionnée par NC : { "<avis>": "<Nº>" }
            if (!appData.excluded) appData.excluded = {};    // NC exclues manuellement : { "<avis>": true }
            if (!appData.ofCree) appData.ofCree = [];        // OF créés (EXPORT_ST) : [{of,user,date,heure}]
            if (!appData.ofClot) appData.ofClot = [];        // OF clôturés (EXPORT_IQ)
            if (!appData.lastOFImport) appData.lastOFImport = "";   // date/heure de la dernière extraction OF
            if (!appData.icRows) appData.icRows = [];        // Interventions Cards : [{ic,user,dfa,hfa,dc,hc}]
            if (!appData.lastICImport) appData.lastICImport = "";
            if (!appData.planif) appData.planif = [];        // Planification (CSV hebdo) : [{ofnc,msn,sujet,statut,date,vac}]
            if (!appData.planifFile) appData.planifFile = "";   // nom du dernier CSV chargé
            if (!appData.planifImport) appData.planifImport = "";
            if (!appData.cfg) appData.cfg = {};             // réglages éditables (codes SAP)
            if (!NettoyerChaine(appData.cfg.clot)) appData.cfg.clot = CLOTURE_CODE;
            if (!NettoyerChaine(appData.cfg.dec)) appData.cfg.dec = DECISION_CODE;
            if (!NettoyerChaine(appData.cfg.decResp)) appData.cfg.decResp = DECISION_RESP;
            if (!appData.calc) appData.calc = {};           // mode de calcul des durées
            if (!appData.calc.mode) appData.calc.mode = 'cal';      // 'cal' = 7j/7j, 'ouvre' = jours ouvrés (lun-ven)
            if (!appData.share) appData.share = { token: "" };      // base partagée : token GitHub (local, par poste)
            for (var mi = 0; mi < appData.roleDesig.length; mi++) { if (appData.roleDesig[mi].type === undefined) appData.roleDesig[mi].type = "int"; }
            if (appData.respAutres && appData.respAutres.length) {
                for (var ami = 0; ami < appData.respAutres.length; ami++) {
                    var raM = appData.respAutres[ami];
                    if (NettoyerChaine(raM.resp) !== "") appData.roleDesig.push({ resp: raM.resp, nom: raM.nom || "", type: "ext" });
                }
            }
            appData.respAutres = [];
        }
        function BuildSaveObject() {
            var eligAvis = {};
            for (var i = 0; i < ncList.length; i++) { if (ncList[i].eligRaw) eligAvis[ncList[i].avis] = true; }
            var allRows = appData.rows || [], savedRows = [];
            for (var j = 0; j < allRows.length; j++) { if (eligAvis[allRows[j].a]) savedRows.push(allRows[j]); }
            return {
                rows: savedRows,
                roleDesig: appData.roleDesig || [],
                teamST: appData.teamST || [], teamTL: appData.teamTL || [], teamIQ: appData.teamIQ || [],
                comments: appData.comments || {},   // toujours conservés (annotations partagées), indépendamment de l'éligibilité des NC
                selLine: appData.selLine || {},
                excluded: appData.excluded || {},
                ofCree: appData.ofCree || [],
                ofClot: appData.ofClot || [],
                lastOFImport: appData.lastOFImport || "",
                icRows: appData.icRows || [],
                lastICImport: appData.lastICImport || "",
                planif: appData.planif || [],
                planifFile: appData.planifFile || "",
                planifImport: appData.planifImport || "",
                msnByAvis: appData.msnByAvis || {},
                cfg: appData.cfg || {},
                calc: appData.calc || {},
                share: appData.share || { token: "" },
                lastImport: appData.lastImport || ""
            };
        }
        function SaveData() {
            try {
                var path = getAppDataFilePath();
                if (!path) return;
                var fso = new ActiveXObject("Scripting.FileSystemObject");
                var tmp = path + ".tmp";
                var f = fso.CreateTextFile(tmp, true, true);
                f.Write(toJSON(BuildSaveObject())); f.Close();
                if (fso.FileExists(path)) fso.DeleteFile(path);
                fso.MoveFile(tmp, path);
            } catch (e) { AfficherErreur("Erreur de sauvegarde : " + e.message); }
        }

        function toJSON(v) {
            if (v === null || v === undefined) return "null";
            var t = typeof v;
            if (t === "number") return isFinite(v) ? (""+v) : "null";
            if (t === "boolean") return v ? "true" : "false";
            if (t === "string") return '"' + v.replace(/\\/g,"\\\\").replace(/"/g,'\\"').replace(/\r/g,"\\r").replace(/\n/g,"\\n").replace(/\t/g,"\\t") + '"';
            if (v instanceof Array) {
                var a = [];
                for (var i = 0; i < v.length; i++) a.push(toJSON(v[i]));
                return "[" + a.join(",") + "]";
            }
            var o = [];
            for (var k in v) { if (v.hasOwnProperty(k)) o.push(toJSON(""+k) + ":" + toJSON(v[k])); }
            return "{" + o.join(",") + "}";
        }

    // ==========================================================
    // BASE PARTAGÉE : commentaires + sélection "Départ" via un Gist privé.
    // Token saisi par poste (Paramètres, stocké en local) ; ID du Gist en dur (SHARE_GIST_ID).
    // ==========================================================
        function shareToken() { return NettoyerChaine(SHARE_TOKEN) || (appData.share && NettoyerChaine(appData.share.token)) || ""; }
        function shareConfigured() { return shareToken() !== "" && SHARE_GIST_ID !== ""; }
        function shareRead(cb) {
            if (!shareConfigured()) { if (cb) cb(null); return; }
            try {
                var xhr = new ActiveXObject("MSXML2.XMLHTTP.6.0");
                xhr.open("GET", "https://api.github.com/gists/" + SHARE_GIST_ID + "?t=" + new Date().getTime(), true);
                xhr.setRequestHeader("Authorization", "token " + shareToken());
                xhr.setRequestHeader("Accept", "application/vnd.github+json");
                try { xhr.setRequestHeader("User-Agent", "KPI-Perfo"); } catch (eUA) {}
                xhr.onreadystatechange = function () {
                    if (xhr.readyState !== 4) return;
                    if (xhr.status !== 200) { if (cb) cb(null); return; }
                    try {
                        var g = JSON.parse(xhr.responseText);
                        var f = g.files && g.files[SHARE_FILE];
                        var d = (f && NettoyerChaine(f.content) !== "") ? JSON.parse(f.content) : {};
                        if (cb) cb(d);
                    } catch (e) { if (cb) cb(null); }
                };
                xhr.send();
            } catch (e) { if (cb) cb(null); }
        }
        function shareApply(d) {
            if (!d) return false;
            var changed = false, a;
            if (d.comments) { if (!appData.comments) appData.comments = {}; for (a in d.comments) { if (d.comments.hasOwnProperty(a) && appData.comments[a] !== d.comments[a]) { appData.comments[a] = d.comments[a]; changed = true; } } }
            if (d.selLine) { if (!appData.selLine) appData.selLine = {}; for (a in d.selLine) { if (d.selLine.hasOwnProperty(a) && appData.selLine[a] !== d.selLine[a]) { appData.selLine[a] = d.selLine[a]; changed = true; } } }
            return changed;
        }
        var syncState = 'off', syncRefreshing = false;
        function setSyncState(s) { syncState = s; UpdateSyncIndicator(); }
        function UpdateSyncIndicator() {
            var el = document.getElementById('sidebar-footer'); if (!el) return;
            var color, label;
            if (syncRefreshing) { color = "#38bdf8"; label = "Actualisation…"; }
            else if (!shareConfigured()) { color = "#64748b"; label = "Synchronisation inactive"; }
            else if (syncState === 'error') { color = "#f59e0b"; label = "Synchronisation : erreur"; }
            else { color = "#22c55e"; label = "Synchronisation active"; }
            el.innerHTML = "<div onclick='RafraichirGist()' title='Actualiser depuis le Gist (config équipes/responsables/version + données partagées)' style='cursor:pointer; padding-bottom:12px;'>"
                + "<span style='display:inline-block; width:8px; height:8px; border-radius:50%; background:" + color + "; margin-right:7px; vertical-align:middle;'></span>"
                + "<span style='vertical-align:middle;'>" + label + "</span>"
                + "<span style='margin-left:8px; vertical-align:middle; font-size:15px; font-weight:700;'>&#x21BB;</span></div>"
                + "<div style='border-top:1px solid rgba(255,255,255,0.08); padding-top:12px; font-size:12px; color:#5f95af;'>v" + VERSION_ACTUELLE + " - © Adrien Truc</div>";
        }
        function RafraichirGist() {
            syncRefreshing = true; UpdateSyncIndicator();
            setTimeout(function () { syncRefreshing = false; UpdateSyncIndicator(); }, 1500);
            try {   // 1) Gist de config (cache-buster frais -> force la relecture, pas le cache 5 min)
                var xhr = new ActiveXObject("MSXML2.XMLHTTP.6.0");
                xhr.open("GET", LIEN_CONFIG_APP + "?t=" + new Date().getTime(), true);
                xhr.onreadystatechange = function () {
                    if (xhr.readyState !== 4 || xhr.status !== 200) return;
                    var cfg = ParseGistConfig(xhr.responseText);
                    if (cfg.version === "" && cfg.users.length === 0) return;
                    window.gistCfg = cfg;
                    var pp = document.getElementById('pageParametres');
                    if (pp && pp.className.indexOf('active') !== -1) { pageValid.parametres = false; RenderParametres(); }   // maj menus déroulants
                    if (cfg.version !== "" && compareVersions(cfg.version, VERSION_ACTUELLE) > 0)
                        AfficherErreur("Nouvelle version disponible : v" + cfg.version + "\n\nRecharge l'application depuis :\n" + URL_TELECHARGEMENT_APP);
                };
                xhr.send();
            } catch (e) {}
            shareLoad();   // 2) données partagées (commentaires + sélections des collègues)
        }
        function shareLoad() {
            shareRead(function (d) {
                setSyncState(d != null ? 'ok' : (shareConfigured() ? 'error' : 'off'));
                if (!shareApply(d)) return;
                SaveData();
                if (typeof RecomputeAll === 'function') RecomputeAll();   // selLine impacte les durées
                InvalidateDash(); InvalidatePages(); InvalidateExtract();
                var pp = document.getElementById('pageParcours');
                if (pp && pp.className.indexOf('active') !== -1) RenderParcours();
                var pd = document.getElementById('pageDashboard');
                if (pd && pd.className.indexOf('active') !== -1) RenderDashIfNeeded();
            });
        }
        var pendingShare = { comments: {}, selLine: {} }, shareWriteTimer = null;
        function shareQueueComment(avis, val) { if (!shareConfigured()) return; pendingShare.comments[avis] = val; shareScheduleFlush(); }
        function shareQueueSel(avis, val) { if (!shareConfigured()) return; pendingShare.selLine[avis] = val; shareScheduleFlush(); }
        function shareScheduleFlush() { if (shareWriteTimer) clearTimeout(shareWriteTimer); shareWriteTimer = setTimeout(shareFlush, 800); }
        function shareFlush() {
            shareWriteTimer = null;
            if (!shareConfigured()) return;
            var pc = pendingShare; pendingShare = { comments: {}, selLine: {} };
            shareRead(function (remote) {
                if (remote == null) {   // lecture échouée -> NE PAS écrire (sinon on écrase toute la base) ; on remet les modifs en attente
                    var c, s;
                    for (c in pc.comments) { if (pc.comments.hasOwnProperty(c)) pendingShare.comments[c] = pc.comments[c]; }
                    for (s in pc.selLine) { if (pc.selLine.hasOwnProperty(s)) pendingShare.selLine[s] = pc.selLine[s]; }
                    setSyncState('error'); return;
                }
                if (!remote.comments) remote.comments = {}; if (!remote.selLine) remote.selLine = {};
                var a;
                for (a in pc.comments) { if (pc.comments.hasOwnProperty(a)) remote.comments[a] = pc.comments[a]; }
                for (a in pc.selLine) { if (pc.selLine.hasOwnProperty(a)) remote.selLine[a] = pc.selLine[a]; }
                var files = {}; files[SHARE_FILE] = { content: toJSON({ comments: remote.comments, selLine: remote.selLine }) };
                try {
                    var xhr = new ActiveXObject("MSXML2.XMLHTTP.6.0");
                    xhr.open("PATCH", "https://api.github.com/gists/" + SHARE_GIST_ID, true);
                    xhr.setRequestHeader("Authorization", "token " + shareToken());
                    xhr.setRequestHeader("Accept", "application/vnd.github+json");
                    xhr.setRequestHeader("Content-Type", "application/json");
                    try { xhr.setRequestHeader("User-Agent", "KPI-Perfo"); } catch (eUA) {}
                    xhr.onreadystatechange = function () { if (xhr.readyState === 4) setSyncState(xhr.status === 200 ? 'ok' : 'error'); };
                    xhr.send(toJSON({ files: files }));
                } catch (e) { setSyncState('error'); }
            });
        }

    // ==========================================================
    // CONNEXION : whitelist GitHub + blocage de version
    // ==========================================================
        function ParseGistConfig(txt) {
            var lines = NettoyerChaine(txt).split(/\r?\n/);
            var cfg = { version: "", users: [], equipe: [], resp: [] };
            var section = "", sawSection = false, i;
            for (i = 0; i < lines.length; i++) {
                var raw = NettoyerChaine(lines[i]);
                if (raw === "") continue;
                var up = raw.toUpperCase();
                if (up === "VERSION" || up === "USER" || up === "USERS" || up === "DATA_EQUIPE" || up === "DATA_RESP" || up === "DATE_RESP") {
                    sawSection = true;
                    section = (up === "USERS") ? "USER" : (up === "DATE_RESP") ? "DATA_RESP" : up;
                    continue;
                }
                if (section === "VERSION") { if (cfg.version === "") cfg.version = raw; }
                else if (section === "USER") { cfg.users.push(up); }
                else if (section === "DATA_EQUIPE") {
                    var p = raw.split(";");
                    if (p.length >= 2 && NettoyerChaine(p[1]) !== "") cfg.equipe.push({ team: NettoyerChaine(p[0]).toUpperCase(), user: NettoyerChaine(p[1]).toUpperCase(), nom: NettoyerChaine(p[2] || "") });
                }
                else if (section === "DATA_RESP") {
                    var q = raw.split(";");
                    if (NettoyerChaine(q[0]) !== "") cfg.resp.push({ code: NettoyerChaine(q[0]).toUpperCase(), nom: NettoyerChaine(q[1] || "") });
                }
            }
            if (!sawSection) {   // ancien format sans en-têtes
                for (i = 0; i < lines.length; i++) {
                    var l = NettoyerChaine(lines[i]);
                    if (l === "") continue;
                    if (cfg.version === "") cfg.version = l; else cfg.users.push(l.toUpperCase());
                }
            }
            return cfg;
        }
        function getGistCachePath() {
            try { var sh = new ActiveXObject("WScript.Shell"); return sh.ExpandEnvironmentStrings("%APPDATA%") + "\\" + DOSSIER_DONNEES + "\\GIST_CACHE.txt"; } catch (e) { return ""; }
        }
        function SaveGistCache(text) {
            try {
                var path = getGistCachePath(); if (!path) return;
                var fso = new ActiveXObject("Scripting.FileSystemObject");
                var dir = fso.GetParentFolderName(path);
                if (dir && !fso.FolderExists(dir)) fso.CreateFolder(dir);
                var f = fso.CreateTextFile(path, true, true); f.Write(text); f.Close();
            } catch (e) {}
        }
        function LoadGistCache() {
            try {
                var path = getGistCachePath(); if (!path) return "";
                var fso = new ActiveXObject("Scripting.FileSystemObject");
                if (!fso.FileExists(path)) return "";
                var f = fso.OpenTextFile(path, 1, false, -1); var c = f.ReadAll(); f.Close();
                return c;
            } catch (e) { return ""; }
        }
        function AppliquerConfigGist(text, idWindows) {
            var cfg = ParseGistConfig(text);
            if (cfg.version === "" && cfg.users.length === 0) { AfficherErreurLogin("Erreur de configuration", "Le fichier de configuration est vide ou mal format&eacute;."); return false; }
            window.gistCfg = cfg;   // pool équipes/responsables pour les menus déroulants des Paramètres
            var accesAutorise = false; window.userLogin = "";
            for (var i = 0; i < cfg.users.length; i++) {
                if (NettoyerChaine(cfg.users[i]).toLowerCase() === idWindows) { accesAutorise = true; window.userLogin = idWindows; break; }
            }
            if (!accesAutorise) { AfficherErreurLogin("Acc&egrave;s refus&eacute;", "Votre identifiant Windows (" + idWindows.toUpperCase() + ") n'est pas autoris&eacute;."); return false; }
            document.getElementById("loginCheckView").style.display = "none";
            document.getElementById("loginErrorView").style.display = "none";
            document.getElementById("loginSuccess").style.display = "block";
            if (cfg.version !== "" && compareVersions(cfg.version, VERSION_ACTUELLE) > 0) {
                document.getElementById("nvVersionNum").innerText = cfg.version;
                document.getElementById("nvUrlInput").value = URL_TELECHARGEMENT_APP;
                document.getElementById("newVersionAlert").style.display = "block";
                document.getElementById("btnEntrer").style.display = "none";
                document.getElementById("loginTitleOk").innerText = "Mise à jour requise";
            }
            return true;
        }
        function UtiliserConfigCache(idWindows) {
            var text = LoadGistCache();
            if (NettoyerChaine(text) === "") return false;
            var cfg = ParseGistConfig(text);
            if (cfg.version === "" && cfg.users.length === 0) return false;
            AppliquerConfigGist(text, idWindows);
            return true;
        }
        function DemarrerVerificationSysteme() {
            var statusMsg = document.getElementById("loginStatus");
            try {
                var idWindows = "";
                try { idWindows = NettoyerChaine(new ActiveXObject("WScript.Network").UserName).toLowerCase(); } catch (eU) {}
                statusMsg.innerText = "Vérification des droits pour : " + idWindows.toUpperCase();

                var xhr = new ActiveXObject("MSXML2.XMLHTTP.6.0");
                var url = LIEN_CONFIG_APP + "?t=" + Math.floor(new Date().getTime() / 300000);
                var timedOut = false;
                var to = setTimeout(function () { timedOut = true; try { xhr.abort(); } catch (e) {}
                    if (!UtiliserConfigCache(idWindows)) AfficherErreurLogin("D&eacute;lai d&eacute;pass&eacute;", "Impossible de joindre le serveur de configuration."); }, 8000);
                xhr.open("GET", url, true);
                xhr.onreadystatechange = function () {
                    if (xhr.readyState !== 4) return;
                    clearTimeout(to);
                    if (timedOut) return;
                    if (xhr.status !== 200) {   // 429 (rate limit) / erreur réseau -> repli sur la dernière config connue
                        if (!UtiliserConfigCache(idWindows)) AfficherErreurLogin("Erreur r&eacute;seau", "Impossible de joindre le serveur de configuration.");
                        return;
                    }
                    if (AppliquerConfigGist(xhr.responseText, idWindows)) SaveGistCache(xhr.responseText);   // config valide -> cache local (repli futur)
                };
                xhr.send();
            } catch (e) { AfficherErreurLogin("Erreur locale", e.message); }
        }

        function AfficherErreurLogin(titre, message) {
            var cv = document.getElementById("loginCheckView"); if (cv) cv.style.display = "none";
            var sv = document.getElementById("loginSuccess"); if (sv) sv.style.display = "none";
            document.getElementById("loginErrorTitle").innerHTML = titre;
            document.getElementById("loginError").innerHTML = message;
            document.getElementById("loginErrorView").style.display = "block";
        }
        function CopierLienDrive(btn) {
            var u = document.getElementById("nvUrlInput");
            if (window.clipboardData) { window.clipboardData.setData("Text", u.value);
                var o = btn.innerHTML; btn.innerHTML = "✔"; setTimeout(function(){ btn.innerHTML = o; }, 1500); }
        }

        function MaximiserFenetre() {
            try {
                window.focus();
                var sh = new ActiveXObject("WScript.Shell");
                sh.SendKeys("% ");   // ouvre le menu système de la fenêtre
                var lang = (navigator.systemLanguage || navigator.userLanguage || navigator.language || "fr").toLowerCase();
                sh.SendKeys(lang.indexOf("fr") === 0 ? "n" : "x");   // "Agrandir" (fr) / "Maximize" (en)
            } catch (e) {
                try { window.moveTo(0, 0); window.resizeTo(screen.availWidth, screen.availHeight); } catch (e2) {}
            }
        }

        function EntrerApplication() {
            var btn = document.getElementById("btnEntrer");
            if (btn) { btn.disabled = true; btn.style.opacity = "0.85"; btn.style.cursor = "default"; btn.innerHTML = "<span class='spinner'></span> Chargement&hellip;"; }
            document.getElementById("mainApp").style.display = "block";
            if (appData.rows && appData.rows.length) RecomputeAll();
            shareLoad();   // récupère commentaires + sélections partagés (asynchrone, rafraîchit si changement)
            PrefillExtractDates();
            dashSuppressLaunchResize = true;
            ShowPage("pageDashboard", true);   // affiche la page SANS rendre les graphiques
            setTimeout(RevelerDashboard, 60);
        }
        function RevelerDashboard() {
            LancerRenduDashboard(0, -1);
        }
        function LancerRenduDashboard(tries, lastH) {
            var el = document.getElementById('content');
            var h = el ? el.clientHeight : 0;
            if ((h > 200 && h === lastH) || tries >= 16) {   // 2 mesures identiques = taille finale atteinte ; garde-fou ~400 ms
                dashSuppressLaunchResize = false;
                RenderDashboard();   // rendu UNIQUE, à la taille finale (l'écran de connexion couvre encore)
                setTimeout(function () { document.getElementById("loginScreen").style.display = "none"; }, 30);
                return;
            }
            setTimeout(function () { LancerRenduDashboard(tries + 1, h); }, 25);
        }
        var dashSuppressLaunchResize = false;

    // ==========================================================
    // NAVIGATION
    // ==========================================================
        var PAGES = ["pageDashboard", "pageAnalyse", "pageParcours", "pageParametres"];
        var pageValid = { parcours: false, parametres: false };
        var extractValid = { NC: false, OF: false, IC: false, PL: false };
        function InvalidatePages() { pageValid.parcours = false; pageValid.parametres = false; }
        function InvalidateExtract() { extractValid.NC = false; extractValid.OF = false; extractValid.IC = false; extractValid.PL = false; }
        function activeExtractSub() {
            if (document.getElementById('extractSubOF') && document.getElementById('extractSubOF').style.display === 'block') return 'OF';
            if (document.getElementById('extractSubIC') && document.getElementById('extractSubIC').style.display === 'block') return 'IC';
            if (document.getElementById('extractSubPL') && document.getElementById('extractSubPL').style.display === 'block') return 'PL';
            return 'NC';
        }
        function RenderExtractSub(s) {
            if (s === 'OF') { RenderOFCombined(); }
            else if (s === 'IC') { RenderICTable(); }
            else if (s === 'PL') { RenderPlanif(); }
            else { RenderListe(); }
        }
        function RenderActiveExtractSub() { var s = activeExtractSub(); if (!extractValid[s]) RenderExtractSub(s); UpdateExtractButtons(); }
        var extractSearchTimer = null;
        function DebounceExtractSearch(fn) {
            if (extractSearchTimer) clearTimeout(extractSearchTimer);
            extractSearchTimer = setTimeout(fn, 250);
        }
        var EXTRACT_ROW_CAP = 500;   // valeur par défaut si la case "Lignes" est vide ou invalide
        function extractCap(id) {
            var el = document.getElementById(id);
            var n = el ? parseInt(NettoyerChaine(el.value), 10) : NaN;
            return (isNaN(n) || n < 1) ? EXTRACT_ROW_CAP : n;
        }
        function RefreshDateClearButtons() {
            var wraps = document.querySelectorAll('.date-wrap');
            for (var i = 0; i < wraps.length; i++) {
                var inp = wraps[i].getElementsByTagName('input')[0], b = wraps[i].getElementsByTagName('button')[0];
                if (inp && b) {
                    var has = NettoyerChaine(inp.value) !== "";
                    b.style.display = has ? '' : 'none';
                    inp.style.paddingRight = has ? '' : '12px';   // pas de × quand vide -> pas d'espace réservé -> placeholder "JJ/MM/AAAA" non tronqué
                }
            }
        }
        function PrerenderExtractSubs() {
            setTimeout(function () {
                if (!extractValid.NC) RenderListe();
                if (!extractValid.OF) RenderOFCombined();
                if (!extractValid.IC) RenderICTable();
            }, 60);
        }
        function ShowPage(id, skipRender) {
            for (var i = 0; i < PAGES.length; i++) {
                var sfx = PAGES[i].substring(4);
                var pg = document.getElementById(PAGES[i]); if (pg) pg.className = "page";
                var nv = document.getElementById("nav" + sfx); if (nv) nv.className = "nav-item";
            }
            var sfx2 = id.substring(4);
            var pageEl = document.getElementById(id); if (pageEl) pageEl.className = "page active";
            var navEl = document.getElementById("nav" + sfx2); if (navEl) navEl.className = "nav-item active";
            ScrollContentTop();   // remet le scroll à zéro AVANT le rendu (mesures de hauteur fiables)
            var ct = document.getElementById('content'); if (ct) ct.style.overflowY = (id === 'pageDashboard') ? 'hidden' : 'auto';
            if (skipRender) return;
            if (id === "pageParametres") { if (!pageValid.parametres) RenderParametres(); }
            if (id === "pageDashboard") RenderDashIfNeeded();
            if (id === "pageAnalyse") { RenderActiveExtractSub(); EgaliserHauteursExtraction(); AjusterHauteurTables(); ResetTblScroll(); PrerenderExtractSubs(); RefreshDateClearButtons(); }
            if (id === "pageParcours") {
                if (!pageValid.parcours) RenderParcours();
                var pc = document.getElementById('parcoursContainer'); if (pc) pc.scrollTop = 0;   // liste tout en haut
                var bST = document.getElementById('btnScrollTop'); if (bST) bST.style.display = 'none';
            }
        }
        function ScrollContentTop() {
            var c = document.getElementById('content');
            if (c) c.scrollTop = 0;
            var b = document.getElementById('btnScrollTop');
            if (b) b.style.display = 'none';
        }
        function tblScrollHandler() {
            var b = document.getElementById('btnScrollTop');
            if (b) b.style.display = (this.scrollTop > 200) ? 'block' : 'none';
        }
        function visibleTblScroll() {
            var boxes = document.querySelectorAll('.tbl-scroll');
            for (var i = 0; i < boxes.length; i++) { if (boxes[i].offsetHeight > 0 && boxes[i].offsetParent) return boxes[i]; }
            return null;
        }
        function ScrollHautTableau() {
            var c = document.getElementById('content'); if (c) c.scrollTop = 0;
            var t = visibleTblScroll(); if (t) t.scrollTop = 0;
            var p = document.getElementById('parcoursContainer'); if (p) p.scrollTop = 0;   // liste des NC (Analyse NC)
            var b = document.getElementById('btnScrollTop'); if (b) b.style.display = 'none';
        }
        function ResetTblScroll() {
            var boxes = document.querySelectorAll('.tbl-scroll');
            for (var i = 0; i < boxes.length; i++) boxes[i].scrollTop = 0;
            var b = document.getElementById('btnScrollTop'); if (b) b.style.display = 'none';
        }

    // ==========================================================
    // DATES (datepicker)
    // ==========================================================
        var dpInput = null, dpMonth, dpYear;
        var moisNoms = ["Janvier","Février","Mars","Avril","Mai","Juin","Juillet","Août","Septembre","Octobre","Novembre","Décembre"];
        function FormatDateString(d) {
            var dd = d.getDate(), mm = d.getMonth() + 1, yy = d.getFullYear();
            if (dd < 10) dd = '0' + dd; if (mm < 10) mm = '0' + mm;
            return dd + '/' + mm + '/' + yy;
        }
        function buildCalendar(month, year) {
            var dp = document.getElementById('custom-datepicker');
            var html = '<div class="dp-header"><button type="button" class="prev" onclick="changeDpMonth(-1, event)">&lt;</button><span>' + moisNoms[month] + ' ' + year + '</span><button type="button" class="next" onclick="changeDpMonth(1, event)">&gt;</button><div style="clear:both;"></div></div><table class="dp-table"><tr><th>Lu</th><th>Ma</th><th>Me</th><th>Je</th><th>Ve</th><th>Sa</th><th>Di</th></tr><tr>';
            var firstDay = new Date(year, month, 1).getDay(); if (firstDay === 0) firstDay = 7;
            for (var i = 1; i < firstDay; i++) html += '<td></td>';
            var nb = new Date(year, month + 1, 0).getDate(), col = firstDay - 1;
            for (var d = 1; d <= nb; d++) {
                html += '<td onclick="pickDpDate(' + d + ',' + month + ',' + year + ')"><span>' + d + '</span></td>';
                col++; if (col === 7 && d < nb) { html += '</tr><tr>'; col = 0; }
            }
            html += '</tr></table>'; dp.innerHTML = html;
        }
        function showCalendar(input, event) {
            dpInput = input; var dp = document.getElementById('custom-datepicker');
            var parts = (input.value || "").split('/'); var today = new Date();
            dpMonth = (parts.length === 3) ? parseInt(parts[1],10) - 1 : today.getMonth();
            dpYear  = (parts.length === 3) ? parseInt(parts[2],10) : today.getFullYear();
            buildCalendar(dpMonth, dpYear);
            var r = input.getBoundingClientRect();
            dp.style.left = r.left + "px"; dp.style.top = (r.bottom + 4) + "px"; dp.style.display = 'block';
            if (event && event.stopPropagation) event.stopPropagation();
        }
        function changeDpMonth(dir, event) {
            dpMonth += dir; if (dpMonth < 0) { dpMonth = 11; dpYear--; } else if (dpMonth > 11) { dpMonth = 0; dpYear++; }
            buildCalendar(dpMonth, dpYear); if (event && event.stopPropagation) event.stopPropagation();
        }
        function pickDpDate(d, m, y) {
            var dd = (d < 10 ? '0' : '') + d, mm = ((m + 1) < 10 ? '0' : '') + (m + 1);
            if (dpInput) dpInput.value = dd + '/' + mm + '/' + y;
            document.getElementById('custom-datepicker').style.display = 'none';
            if (dpInput) validateDatePair(dpInput.id);
            if (dpInput && dpInput.getAttribute('data-filter')) {
                var df = dpInput.getAttribute('data-filter');
                if (df === 'of') RenderOFAll(); else if (df === 'ic') RenderICTable(); else if (df === 'planif') RenderPlanif(); else RenderListe();
            }
            RefreshDateClearButtons();
        }
        var DATE_PAIRS = [['extractDate', 'extractDateFin'], ['filtreDateDebut', 'filtreDateFin'], ['ofDateDebut', 'ofDateFin'], ['ofFiltreDateDebut', 'ofFiltreDateFin'], ['icDateDebut', 'icDateFin'], ['icFiltreDateDebut', 'icFiltreDateFin'], ['planifFiltreDateDebut', 'planifFiltreDateFin']];
        function validateDatePair(id) {
            for (var i = 0; i < DATE_PAIRS.length; i++) {
                if (DATE_PAIRS[i][0] === id || DATE_PAIRS[i][1] === id) {
                    var lo = document.getElementById(DATE_PAIRS[i][0]), hi = document.getElementById(DATE_PAIRS[i][1]);
                    var nlo = dateToNum(lo.value), nhi = dateToNum(hi.value);
                    if (nlo != null && nhi != null && nlo > nhi) {
                        AfficherErreur("La date « à partir du » ne peut pas être postérieure à la date « jusqu'au ».");
                        document.getElementById(id).value = "";   // annule la saisie fautive
                        return false;
                    }
                }
            }
            return true;
        }
        function verifierOrdreDates(loVal, hiVal) {
            var nlo = dateToNum(loVal), nhi = dateToNum(hiVal);
            if (nlo != null && nhi != null && nlo > nhi) {
                AfficherErreur("La date « à partir du » ne peut pas être postérieure à la date « jusqu'au ».");
                return false;
            }
            return true;
        }
        function clearDate(id, event) {
            var el = document.getElementById(id); if (el) el.value = "";
            RefreshDateClearButtons();
            var f = el ? el.getAttribute('data-filter') : null;
            if (f === 'of') RenderOFAll(); else if (f === 'ic') RenderICTable(); else if (f === 'planif') RenderPlanif(); else if (f) RenderListe();
            if (event && event.stopPropagation) event.stopPropagation();
        }
        document.onclick = function (e) {
            var ev = e || window.event; var t = ev.target || ev.srcElement;
            var dp = document.getElementById('custom-datepicker');
            if (dp && dp.style.display === 'block' && !dp.contains(t) && t !== dpInput) dp.style.display = 'none';
        };

    // ==========================================================
    // IMPORT & PARSING DE L'EXPORT QM13
    //  Format : tabulé, ANSI (Windows-1252), 2 tabulations en tête, 12 colonnes :
    //  Avis | Statut | Description | Respons. | Code | Désignation | Terminé par
    //      | Date(créé le) | Heure(créé à) | Terminé le | Terminé à | Nº
    // ==========================================================
        function LancerExtractionSAP() {
            if (!hasAnyTeamMember()) return;   // sécurité : bouton grisé sans équipe
            var btn = document.getElementById('btnExtract');
            var dateVal = NettoyerChaine(document.getElementById('extractDate').value);
            var dateFin = NettoyerChaine(document.getElementById('extractDateFin').value);
            if (!dateVal || !dateFin) { AfficherErreur("Renseigne les deux dates (à partir du / jusqu'au)."); return; }
            if (!verifierOrdreDates(dateVal, dateFin)) return;
            var dateSAP = dateVal.replace(/\//g, '.');          // JJ/MM/AAAA -> JJ.MM.AAAA
            var dateSAPFin = dateFin.replace(/\//g, '.');
            if (btn) { btn.className = "btn-toolbar btn-disabled"; btn.innerHTML = "<span class='spinner'></span> Extraction"; }
            setTimeout(function () {
                try {
                    var sh = new ActiveXObject("WScript.Shell");
                    var path = sh.ExpandEnvironmentStrings("%APPDATA%") + "\\" + DOSSIER_DONNEES + "\\EXPORT_NC.txt";
                    var res = VBS_ExtractQM13(dateSAP, dateSAPFin);
                    if (res && res.indexOf("ERREUR") === -1) {
                        ChargerMSN(dateSAP, dateSAPFin, sh);   // 2e extract QM11 (LAROCHE_NC2) : mappe le MSN à chaque NC (best-effort)
                        LireEtAnalyser(path);   // parse + sauvegarde + recalcul + rendu liste + MsgBox résultat
                    } else {
                        AfficherErreur(res || "Erreur inconnue lors de l'extraction.");
                    }
                } catch (e) {
                    AlerteExtract("Erreur : " + e.message);
                }
                if (btn) { btn.innerHTML = "Extract NC"; }
                UpdateExtractButtons();   // rétablit l'état actif/grisé selon les équipes
            }, 80);
        }
        function ChargerMSNDepuisFichier() {
            try {
                var sh = new ActiveXObject("WScript.Shell");
                var path = sh.ExpandEnvironmentStrings("%APPDATA%") + "\\" + DOSSIER_DONNEES + "\\EXPORT_NC2.txt";
                var fso = new ActiveXObject("Scripting.FileSystemObject");
                if (!fso.FileExists(path)) return false;
                var ts = fso.OpenTextFile(path, 1, false, 0); var content = ts.AtEndOfStream ? "" : ts.ReadAll(); ts.Close();
                var map = ParseNCMSN(content);
                if (!appData.msnByAvis) appData.msnByAvis = {};
                var n = 0;
                for (var av in map) { if (map.hasOwnProperty(av)) { appData.msnByAvis[av] = map[av]; n++; } }
                return n > 0;
            } catch (e) { return false; }
        }
        function ChargerMSN(dateSAP, dateSAPFin, sh) {
            try {
                var res = VBS_ExtractNCMSN(dateSAP, dateSAPFin);
                if (!res || res.indexOf("ERREUR") !== -1) return;
                ChargerMSNDepuisFichier();
            } catch (e) { /* best-effort : on n'interrompt pas l'import NC */ }
        }
        function LireEtAnalyser(path) {
            try {
                var fso = new ActiveXObject("Scripting.FileSystemObject");
                if (!fso.FileExists(path)) { AlerteExtract("Fichier introuvable :\n" + path); return; }
                var ts = fso.OpenTextFile(path, 1, false, 0); // 0 = ANSI (Windows-1252)
                var content = ts.ReadAll(); ts.Close();
                var rows = ParseExport(content);
                if (rows.length === 0) { AlerteExtract("Aucune ligne exploitable détectée (format inattendu)."); return; }

                var cur = appData.rows || [], existing = {};
                for (var x = 0; x < cur.length; x++) existing[cur[x].a] = true;
                var addedAvis = {}, skippedAvis = {};
                for (var y = 0; y < rows.length; y++) {
                    var av = rows[y].a;
                    if (existing[av]) { skippedAvis[av] = true; }
                    else { cur.push(rows[y]); addedAvis[av] = true; }
                }
                appData.rows = cur;
                appData.lastImport = FormatDateString(new Date()) + " " + new Date().toLocaleTimeString();
                RecomputeAll();   // calcule l'éligibilité AVANT la sauvegarde
                SaveData();

                var nbAdded = 0; for (var ka in addedAvis) { if (addedAvis.hasOwnProperty(ka)) nbAdded++; }
                var nbSkipped = 0; for (var ks in skippedAvis) { if (skippedAvis.hasOwnProperty(ks)) nbSkipped++; }
                var nbElig = 0; for (var e = 0; e < ncList.length; e++) { if (ncList[e].eligible) nbElig++; }
                var lbl = document.getElementById('lastExtractDate'); if (lbl) lbl.innerText = appData.lastImport || "";
                RenderListe();
                EgaliserHauteursExtraction();

                if (nbElig === 0) alert("Extraction terminée, mais aucune NC analysée.\n\n" + DiagnostiquerNCTexte());
            } catch (e) {
                AlerteExtract("Erreur de lecture : " + e.message);
            }
        }

        // ======================= ORDRES DE FABRICATION (OF) =======================
        function ShowExtractSub(s) {
            var subs = { NC: 'extractSubNC', OF: 'extractSubOF', IC: 'extractSubIC', PL: 'extractSubPL' };
            var tabs = { NC: 'subtabNC', OF: 'subtabOF', IC: 'subtabIC', PL: 'subtabPL' };
            for (var kk in subs) {
                if (!subs.hasOwnProperty(kk)) continue;
                var pane = document.getElementById(subs[kk]); if (pane) pane.style.display = (kk === s) ? "block" : "none";
                var tab = document.getElementById(tabs[kk]); if (tab) tab.className = (kk === s) ? "subtab active" : "subtab";
            }
            var ctSc = document.getElementById('content'); if (ctSc) ctSc.scrollTop = 0;   // repart en haut (évite un mauvais calcul de hauteur de l'état vide)
            if (!extractValid[s]) RenderExtractSub(s);
            UpdateExtractButtons();   // maj état grisé des boutons d'export même si le tableau est en cache
            if (s === 'NC') EgaliserHauteursExtraction();
            AjusterHauteurTables();
            ResizeEmptyCards();   // re-dimensionne l'état vide maintenant que le pane est visible (corrige un pré-rendu fait à l'état masqué)
            ResetTblScroll();   // le tableau du sous-onglet s'affiche tout en haut
        }
        function msnFromOTP(s) {
            s = NettoyerChaine(s);
            var m = s.match(/MSV-000(\d{3})/i);
            if (m) return m[1];
            var m2 = s.match(/MSV[-\s_]*0*(\d+)/i);   // repli si le préfixe/nb de zéros diffère
            return m2 ? m2[1] : "";
        }
        function ParseOF(content) {
            var lines = content.split(/\r?\n/), out = [];
            for (var i = 0; i < lines.length; i++) {
                var raw = lines[i];
                if (raw.indexOf("\t") === -1) continue;
                var parts = raw.split("\t");
                while (parts.length && NettoyerChaine(parts[0]) === "") parts.shift();
                if (parts.length < 4) continue;
                var of = NettoyerChaine(parts[0]);
                if (!/^\d{6,}$/.test(of)) continue;   // 1re colonne = n° d'OF (6+ chiffres)
                if (/MSV/i.test(parts[1])) {          // colonne 2 = Élément d'OTP -> disposition ST (avec MSN)
                    out.push({ of: of, msn: msnFromOTP(parts[1]), user: NettoyerChaine(parts[2]), date: NettoyerChaine(parts[3]), heure: NettoyerChaine(parts[4] || "") });
                } else {                              // disposition IQ (user en colonne 2, pas de MSN)
                    out.push({ of: of, msn: "", user: NettoyerChaine(parts[1]), date: NettoyerChaine(parts[2]), heure: NettoyerChaine(parts[3]) });
                }
            }
            return out;
        }
        function MergeOFFile(path, type) {
            var fso = new ActiveXObject("Scripting.FileSystemObject");
            if (!fso.FileExists(path)) return -1;
            var ts = fso.OpenTextFile(path, 1, false, 0);   // ANSI
            var content = ts.AtEndOfStream ? "" : ts.ReadAll(); ts.Close();
            var data = ParseOF(content);
            var cur = (type === 'cree') ? (appData.ofCree || []) : (appData.ofClot || []);
            var seen = {}; for (var i = 0; i < cur.length; i++) seen[cur[i].of] = true;
            var added = 0;
            for (var j = 0; j < data.length; j++) { if (!seen[data[j].of]) { cur.push(data[j]); seen[data[j].of] = true; added++; } }
            if (type === 'cree') appData.ofCree = cur; else appData.ofClot = cur;
            return added;
        }
        function ParseOFMSN(content) {
            var lines = content.split(/\r?\n/), map = {};
            for (var i = 0; i < lines.length; i++) {
                var raw = lines[i]; if (raw.indexOf("\t") === -1) continue;
                var parts = raw.split("\t");
                while (parts.length && NettoyerChaine(parts[0]) === "") parts.shift();
                if (parts.length < 2) continue;
                var of = NettoyerChaine(parts[0]);
                if (!/^\d{6,}$/.test(of)) continue;   // 1re colonne = Ordre (6+ chiffres)
                var msn = msnFromOTP(parts[1]);       // 2e colonne = "MSV-000846/..." -> 846
                if (msn) map[of] = msn;
            }
            return map;
        }
        // Clé triable date+heure ("JJ.MM.AAAA" + "HH:MM:SS") -> AAAAMMJJ*1e6 + HHMMSS.
        function ofDateTimeKey(date, heure) {
            var d = dateToNum(date) || 0;
            var h = (NettoyerChaine(heure).replace(/\D/g, "") + "000000").slice(0, 6);
            return d * 1000000 + (parseInt(h, 10) || 0);
        }
        // Clôture OF : IQ1 (user/date/heure, multi-lignes -> on garde la DERNIÈRE confirmation = clôture) + IQ2 (OF + MSN).
        // Le filtrage "clôturé par un membre de l'équipe IQ" se fait à l'affichage (getOFTeamRows('clot')) sur le user de clôture.
        function MergeOFClot(pathIQ1, pathIQ2) {
            try {
                var fso = new ActiveXObject("Scripting.FileSystemObject");
                if (!fso.FileExists(pathIQ1)) return 0;
                var t1 = fso.OpenTextFile(pathIQ1, 1, false, 0); var c1 = t1.AtEndOfStream ? "" : t1.ReadAll(); t1.Close();
                var lines = c1.split(/\r?\n/), closeMap = {};
                for (var i = 0; i < lines.length; i++) {
                    var raw = lines[i]; if (raw.indexOf("\t") === -1) continue;
                    var parts = raw.split("\t"); while (parts.length && NettoyerChaine(parts[0]) === "") parts.shift();
                    if (parts.length < 4) continue;
                    var of = NettoyerChaine(parts[0]); if (!/^\d{6,}$/.test(of)) continue;
                    var user = NettoyerChaine(parts[1]), date = NettoyerChaine(parts[2]), heure = NettoyerChaine(parts[3]);
                    var k = ofDateTimeKey(date, heure);
                    if (!closeMap[of] || k >= closeMap[of].k) closeMap[of] = { user: user, date: date, heure: heure, k: k };   // dernière confirmation = clôture
                }
                var msnMap = {};
                if (fso.FileExists(pathIQ2)) { var t2 = fso.OpenTextFile(pathIQ2, 1, false, 0); var c2 = t2.AtEndOfStream ? "" : t2.ReadAll(); t2.Close(); msnMap = ParseOFMSN(c2); }
                var cur = appData.ofClot || [], byOf = {};
                for (var j = 0; j < cur.length; j++) byOf[cur[j].of] = cur[j];
                var n = 0;
                for (var o in closeMap) {
                    if (!closeMap.hasOwnProperty(o)) continue;
                    var cl = closeMap[o];
                    byOf[o] = { of: o, user: cl.user, date: cl.date, heure: cl.heure, msn: msnMap[o] || (byOf[o] && byOf[o].msn) || "" };
                    n++;
                }
                var res = []; for (var oo in byOf) { if (byOf.hasOwnProperty(oo)) res.push(byOf[oo]); }
                appData.ofClot = res;
                return n;
            } catch (e) { return 0; }
        }
        function teamHasMembers(arr) {
            arr = arr || [];
            for (var i = 0; i < arr.length; i++) { if (NettoyerChaine(arr[i].user) !== "") return true; }
            return false;
        }
        function hasAnyTeamMember() {
            return teamHasMembers(appData.teamST) || teamHasMembers(appData.teamTL) || teamHasMembers(appData.teamIQ);
        }
        function setExtractBtnDisabled(id, ok, tip) {
            var btn = document.getElementById(id); if (!btn) return;
            btn.disabled = !ok;
            btn.className = "btn-toolbar";
            btn.style.backgroundColor = ok ? "" : "#94a3b8";
            btn.style.opacity = ok ? "" : "0.8";
            btn.style.cursor = ok ? "" : "not-allowed";
            btn.title = ok ? "" : (tip || "");
        }
        function UpdateExtractButtons() {
            var any = hasAnyTeamMember(), tip = "Sélectionne au moins une équipe (ST, TL ou IQ) dans les Paramètres.";
            setExtractBtnDisabled('btnExtract', any, tip);      // Extract NC
            setExtractBtnDisabled('btnICExtract', any, tip);    // Extract IC
            setExtractBtnDisabled('btnOF', teamHasMembers(appData.teamST) || teamHasMembers(appData.teamIQ), "Renseigne au moins une équipe (ST ou IQ) dans les Paramètres.");   // Extract OF
        }
        function LancerExtractOFTout() {
            if (!teamHasMembers(appData.teamST) && !teamHasMembers(appData.teamIQ)) return;   // sécurité : bouton grisé sans équipe
            var d1 = NettoyerChaine(document.getElementById('ofDateDebut').value).replace(/\//g, '.');
            var d2 = NettoyerChaine(document.getElementById('ofDateFin').value).replace(/\//g, '.');
            if (!d1 || !d2) { AfficherErreur("Renseigne les deux dates (à partir du / jusqu'au)."); return; }
            if (!verifierOrdreDates(d1, d2)) return;
            var btn = document.getElementById('btnOF');
            if (btn) { btn.className = "btn-toolbar btn-disabled"; btn.innerHTML = "<span class='spinner'></span> Extraction"; }
            setTimeout(function () {
                try {
                    var sh = new ActiveXObject("WScript.Shell");
                    var folder = sh.ExpandEnvironmentStrings("%APPDATA%") + "\\" + DOSSIER_DONNEES + "\\";
                    var errs = [], sapDown = false;
                    var r1 = VBS_ExtractOFCree(d1, d2);
                    if (r1 && r1.indexOf("SAP inaccessible") !== -1) { sapDown = true; }   // SAP indisponible -> message unique, on n'enchaîne pas les autres extracts
                    else {
                        if (r1 && r1.indexOf("ERREUR") === -1) MergeOFFile(folder + "EXPORT_ST.txt", 'cree'); else errs.push("Création : " + (r1 || "erreur inconnue"));
                        var r2 = VBS_ExtractOFClotUser(d1, d2);   // IQ1 : user + date + heure de clôture (primaire)
                        var r3 = VBS_ExtractOFClotMSN(d1, d2);    // IQ2 : OF + MSN (affectation MSN, best-effort)
                        if (r3 && r3.indexOf("ERREUR") !== -1) errs.push("Clôture (MSN) : " + r3);
                        if (r2 && r2.indexOf("ERREUR") === -1) MergeOFClot(folder + "EXPORT_IQ1.txt", folder + "EXPORT_IQ2.txt"); else errs.push("Clôture : " + (r2 || "erreur inconnue"));
                    }
                    if (sapDown) {
                        AlerteExtract("SAP n'est pas disponible. Ouvre SAP Logon et connecte-toi.");
                    } else {
                        appData.lastOFImport = FormatDateString(new Date()) + " " + new Date().toLocaleTimeString();
                        SaveData();
                        RenderOFCombined();
                        InvalidateDash();   // données OF modifiées -> dashboard à recalculer
                        if (document.getElementById('dashSubOF') && document.getElementById('dashSubOF').style.display === 'block') RenderDashboardOF();
                        if (errs.length) AlerteExtract("Extraction OF partielle :\n" + errs.join("\n"));
                    }
                } catch (e) { AlerteExtract("Erreur : " + e.message); }
                if (btn) { btn.innerHTML = "Extract OF"; }
                UpdateExtractButtons();   // rétablit l'état actif/grisé selon les équipes
            }, 80);
        }
        function emptyExtractHtml(title, subtitle) {
            return "<div class='empty-extract card' style='margin-bottom:0; box-sizing:border-box;'>"
                + "<div style='display:table; width:100%; height:100%;'><div style='display:table-cell; vertical-align:middle; text-align:center; padding:20px;'>"
                + "<div style='width:56px; height:56px; margin:0 auto 16px auto; border-radius:50%; background:#eef2f5; display:table;'><span style='display:table-cell; vertical-align:middle; text-align:center;'>"
                + "<svg width='28' height='28' viewBox='0 0 24 24' fill='none' stroke='#94a3b8' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><rect x='3' y='4' width='18' height='16' rx='2'/><path d='M3 9h18M8 4v16'/></svg>"
                + "</span></div>"
                + "<div style='font-size:16px; font-weight:700; color:#334155; margin-bottom:6px;'>" + escapeHtml(title) + "</div>"
                + "<div style='font-size:13px; color:#64748b;'>" + escapeHtml(subtitle) + "</div>"
                + "</div></div></div>";
        }
        function showEmptyExtract(contId, title, subtitle) {
            var cont = document.getElementById(contId); if (!cont) return;
            cont.innerHTML = emptyExtractHtml(title, subtitle);
            var av = ComputeAvailHeight(contId);
            if (av != null && cont.firstChild) cont.firstChild.style.height = av + "px";
        }
        function getOFTeamRows(type) {
            var teamArr = (type === 'cree') ? (appData.teamST || []) : (appData.teamIQ || []);
            var teamSet = {};
            for (var t = 0; t < teamArr.length; t++) { var tu = NettoyerChaine(teamArr[t].user).toUpperCase(); if (tu) teamSet[tu] = true; }
            var all = (type === 'cree') ? (appData.ofCree || []) : (appData.ofClot || []);
            var data = [];
            for (var d = 0; d < all.length; d++) { if (teamSet[NettoyerChaine(all[d].user).toUpperCase()]) data.push(all[d]); }
            return data;
        }
        function ofCombinedRows() {
            var out = [], cree = getOFTeamRows('cree'), clot = getOFTeamRows('clot');
            for (var i = 0; i < cree.length; i++) out.push({ of: cree[i].of, msn: cree[i].msn || "", user: cree[i].user, date: cree[i].date, heure: cree[i].heure, type: 'cree' });
            for (var j = 0; j < clot.length; j++) out.push({ of: clot[j].of, msn: clot[j].msn || "", user: clot[j].user, date: clot[j].date, heure: clot[j].heure, type: 'clot' });
            return out;
        }
        function RenderOFCombined() {
            extractValid.OF = true;   // rendu à jour (cache)
            UpdateExtractButtons();
            var lbl = document.getElementById('lastOFExtractDate'); if (lbl) lbl.innerText = appData.lastOFImport ? appData.lastOFImport : "Jamais";
            var cont = document.getElementById('ofTable'); if (!cont) return;
            var data = ofCombinedRows();
            var totalOF = data.length;   // nb d'OF AVANT filtres (pour distinguer "aucune extraction" de "aucun résultat filtré")
            var fE1 = document.getElementById('ofFiltreDateDebut'), fE2 = document.getElementById('ofFiltreDateFin'), fER = document.getElementById('ofFiltreRecherche');
            var nd = fE1 ? dateToNum(fE1.value) : null, nf = fE2 ? dateToNum(fE2.value) : null;
            var fr = fER ? NettoyerChaine(fER.value).toUpperCase() : "";
            if (nd || nf || fr) {
                var keep = [];
                for (var k = 0; k < data.length; k++) {
                    var row = data[k];
                    if (nd || nf) { var rn = dateToNum(row.date); if (rn != null) { if (nd && rn < nd) continue; if (nf && rn > nf) continue; } }
                    var tl = (row.type === 'cree') ? 'CRÉATION' : 'CLÔTURE';
                    if (fr && (NettoyerChaine(row.of) + " " + NettoyerChaine(row.user) + " " + NettoyerChaine(row.msn) + " " + tl).toUpperCase().indexOf(fr) === -1) continue;
                    keep.push(row);
                }
                data = keep;
            }
            if (!data.length) {
                if (totalOF) showEmptyExtract('ofTable', "Aucun OF ne correspond aux filtres.", "Modifie ou réinitialise les filtres.");
                else showEmptyExtract('ofTable', "Aucune extraction réalisée", "Lance une extraction des ordres de fabrication ci-dessus.");
                return;
            }
            var sc = ofSort.col, sd = ofSort.dir;
            if (sc) {
                data.sort(function (a, b) {
                    var va, vb;
                    if (sc === 'date') { va = dateToNum(a.date) || 0; vb = dateToNum(b.date) || 0; }
                    else { va = NettoyerChaine(a[sc]).toUpperCase(); vb = NettoyerChaine(b[sc]).toUpperCase(); }
                    var c = (va < vb ? -1 : (va > vb ? 1 : 0)) * sd;
                    if (c !== 0) return c;
                    var ha = NettoyerChaine(a.heure).toUpperCase(), hb = NettoyerChaine(b.heure).toUpperCase();   // départage : heure décroissante
                    return (ha < hb ? 1 : (ha > hb ? -1 : 0));
                });
            }
            var cap = extractCap('nbLignesOF'), totalRows = data.length;
            if (totalRows > cap) data = data.slice(0, cap);
            var rows = "";
            for (var i = 0; i < data.length; i++) {
                var r = data[i];
                var badge = (r.type === 'cree')
                    ? "<span style='display:inline-block; padding:2px 10px; border-radius:10px; font-size:12px; font-weight:700; background:#E6F1FB; color:#0C447C;'>Création</span>"
                    : "<span style='display:inline-block; padding:2px 10px; border-radius:10px; font-size:12px; font-weight:700; background:#dcfce3; color:#166534;'>Clôture</span>";
                rows += "<tr><td style='text-align:center;'><button type='button' class='btn-view' onclick=\"OuvrirOFSap('" + escapeHtml(r.of) + "', this)\" title=\"Afficher l'ordre dans SAP (CO03)\"></button></td>"
                    + "<td style='text-align:center; font-weight:700;'>" + escapeHtml(r.of) + "</td>"
                    + "<td style='text-align:center;'>" + (r.msn ? escapeHtml(r.msn) : "-") + "</td>"
                    + "<td style='text-align:center;'>" + escapeHtml(r.user) + "</td>"
                    + "<td style='text-align:center;'>" + escapeHtml(fmtOFDate(r.date)) + "</td>"
                    + "<td style='text-align:center;'>" + escapeHtml(r.heure) + "</td>"
                    + "<td style='text-align:center;'>" + badge + "</td></tr>";
            }
            cont.innerHTML = "<div class='tbl-scroll' style='overflow-y:auto; padding-bottom:14px;'>"
                + "<table class='data-table'><thead><tr><th width='4%'></th>"
                + ofTh('of', 'Ordre de Fabrication', '16%') + ofTh('msn', 'MSN', '16%') + ofTh('user', 'User', '16%')
                + ofTh('date', 'Date', '16%') + ofTh('heure', 'Heure', '16%') + ofTh('type', 'Type', '')
                + "</tr></thead><tbody>" + rows + "</tbody></table></div>";
            AjusterHauteurTables();
        }
        var ofSort = { col: 'date', dir: -1 };   // tri par défaut : date décroissante (puis heure décroissante en départage)
        function ofTh(col, label, w) {
            var arrow = (ofSort.col === col) ? (ofSort.dir === 1 ? " &#9650;" : " &#9660;") : " <span style='color:#cbd5e1;'>&#8645;</span>";
            var wAttr = w ? (" width='" + w + "'") : "";   // w vide = colonne élastique (absorbe l'espace restant)
            return "<th" + wAttr + " style='cursor:pointer; -ms-user-select:none; user-select:none;' onclick=\"SortOF('" + col + "')\" title='Trier'>" + label + arrow + "</th>";
        }
        function SortOF(col) {
            if (ofSort.col === col) ofSort.dir = -ofSort.dir; else { ofSort.col = col; ofSort.dir = 1; }
            RenderOFCombined();
        }
        function RenderOFAll() { RenderOFCombined(); }
        // ======================= PLANIFICATION (CSV hebdomadaire) =======================
        function ChargerPlanifCSV() {
            var inp = document.getElementById('planifFileInput');
            if (inp) { inp.value = ""; inp.click(); }   // reset -> onchange se déclenche même si on rechoisit le même fichier
        }
        function OnPlanifFileChosen(inp) {
            var path = (inp && inp.value) ? inp.value : "";   // en HTA, .value = chemin complet du fichier choisi
            if (!path) return;
            var content = readPlanifFile(path);
            if (content == null) { AfficherErreur("Impossible de lire le fichier CSV."); return; }
            var res = ParsePlanifCSV(content), rows = res.rows;
            if (!rows.length) { AfficherErreur("Aucune donnée exploitable (en-tête MSN / OF / VAC introuvable dans le CSV ?)."); return; }
            appData.planif = rows;
            appData.planifFile = path.replace(/^.*[\\\/]/, "");   // nom de fichier seul
            appData.planifImport = FormatDateString(new Date()) + " " + new Date().toLocaleTimeString();
            SaveData();
            InvalidateDash();       // le tableau de bord Planification pourra exploiter ces données
            RenderPlanif();
            PlanifReportColonnes(res.found, rows.length);   // récap colonnes + avertissement en-têtes manquants
        }
        // Récapitulatif à l'import : liste les colonnes reconnues par en-tête et avertit si un intitulé attendu est introuvable.
        function PlanifReportColonnes(found, nb) {
            found = found || {};
            var disp = [['of', 'OF/NC'], ['msn', 'MSN'], ['sujet', 'Sujet'], ['statut', 'Statut'], ['date', 'Date'], ['vac', 'Vacation']];
            var ok = [], miss = [];
            for (var i = 0; i < disp.length; i++) { if (found[disp[i][0]]) ok.push(disp[i][1]); else miss.push(disp[i][1]); }
            if (found.team) ok.push('Team');
            var msg = nb + " ligne" + (nb > 1 ? "s" : "") + " chargée" + (nb > 1 ? "s" : "") + ".\n\nColonnes reconnues par en-tête : " + (ok.length ? ok.join(", ") : "aucune") + ".";
            if (miss.length) msg += "\n\n⚠ En-tête introuvable : " + miss.join(", ") + " - ces colonnes resteront vides. Vérifie les intitulés dans le fichier.";
            if (!found.team) msg += "\n\n⚠ En-tête « Team » introuvable : l'exclusion QLS / ST est appliquée par position (colonne juste avant PRIO). Vérifie l'intitulé.";
            AlerteExtract(msg);
        }
        // Lecture texte : ADODB.Stream en UTF-8 (export Google Sheets), repli FSO ANSI.
        function readPlanifFile(path) {
            try { var st = new ActiveXObject("ADODB.Stream"); st.Type = 2; st.Charset = "UTF-8"; st.Open(); st.LoadFromFile(path); var t = st.ReadText(); st.Close(); return t; } catch (e) {}
            try { var fso = new ActiveXObject("Scripting.FileSystemObject"); var ts = fso.OpenTextFile(path, 1, false, 0); var c = ts.AtEndOfStream ? "" : ts.ReadAll(); ts.Close(); return c; } catch (e2) {}
            return null;
        }
        // Détecte le séparateur sur la 1re ligne : ',' (Google), ';' (Excel FR) ou tabulation.
        function planifSniffSep(text) {
            var fl = text.split(/\r?\n/)[0] || "", cc = 0, sc = 0, tc = 0;
            for (var i = 0; i < fl.length; i++) { var c = fl.charAt(i); if (c === ',') cc++; else if (c === ';') sc++; else if (c === '\t') tc++; }
            if (sc >= cc && sc >= tc) return ';';
            if (tc >= cc && tc >= sc) return '\t';
            return ',';
        }
        // Parseur CSV complet : gère les champs entre guillemets ("" échappé) et les séparateurs/retours-ligne à l'intérieur.
        function parseCSVText(text, sep) {
            if (text.charCodeAt(0) === 0xFEFF) text = text.slice(1);   // BOM
            var rows = [], field = "", row = [], i = 0, n = text.length, inQ = false;
            while (i < n) {
                var c = text.charAt(i);
                if (inQ) {
                    if (c === '"') { if (text.charAt(i + 1) === '"') { field += '"'; i += 2; continue; } inQ = false; i++; continue; }
                    field += c; i++; continue;
                }
                if (c === '"') { inQ = true; i++; continue; }
                if (c === sep) { row.push(field); field = ""; i++; continue; }
                if (c === '\r') { i++; continue; }
                if (c === '\n') { row.push(field); rows.push(row); row = []; field = ""; i++; continue; }
                field += c; i++;
            }
            if (field !== "" || row.length) { row.push(field); rows.push(row); }
            return rows;
        }
        // OF/NC/MSN numériques : normalise "1.0293E9" / "843.0" -> entier ; laisse le texte tel quel.
        function planifFmtNum(v) {
            v = NettoyerChaine(v);
            if (v === "") return "";
            var s = v.replace(/\s/g, "");
            if (/^[\d.,]+([eE][+\-]?\d+)?$/.test(s)) {
                var num = parseFloat(s.replace(",", "."));
                if (isFinite(num) && num >= 1) return String(Math.round(num));
            }
            return v;
        }
        // Date : convertit un n° de série Excel/Sheets en JJ/MM/AAAA ; laisse une date déjà texte inchangée.
        function planifFmtDate(v) {
            v = NettoyerChaine(v);
            if (v === "") return "";
            if (/^\d{4,6}(\.\d+)?$/.test(v)) {
                var n = parseFloat(v);
                if (n > 20000 && n < 80000) {
                    var d = new Date(Date.UTC(1899, 11, 30) + Math.round(n) * 86400000), p = function (x) { return (x < 10 ? "0" : "") + x; };
                    return p(d.getUTCDate()) + "/" + p(d.getUTCMonth() + 1) + "/" + d.getUTCFullYear();
                }
            }
            return v;
        }
        function ParsePlanifCSV(text) {
            var grid = parseCSVText(text, planifSniffSep(text));
            if (!grid.length) return { rows: [], found: {} };
            function norm(s) { return NettoyerChaine(s).toUpperCase(); }
            var hdrIdx = -1, hdr = null;
            for (var r = 0; r < Math.min(grid.length, 12); r++) {   // repère la ligne d'en-tête (MSN + VAC/OF) dans les 1res lignes
                var line = grid[r], hasMsn = false, hasVac = false, hasOf = false;
                for (var c = 0; c < line.length; c++) { var h = norm(line[c]); if (h.indexOf('MSN') !== -1) hasMsn = true; if (h.indexOf('VAC') !== -1) hasVac = true; if (h === 'OF' || h.indexOf('OF/') !== -1) hasOf = true; }
                if (hasMsn && (hasVac || hasOf)) { hdrIdx = r; hdr = line; break; }
            }
            if (hdrIdx === -1) { hdrIdx = 0; hdr = grid[0]; }
            function findCol(pred) { for (var cc = 0; cc < hdr.length; cc++) { if (pred(norm(hdr[cc]))) return cc; } return -1; }
            var iOF = findCol(function (h) { return h === 'OF' || h.indexOf('OF/NC') !== -1; });
            if (iOF === -1) iOF = findCol(function (h) { return /(^| )OF( |$|\/)/.test(h); });
            var iMSN = findCol(function (h) { return h.indexOf('MSN') !== -1; });
            var iPRIO = findCol(function (h) { return h.indexOf('PRIO') !== -1; });
            var iSUJ = findCol(function (h) { return h.indexOf('SUJET') !== -1 || h.indexOf('SUBJECT') !== -1; });
            var iSTA = findCol(function (h) { return h.indexOf('STATUT') !== -1 || h.indexOf('STATUS') !== -1; });
            var iDAT = findCol(function (h) { return h.indexOf('DATE') !== -1; });
            var iVAC = findCol(function (h) { return h.indexOf('VAC') !== -1; });
            var iTEAM = findCol(function (h) { return h.indexOf('TEAM') !== -1 || h.indexOf('EQUIPE') !== -1 || h.indexOf('ÉQUIPE') !== -1; });
            var found = { of: iOF !== -1, msn: iMSN !== -1, sujet: iSUJ !== -1, statut: iSTA !== -1, date: iDAT !== -1, vac: iVAC !== -1, team: iTEAM !== -1 };   // colonnes trouvées par en-tête (avant replis positionnels)
            if (iTEAM === -1 && iPRIO > 0) iTEAM = iPRIO - 1;   // colonne TEAM = juste avant PRIO (en-tête souvent vide)
            if (iTEAM === -1) iTEAM = 0;
            var out = [];
            for (var r2 = hdrIdx + 1; r2 < grid.length; r2++) {
                var ln = grid[r2]; if (!ln) continue;
                var g = function (idx) { return (idx >= 0 && idx < ln.length) ? NettoyerChaine(ln[idx]) : ""; };
                var team = g(iTEAM).toUpperCase();
                if (team === 'QLS' || team === 'ST') continue;   // exclusion demandée : lignes QLS / ST
                var msnRaw = g(iMSN);
                if (msnRaw === "" && iPRIO >= 0) { var pv = planifFmtNum(g(iPRIO)); if (/^\d{3}$/.test(pv)) msnRaw = pv; }   // MSN parfois saisi dans la colonne PRIO
                var ofnc = planifFmtNum(g(iOF)), msn = planifFmtNum(msnRaw), sujet = g(iSUJ), statut = g(iSTA), date = planifFmtDate(g(iDAT)), vac = g(iVAC);
                if (ofnc === "" && msn === "" && sujet === "") continue;   // ligne vide
                out.push({ ofnc: ofnc, msn: msn, sujet: sujet, statut: statut, date: date, vac: vac });
            }
            return { rows: out, found: found };
        }
        // Semaine ISO dominante des dates du planning chargé (badge "Dernière semaine extraite").
        function planifDominantWeek() {
            var data = appData.planif || [], counts = {}, best = null, bestN = 0;
            for (var i = 0; i < data.length; i++) {
                var d = parseOFDateObj(data[i].date); if (!d) continue;
                var w = isoWeek(d), y = d.getFullYear(), key = y + "-" + w;
                counts[key] = (counts[key] || 0) + 1;
                if (counts[key] > bestN) { bestN = counts[key]; best = { week: w, year: y }; }
            }
            return best;
        }
        function PlanifMajBadge() {
            var lw = document.getElementById('lastPlanifWeek'); if (!lw) return;
            var n = (appData.planif || []).length, wk = planifDominantWeek();
            lw.innerText = n ? (wk ? ("Semaine " + wk.week + " - " + wk.year) : "?") : "-";
            var badge = document.getElementById('planifWeekBadge'); if (badge) badge.title = appData.planifFile ? ("Fichier : " + appData.planifFile) : "";
        }
        function RenderPlanif() {
            extractValid.PL = true;
            PlanifMajBadge();
            var cont = document.getElementById('planifTable'); if (!cont) return;
            var all = appData.planif || [], totalRows = all.length;
            if (!totalRows) {
                showEmptyExtract('planifTable', "Aucun fichier chargé", "Clique sur « Charger un fichier CSV » pour importer le planning de la semaine.");
                return;
            }
            var fE1 = document.getElementById('planifFiltreDateDebut'), fE2 = document.getElementById('planifFiltreDateFin'), fER = document.getElementById('planifFiltreRecherche');
            var nd = fE1 ? dateToNum(fE1.value) : null, nf = fE2 ? dateToNum(fE2.value) : null;
            var fr = fER ? NettoyerChaine(fER.value).toUpperCase() : "";
            var data = [];
            for (var k = 0; k < all.length; k++) {
                var rw = all[k];
                if (nd || nf) { var rnum = dateToNum(rw.date); if (rnum != null) { if (nd && rnum < nd) continue; if (nf && rnum > nf) continue; } }
                if (fr && (NettoyerChaine(rw.ofnc) + " " + NettoyerChaine(rw.msn) + " " + NettoyerChaine(rw.sujet) + " " + NettoyerChaine(rw.statut) + " " + NettoyerChaine(rw.vac)).toUpperCase().indexOf(fr) === -1) continue;
                data.push(rw);
            }
            if (!data.length) {
                showEmptyExtract('planifTable', "Aucune ligne ne correspond aux filtres", "Modifie ou réinitialise les filtres.");
                return;
            }
            var cap = extractCap('nbLignesPlanif');
            if (data.length > cap) data = data.slice(0, cap);
            var rows = "";
            for (var i = 0; i < data.length; i++) {
                var r = data[i];
                rows += "<tr><td style='text-align:center; font-weight:700;'>" + (r.ofnc ? escapeHtml(r.ofnc) : "-") + "</td>"
                    + "<td style='text-align:center;'>" + (r.msn ? escapeHtml(r.msn) : "-") + "</td>"
                    + "<td>" + (r.sujet ? escapeHtml(r.sujet) : "-") + "</td>"
                    + "<td style='text-align:center;'>" + (r.statut ? escapeHtml(r.statut) : "-") + "</td>"
                    + "<td style='text-align:center;'>" + (r.date ? escapeHtml(r.date) : "-") + "</td>"
                    + "<td style='text-align:center;'>" + (r.vac ? escapeHtml(r.vac) : "-") + "</td></tr>";
            }
            cont.innerHTML = "<div class='tbl-scroll' style='overflow-y:auto; padding-bottom:14px;'>"
                + "<table class='data-table'><thead><tr>"
                + "<th width='14%'>OF/NC</th><th width='9%'>MSN</th><th>Sujet</th><th width='14%'>Statut</th><th width='12%'>Date</th><th width='10%'>Vacation</th>"
                + "</tr></thead><tbody>" + rows + "</tbody></table></div>";
            AjusterHauteurTables();
        }
        function ResetPlanifFiltres() {
            var ids = ['planifFiltreDateDebut', 'planifFiltreDateFin', 'planifFiltreRecherche'];
            for (var i = 0; i < ids.length; i++) { var el = document.getElementById(ids[i]); if (el) el.value = ""; }
            RefreshDateClearButtons();
            RenderPlanif();
        }
        // ---- Réinitialisation par onglet : efface uniquement l'extraction de l'onglet courant ----
        function ResetExtractNC() {
            if (!confirm("Réinitialiser l'extraction Non-conformité ?\nLes NC extraites seront effacées.\nLes commentaires et lignes sélectionnées (base partagée) sont conservés.")) return;
            appData.rows = []; appData.msnByAvis = {}; appData.lastImport = "";   // on garde comments / selLine / excluded (annotations, dont base partagée)
            SaveData();
            RecomputeAll();   // reconstruit ncList (vide) + invalide dashboard / Analyse NC / paramètres
            RenderListe();
            UpdateExtractButtons();
        }
        function ResetExtractOF() {
            if (!confirm("Réinitialiser l'extraction Ordre de Fabrication ?\nLes OF extraits seront effacés (cet onglet uniquement).")) return;
            appData.ofCree = []; appData.ofClot = []; appData.lastOFImport = "";
            SaveData(); InvalidateDash();
            RenderOFCombined(); UpdateExtractButtons();
        }
        function ResetExtractIC() {
            if (!confirm("Réinitialiser l'extraction Intervention Card ?\nLes IC extraites seront effacées (cet onglet uniquement).")) return;
            appData.icRows = []; appData.lastICImport = "";
            SaveData(); InvalidateDash();
            RenderICTable(); UpdateExtractButtons();
        }
        function ResetExtractPlanif() {
            if (!confirm("Réinitialiser la Planification ?\nLe planning chargé sera effacé.")) return;
            appData.planif = []; appData.planifFile = ""; appData.planifImport = "";
            SaveData(); InvalidateDash();
            RenderPlanif();
        }
        function ResetOFFiltres() {
            var ids = ['ofFiltreDateDebut', 'ofFiltreDateFin', 'ofFiltreRecherche'];
            for (var i = 0; i < ids.length; i++) { var el = document.getElementById(ids[i]); if (el) el.value = ""; }
            RefreshDateClearButtons();
            RenderOFAll();
        }

        // ======================= INTERVENTIONS CARDS (IC) =======================
        function isICLate(r) {
            var fin = parseDT(r.dfa, r.hfa), clo = parseDT(r.dc, r.hc);
            return (fin && clo) ? (clo > fin) : false;
        }
        function icEcartMs(r) {
            var fin = parseDT(r.dfa, r.hfa), clo = parseDT(r.dc, r.hc);
            return (fin && clo) ? (clo.getTime() - fin.getTime()) : null;
        }
        function ParseIC(content) {
            var lines = content.split(/\r?\n/), out = [];
            for (var i = 0; i < lines.length; i++) {
                var raw = lines[i];
                if (raw.indexOf("\t") === -1) continue;
                var parts = raw.split("\t");
                while (parts.length && NettoyerChaine(parts[0]) === "") parts.shift();
                var p0 = NettoyerChaine(parts[0]), p1 = NettoyerChaine(parts[1] || "");
                if (/^\d{6,}$/.test(p0)) {   // colonne 1 = Avis
                    var newFmt = (parts.length >= 8) && (p1 === "" || /^\d+$/.test(p1));
                    if (newFmt) {
                        out.push({ ic: p0, msn: p1, user: NettoyerChaine(parts[2]), dfa: NettoyerChaine(parts[3]), hfa: NettoyerChaine(parts[4]), dc: NettoyerChaine(parts[5]), hc: NettoyerChaine(parts[6]), statut: NettoyerChaine(parts[7] || "") });
                    } else {
                        if (parts.length < 6) continue;   // ancien format 7 col : Avis | Auteur | dfa | hfa | dc | hc | statut
                        out.push({ ic: p0, msn: "", user: p1, dfa: NettoyerChaine(parts[2]), hfa: NettoyerChaine(parts[3]), dc: NettoyerChaine(parts[4]), hc: NettoyerChaine(parts[5]), statut: NettoyerChaine(parts[6] || "") });
                    }
                } else if (parts.length > 1 && /^\d{6,}$/.test(p1)) {   // ancien format 8 col : MSN | Avis | Date | Auteur | dfa | hfa | dc | hc
                    if (parts.length < 8) continue;
                    out.push({ ic: p1, msn: p0, user: NettoyerChaine(parts[3]), dfa: NettoyerChaine(parts[4]), hfa: NettoyerChaine(parts[5]), dc: NettoyerChaine(parts[6]), hc: NettoyerChaine(parts[7]), statut: "" });
                }
            }
            return out;
        }
        function LireIC(path) {
            try {
                var fso = new ActiveXObject("Scripting.FileSystemObject");
                if (!fso.FileExists(path)) { AlerteExtract("Fichier introuvable :\n" + path); return; }
                var ts = fso.OpenTextFile(path, 1, false, 0); var content = ts.AtEndOfStream ? "" : ts.ReadAll(); ts.Close();
                var data = ParseIC(content);
                var cur = appData.icRows || [], seen = {};
                for (var i = 0; i < cur.length; i++) seen[cur[i].ic] = true;
                for (var j = 0; j < data.length; j++) { if (!seen[data[j].ic]) { cur.push(data[j]); seen[data[j].ic] = true; } }
                appData.icRows = cur;
                appData.lastICImport = FormatDateString(new Date()) + " " + new Date().toLocaleTimeString();
                SaveData();
                RenderICTable();
                InvalidateDash();
                if (document.getElementById('dashSubIC') && document.getElementById('dashSubIC').style.display === 'block') RenderDashboardIC();
                if (!data.length) alert("Extraction terminée, mais aucune IC exploitable détectée (format inattendu ?).");
            } catch (e) { AlerteExtract("Erreur de lecture IC : " + e.message); }
        }
        function LancerExtractIC() {
            if (!hasAnyTeamMember()) return;   // sécurité : bouton grisé sans équipe
            var d1 = NettoyerChaine(document.getElementById('icDateDebut').value).replace(/\//g, '.');
            var d2 = NettoyerChaine(document.getElementById('icDateFin').value).replace(/\//g, '.');
            if (!d1 || !d2) { AfficherErreur("Renseigne les deux dates (à partir du / jusqu'au)."); return; }
            if (!verifierOrdreDates(d1, d2)) return;
            var btn = document.getElementById('btnICExtract');
            if (btn) { btn.className = "btn-toolbar btn-disabled"; btn.innerHTML = "<span class='spinner'></span> Extraction"; }
            setTimeout(function () {
                try {
                    var sh = new ActiveXObject("WScript.Shell");
                    var pathIC = sh.ExpandEnvironmentStrings("%APPDATA%") + "\\" + DOSSIER_DONNEES + "\\EXPORT_IC.txt";
                    var res = VBS_ExtractIC(d1, d2);
                    if (res && res.indexOf("ERREUR") === -1) LireIC(pathIC); else AfficherErreur(res || "Erreur inconnue lors de l'extraction IC.");
                } catch (e) { AlerteExtract("Erreur : " + e.message); }
                if (btn) { btn.innerHTML = "Extract IC"; }
                UpdateExtractButtons();   // rétablit l'état actif/grisé selon les équipes
            }, 80);
        }
        var icSort = { col: 'dfa', dir: -1 };   // tri par défaut : date fin autorisée décroissante (puis heure fin autorisée décroissante)
        function icTh(col, label, w) {
            var arrow = (icSort.col === col) ? (icSort.dir === 1 ? " &#9650;" : " &#9660;") : " <span style='color:#cbd5e1;'>&#8645;</span>";
            var wAttr = w ? (" width='" + w + "'") : "";   // w vide = colonne élastique (absorbe l'espace restant)
            return "<th" + wAttr + " style='cursor:pointer; -ms-user-select:none; user-select:none;' onclick=\"SortIC('" + col + "')\" title='Trier'>" + label + arrow + "</th>";
        }
        function SortIC(col) { if (icSort.col === col) icSort.dir = -icSort.dir; else { icSort.col = col; icSort.dir = 1; } RenderICTable(); }
        function ResetICFiltres() {
            var ids = ['icFiltreDateDebut', 'icFiltreDateFin', 'icFiltreRecherche'];
            for (var i = 0; i < ids.length; i++) { var el = document.getElementById(ids[i]); if (el) el.value = ""; }
            RefreshDateClearButtons();
            RenderICTable();
        }
        function RenderICTable() {
            extractValid.IC = true;   // rendu à jour (cache)
            var lbl = document.getElementById('lastICExtractDate'); if (lbl) lbl.innerText = appData.lastICImport ? appData.lastICImport : "Jamais";
            var cont = document.getElementById('icTable'); if (!cont) return;
            var data = (appData.icRows || []).slice(0);
            var totalIC = data.length;   // nb d'IC AVANT filtres
            var fE1 = document.getElementById('icFiltreDateDebut'), fE2 = document.getElementById('icFiltreDateFin'), fER = document.getElementById('icFiltreRecherche');
            var nd = fE1 ? dateToNum(fE1.value) : null, nf = fE2 ? dateToNum(fE2.value) : null;
            var fr = fER ? NettoyerChaine(fER.value).toUpperCase() : "";
            if (nd || nf || fr) {
                var keep = [];
                for (var k = 0; k < data.length; k++) {
                    var row = data[k];
                    if (nd || nf) { var rn = dateToNum(row.dc); if (rn != null) { if (nd && rn < nd) continue; if (nf && rn > nf) continue; } }
                    if (fr && (NettoyerChaine(row.ic) + " " + NettoyerChaine(row.user) + " " + NettoyerChaine(row.msn || "")).toUpperCase().indexOf(fr) === -1) continue;
                    keep.push(row);
                }
                data = keep;
            }
            if (!data.length) {
                if (totalIC) showEmptyExtract('icTable', "Aucune IC ne correspond aux filtres.", "Modifie ou réinitialise les filtres.");
                else showEmptyExtract('icTable', "Aucune extraction réalisée", "Lance une extraction des Interventions Cards ci-dessus.");
                return;
            }
            var sc = icSort.col, sd = icSort.dir;
            if (sc) {
                data.sort(function (a, b) {
                    var va = (sc === 'dfa' || sc === 'dc') ? (dateToNum(a[sc]) || 0) : NettoyerChaine(a[sc]).toUpperCase();
                    var vb = (sc === 'dfa' || sc === 'dc') ? (dateToNum(b[sc]) || 0) : NettoyerChaine(b[sc]).toUpperCase();
                    var c = (va < vb ? -1 : (va > vb ? 1 : 0)) * sd;
                    if (c !== 0) return c;
                    var ha = NettoyerChaine(a.hfa).toUpperCase(), hb = NettoyerChaine(b.hfa).toUpperCase();   // départage : heure fin autorisée décroissante
                    return (ha < hb ? 1 : (ha > hb ? -1 : 0));
                });
            }
            var cap = extractCap('nbLignesIC'), totalRows = data.length;
            if (totalRows > cap) data = data.slice(0, cap);
            var rows = "";
            for (var i = 0; i < data.length; i++) {
                var r = data[i], late = isICLate(r), lateSt = late ? " color:#b91c1c; font-weight:700;" : "";
                rows += "<tr" + (late ? " style='background:#fef2f2;'" : "") + ">"
                    + "<td style='text-align:center;'><button type='button' class='btn-view' onclick=\"OuvrirNCSap('" + escapeHtml(r.ic) + "', this)\" title=\"Afficher l'IC dans SAP (QM03)\"></button></td>"
                    + "<td style='text-align:center; font-weight:700;'>" + escapeHtml(r.ic) + "</td>"
                    + "<td style='text-align:center;'>" + (r.msn ? escapeHtml(r.msn) : "-") + "</td>"
                    + "<td style='text-align:center;'>" + escapeHtml(fmtOFDate(r.dfa)) + "</td>"
                    + "<td style='text-align:center;'>" + escapeHtml(r.hfa) + "</td>"
                    + "<td style='text-align:center;" + lateSt + "'>" + escapeHtml(fmtOFDate(r.dc)) + "</td>"
                    + "<td style='text-align:center;" + lateSt + "'>" + escapeHtml(r.hc) + "</td>"
                    + "<td style='text-align:center;'>" + escapeHtml(r.user) + "</td></tr>";
            }
            cont.innerHTML = "<div class='tbl-scroll' style='overflow-y:auto; padding-bottom:14px;'>"
                + "<table class='data-table'><thead><tr><th width='4%'></th>"
                + icTh('ic', 'Numéro IC', '13%') + icTh('msn', 'MSN', '13%')
                + icTh('dfa', 'Date fin autorisée', '14%') + icTh('hfa', 'Heure fin autorisée', '14%')
                + icTh('dc', 'Date clôture', '14%') + icTh('hc', 'Heure clôture', '14%')
                + icTh('user', 'User', '')
                + "</tr></thead><tbody>" + rows + "</tbody></table></div>";
            AjusterHauteurTables();
        }
        function fmtOFDate(s) {
            s = NettoyerChaine(s); if (!s) return "";
            var p = s.split(/[.\/\-]/); if (p.length < 3) return s;
            var d = p[0], m = p[1], y = p[2];
            if (d.length === 1) d = '0' + d; if (m.length === 1) m = '0' + m;
            if (y.length === 2) y = '20' + y;
            return d + '/' + m + '/' + y;
        }
        function dateToNum(s) {
            s = NettoyerChaine(s); if (!s) return null;
            var p = s.split(/[.\/\-]/); if (p.length < 3) return null;
            var d = parseInt(p[0], 10), m = parseInt(p[1], 10), y = parseInt(p[2], 10);
            if (isNaN(d) || isNaN(m) || isNaN(y)) return null;
            if (y < 100) y += 2000;
            return y * 10000 + m * 100 + d;
        }

        function ParseExport(content) {
            var lines = content.split(/\r?\n/);
            var out = [];
            for (var i = 0; i < lines.length; i++) {
                var raw = lines[i];
                if (raw.indexOf("\t") === -1) continue;          // lignes d'en-tête / titres : pas de tab
                var parts = raw.split("\t");
                while (parts.length && NettoyerChaine(parts[0]) === "") parts.shift();
                if (parts.length < 12) continue;
                var avis = NettoyerChaine(parts[0]);
                if (!/^\d{8,}$/.test(avis)) continue;             // 1ère colonne = n° d'avis (8+ chiffres)
                var nF = parts.length;
                out.push({
                    a:  avis,
                    s:  NettoyerChaine(parts[1]),        // Statut de l'avis
                    d:  NettoyerChaine(parts[2]),        // Description
                    r:  NettoyerChaine(parts[3]),        // Respons.
                    c:  NettoyerChaine(parts[4]),        // Code
                    dg: NettoyerChaine(parts[5]),        // Désignation de l'exécutant
                    tp: NettoyerChaine(parts[nF - 6]),   // Terminé par
                    cd: NettoyerChaine(parts[nF - 5]),   // Date  = créé le
                    ct: NettoyerChaine(parts[nF - 4]),   // Heure = créé à
                    td: NettoyerChaine(parts[nF - 3]),   // Terminé le
                    tt: NettoyerChaine(parts[nF - 2]),   // Terminé à
                    n:  NettoyerChaine(parts[nF - 1])    // Nº
                });
            }
            return out;
        }
        function ParseNCMSN(content) {
            var lines = content.split(/\r?\n/), map = {};
            for (var i = 0; i < lines.length; i++) {
                var raw = lines[i];
                if (raw.indexOf("\t") === -1) continue;
                var parts = raw.split("\t");
                while (parts.length && NettoyerChaine(parts[0]) === "") parts.shift();
                if (parts.length < 2) continue;
                var msn = NettoyerChaine(parts[0]), avis = NettoyerChaine(parts[1]);
                if (!/^\d{8,}$/.test(avis)) continue;   // 2e colonne = n° d'avis (8+ chiffres) ; ligne d'en-tête ignorée
                if (msn) map[avis] = msn;
            }
            return map;
        }

    // ==========================================================
    // AGRÉGATION PAR NC + CALCUL DES DURÉES
    // ==========================================================
        function parseDT(d, t) {
            if (!d) return null;
            var dp = (""+d).split('.'); if (dp.length < 3) return null;
            var tp = (""+(t || "0:0:0")).split(':');
            var dt = new Date(parseInt(dp[2],10), parseInt(dp[1],10)-1, parseInt(dp[0],10),
                              parseInt(tp[0]||0,10), parseInt(tp[1]||0,10), parseInt(tp[2]||0,10));
            if (isNaN(dt.getTime())) return null;
            if (dt.getSeconds() > 0) { dt.setSeconds(0); dt.setMinutes(dt.getMinutes() + 1); }
            return dt;
        }
        function fmtHM(d) {
            if (!d) return "";
            var h = d.getHours(), m = d.getMinutes();
            return (h < 10 ? '0' + h : h) + ':' + (m < 10 ? '0' + m : m);
        }


        function durBetween(a, b) {
            if (!a || !b || b <= a) return 0;
            var c = appData.calc || {};
            if ((c.mode || 'cal') !== 'ouvre') return b - a;   // 7j/7j (calendaire)
            var aMs = a.getTime(), bMs = b.getTime(), total = 0;
            var cur = new Date(a.getFullYear(), a.getMonth(), a.getDate());
            while (cur.getTime() <= bMs) {
                var dow = cur.getDay();   // 0=dim, 6=sam
                if (dow >= 1 && dow <= 5) {
                    var dayStart = cur.getTime(), dayEnd = dayStart + 86400000;
                    var s = Math.max(aMs, dayStart), e = Math.min(bMs, dayEnd);
                    if (e > s) total += (e - s);
                }
                cur.setDate(cur.getDate() + 1);
            }
            return total;
        }

        function ncGaps(nc) { if (!nc._gaps) nc._gaps = stepGaps(nc.lines); return nc._gaps; }
        function stepGaps(lines) {
            var arr = lines.slice(0).sort(function (a, b) { return (parseInt(NettoyerChaine(a.n), 10) || 0) - (parseInt(NettoyerChaine(b.n), 10) || 0); });
            var creation = null;
            for (var c = 0; c < arr.length; c++) { var cd = parseDT(arr[c].cd, arr[c].ct); if (cd && (!creation || cd < creation)) creation = cd; }
            var out = [], prev = creation;   // réception de la 1re tâche = création NC
            for (var j = 0; j < arr.length; j++) {
                var e = parseDT(arr[j].td, arr[j].tt);
                var gap = (e && prev && e > prev) ? durBetween(prev, e) : null;
                out.push({ code: (arr[j].c || ""), r: (arr[j].r || ""), tp: (arr[j].tp || ""), dg: (arr[j].dg || ""), end: e, gap: gap });
                if (e) prev = e;
            }
            return out;
        }

        function buildRoleByID() {
            var m = {};
            var teams = [["ST", appData.teamST], ["TL", appData.teamTL], ["IQ", appData.teamIQ]];
            for (var t = 0; t < teams.length; t++) {
                var role = teams[t][0], arr = teams[t][1] || [];
                for (var i = 0; i < arr.length; i++) {
                    var u = NettoyerChaine(arr[i].user);
                    if (u && !m[u]) m[u] = role;
                }
            }
            return m;
        }

        function RecomputeAll() {
            if (typeof InvalidateDash === 'function') InvalidateDash();   // les données NC ont changé -> dashboard à recalculer
            extractValid.NC = false; pageValid.parcours = false; pageValid.parametres = false;   // idem : caches à invalider
            var rows = appData.rows || [];
            var roleByID = buildRoleByID();
            var clotCode = cfgVal('clot', CLOTURE_CODE).toUpperCase();
            var decSet = {};   // Responsables CT (décision technique), ex 70009001 / 70005847
            var da = cfgVal('decResp', DECISION_RESP).split(";");
            for (var y = 0; y < da.length; y++) { var dc = NettoyerChaine(da[y]).toUpperCase(); if (dc) decSet[dc] = true; }
            var t1int = {};    // Responsables INTERNES = tableau 1 de type int
            var rdT = appData.roleDesig || [];
            for (var w0 = 0; w0 < rdT.length; w0++) { if (NettoyerChaine(rdT[w0].type) === "int") { var rcc = NettoyerChaine(rdT[w0].resp).toUpperCase(); if (rcc) t1int[rcc] = true; } }
            var userSet = {};  // Users présents dans les équipes ST/TL/IQ
            var teams = [appData.teamST, appData.teamTL, appData.teamIQ];
            for (var tt = 0; tt < teams.length; tt++) { var ta = teams[tt] || []; for (var ui = 0; ui < ta.length; ui++) { var uu = NettoyerChaine(ta[ui].user).toUpperCase(); if (uu) userSet[uu] = true; } }
            var iqSet = {};    // Users du tableau IQ uniquement (pour la clôture qualité)
            var iqA = appData.teamIQ || [];
            for (var qi = 0; qi < iqA.length; qi++) { var qu = NettoyerChaine(iqA[qi].user).toUpperCase(); if (qu) iqSet[qu] = true; }
            var clotResp = NettoyerChaine(CLOTURE_RESP).toUpperCase();   // responsable qualité de la clôture (70005848)
            var map = {};
            for (var i = 0; i < rows.length; i++) {
                var r = rows[i], k = r.a;
                if (!map[k]) map[k] = { avis: k, statut: r.s, desc: r.d, lines: [] };
                map[k].lines.push(r);
            }
            ncList = [];
            for (var key in map) {
                if (!map.hasOwnProperty(key)) continue;
                var nc = map[key];
                var start = null, maxEnd = null, roles = {};
                for (var j = 0; j < nc.lines.length; j++) {
                    var L = nc.lines[j];
                    var cdt = parseDT(L.cd, L.ct), edt = parseDT(L.td, L.tt);
                    if (cdt && (!start || cdt < start)) start = cdt;       // création NC
                    if (edt && (!maxEnd || edt > maxEnd)) maxEnd = edt;    // dernière fin
                    var role = roleByID[L.r] || roleByID[L.tp];
                    if (role) roles[role] = true;
                }
                var gaps = ncGaps(nc);
                var chezMs = 0, hasCT = false, hasClot = false, hasOri0Q = false, clot = null;
                for (var gi = 0; gi < gaps.length; gi++) {
                    var g = gaps[gi], rU = (g.r || "").toUpperCase(), tpU = (g.tp || "").toUpperCase(), cU = (g.code || "").toUpperCase();
                    var inTeam = !!userSet[tpU];
                    if (cU === "ORI0" && rU === clotResp) hasOri0Q = true;
                    if (decSet[rU] && inTeam) hasCT = true;
                    if (cU === clotCode && rU === clotResp && iqSet[tpU]) { hasClot = true; if (g.end && (!clot || g.end > clot)) clot = g.end; }
                    if (g.gap != null && t1int[rU] && inTeam) chezMs += g.gap;
                }
                nc.start = start; nc.end = clot;
                nc.msn = (appData.msnByAvis && appData.msnByAvis[key]) ? appData.msnByAvis[key] : "";   // MSN issu du 2e extract (QM11)
                nc.hasST = !!roles.ST; nc.hasIQ = !!roles.IQ; nc.hasTL = !!roles.TL;
                nc.hasCT = hasCT; nc.hasClot = hasClot;
                nc.durMs = (start && maxEnd) ? durBetween(start, maxEnd) : null;
                nc.chezMs = chezMs;
                nc.pasMs = (nc.durMs != null) ? Math.max(0, nc.durMs - chezMs) : null;
                if (nc.end) {
                    var sl = nc.lines.slice(0).sort(function (a, b) { return (parseInt(NettoyerChaine(a.n), 10) || 0) - (parseInt(NettoyerChaine(b.n), 10) || 0); });
                    var sIdx = effectiveSelIdx(nc.avis, sl);
                    if (sIdx >= 0) { var tt0 = parcoursTotals(nc, sl, sIdx); nc.durMs = tt0.g; nc.chezMs = tt0.e; nc.pasMs = Math.max(0, tt0.g - tt0.e); }
                }
                nc.eligRaw = hasCT && hasClot && !hasOri0Q;
                nc.excluded = !!(appData.excluded && appData.excluded[nc.avis]);   // exclusion manuelle
                nc.eligible = nc.eligRaw && !nc.excluded;
                ncList.push(nc);
            }
            ncList.sort(function (a, b) { return parseInt(a.avis,10) - parseInt(b.avis,10); });
        }

        function DiagnostiquerNCTexte() {
            var clotCode = cfgVal('clot', CLOTURE_CODE).toUpperCase();
            var total = ncList.length, nCT = 0, nClot = 0;
            for (var j = 0; j < ncList.length; j++) {
                if (ncList[j].hasCT) nCT++;
                if (ncList[j].hasClot) nClot++;
            }
            var t = "Pourquoi 0 NC analysée ?\n";
            t += "Une NC est analysée si elle a une tâche d'un responsable CT interne (user en équipe) ET une clôture " + clotCode + " du responsable " + CLOTURE_RESP + " terminée par un user du tableau IQ.\n";
            t += "Sur " + total + " NC : " + nCT + " avec une tâche CT interne, " + nClot + " avec une clôture " + clotCode + " valide (resp " + CLOTURE_RESP + " + user IQ).\n";
            if (nCT === 0) t += "- Aucune tâche CT interne reconnue : vérifie le responsable CT (tableau 1, type interne) et les équipes.\n";
            if (nClot === 0) t += "- Aucune clôture " + clotCode + " valide : vérifie que le responsable " + CLOTURE_RESP + " fait l'APQ0 et que son 'Terminé par' est bien dans le tableau IQ.\n";
            return t;
        }

    // ==========================================================
    // OUTILS D'AFFICHAGE
    // ==========================================================
        function dayMs() { return 86400000; }
        function fmtDHM(ms) {
            if (ms == null || isNaN(ms)) return "-";
            var totalMin = Math.round(ms / 60000);
            if (totalMin < 0) return "-";
            var dayMin = Math.round(dayMs() / 60000);
            var d = Math.floor(totalMin / dayMin); totalMin -= d * dayMin;
            var h = Math.floor(totalMin / 60); var m = totalMin - h * 60;
            var parts = [];
            if (d > 0) parts.push(d + " j");
            if (h > 0) parts.push(h + " h");
            if (m > 0 || parts.length === 0) parts.push(m + " min");
            return parts.join(" ");
        }
        function fmtEcartSigned(ms) {
            if (ms == null || isNaN(ms)) return "-";
            if (Math.round(Math.abs(ms) / 60000) === 0) return "à l'heure";
            return (ms < 0 ? "− " : "+ ") + fmtDHM(Math.abs(ms));
        }
        function icAxisLabel(hours) {
            var v = Math.round(hours);
            if (v === 0) return "0";
            return (v < 0 ? "−" : "") + Math.abs(v) + " h";
        }

    // ==========================================================
    // PAGE : PARAMÈTRES (4 tableaux)
    //  1) Rôles & Désignation : code Respons. -> ST / TL / IQ
    //  2/3/4) Équipes ST / TL / IQ : User + Nom (éditables)
    // ==========================================================
        var isEditingParams = false;
        var paramsBackup = null;
        var PARAM_EDIT_ROWS = 15;   // nb de lignes (vides) affichées en mode édition (recalculé à l'entrée)
        function computeParamRows() {
            var rc = document.getElementById('rolesContainer');
            var clientH = document.documentElement.clientHeight || window.innerHeight || 800;
            if (rc) {
                var top = rc.getBoundingClientRect().top;     // haut du tableau (thead inclus)
                var avail = clientH - top - 80;               // - thead - paddings carte/contenu (sécurité)
                var n = Math.floor(avail / 38);
                var dataN = (appData.roleDesig || []).length;
                var teams = [appData.teamST, appData.teamTL, appData.teamIQ];
                for (var i = 0; i < teams.length; i++) dataN = Math.max(dataN, (teams[i] || []).length);
                return Math.max(dataN + 1, n);
            }
            return 12;
        }
        function cloneObj(o) { return JSON.parse(toJSON(o)); }
        function padRoleDesig() { while (appData.roleDesig.length < PARAM_EDIT_ROWS) appData.roleDesig.push({ resp: "", nom: "", type: "" }); }
        function padTeam(role) { var a = teamArr(role); while (a.length < PARAM_EDIT_ROWS) a.push({ user: "", nom: "" }); }

        function RenderParametres() {
            pageValid.parametres = true;   // rendu à jour (cache)
            UpdateParamsButtons();
            RenderCalcMode();
            RenderRolesTable();
            RenderTeam("ST"); RenderTeam("TL"); RenderTeam("IQ");
        }
        function RenderCalcMode() {
            var cont = document.getElementById('calcModePanel');
            if (!cont) return;
            var c = appData.calc || {}, ouvre = (c.mode || 'cal') === 'ouvre', ed = isEditingParams;
            var lbl = "font-size:13px; font-weight:600; color:#475569; margin-right:10px; vertical-align:middle;";
            function box(val, text, sel) {
                var base = "display:inline-block; vertical-align:middle; border:1px solid #c5d5de; border-radius:8px; padding:8px 16px; margin-right:10px; font-size:13px; font-weight:600; color:#1e293b;" + (ed ? " cursor:pointer;" : "");
                var dis = ed ? "" : " disabled";
                var click = ed ? " onclick=\"UpdateCalc('mode','" + val + "')\"" : "";
                return "<label style='" + base + "'><input type='radio' name='calcmode' value='" + val + "'" + (sel ? " checked" : "") + dis + click + " style='vertical-align:middle; margin-right:8px;'>" + text + "</label>";
            }
            cont.innerHTML =
                "<span style='" + lbl + "'>Mode</span>"
                + box('cal', '7j/7j', !ouvre)
                + box('ouvre', 'Jours ouvrés', ouvre);
        }
        function UpdateCalc(key, val) {
            if (!isEditingParams) return;
            if (!appData.calc) appData.calc = {};
            appData.calc[key] = NettoyerChaine(val);
            RenderCalcMode();
        }
        function UpdateParamsButtons() {
            var e = document.getElementById('btnParamsEdit');
            var v = document.getElementById('btnParamsSave');
            var c = document.getElementById('btnParamsCancel');
            if (e) e.style.display = isEditingParams ? 'none' : 'inline-block';
            if (v) v.style.display = isEditingParams ? 'inline-block' : 'none';
            if (c) c.style.display = isEditingParams ? 'inline-block' : 'none';
        }
        function ParamsEdit() {
            isEditingParams = true;
            paramsBackup = {
                roleDesig: cloneObj(appData.roleDesig),
                teamST: cloneObj(appData.teamST),
                teamTL: cloneObj(appData.teamTL),
                teamIQ: cloneObj(appData.teamIQ),
                calc: cloneObj(appData.calc)
            };
            PARAM_EDIT_ROWS = computeParamRows();
            padRoleDesig(); padTeam("ST"); padTeam("TL"); padTeam("IQ");
            RenderParametres();
        }
        function ParamsValider() {
            appData.roleDesig = cleanRoleDesig(appData.roleDesig);
            appData.teamST = cleanTeam(appData.teamST);
            appData.teamTL = cleanTeam(appData.teamTL);
            appData.teamIQ = cleanTeam(appData.teamIQ);
            isEditingParams = false; paramsBackup = null;
            RecomputeAll();   // recalcule l'éligibilité AVANT la sauvegarde
            SaveData();
            RenderParametres();
            UpdateExtractButtons();   // les équipes ont pu changer -> maj de l'état du bouton Extract OF
        }
        function ParamsAnnuler() {
            if (paramsBackup) {
                appData.roleDesig = paramsBackup.roleDesig;
                appData.teamST = paramsBackup.teamST;
                appData.teamTL = paramsBackup.teamTL;
                appData.teamIQ = paramsBackup.teamIQ;
                appData.calc = paramsBackup.calc;
            }
            isEditingParams = false; paramsBackup = null;
            RenderParametres();
        }
        function cleanRoleDesig(a) {
            var o = []; for (var i = 0; i < a.length; i++) {
                if (NettoyerChaine(a[i].resp) !== "" && NettoyerChaine(a[i].type) !== "") o.push(a[i]);
            } return o;
        }
        function cleanTeam(a) {
            var o = []; for (var i = 0; i < a.length; i++) {
                if (NettoyerChaine(a[i].user) !== "") o.push(a[i]);
            } return o;
        }

        function gistRespMap() {
            var m = {}, g = (window.gistCfg && gistCfg.resp) || [];
            for (var i = 0; i < g.length; i++) { var gc = NettoyerChaine(g[i].code); if (gc) m[gc] = g[i].nom || m[gc] || ""; }
            return m;
        }
        function respOptionsHtml(selected, selNom) {
            var m = gistRespMap(), codes = [];
            for (var c in m) { if (m.hasOwnProperty(c)) codes.push(c); }
            codes.sort();
            var h = "<option value=''></option>", found = false;
            for (var i = 0; i < codes.length; i++) {
                if (codes[i] === selected) found = true;
                h += "<option value='" + escapeHtml(codes[i]) + "'" + (codes[i] === selected ? " selected" : "") + ">" + escapeHtml(codes[i]) + " - " + escapeHtml(m[codes[i]]) + "</option>";
            }
            if (selected && !found) h += "<option value='" + escapeHtml(selected) + "' selected>" + escapeHtml(selected) + (selNom ? " - " + escapeHtml(selNom) : "") + "</option>";
            return h;
        }

        function RenderRolesTable() {
            var cont = document.getElementById('rolesContainer');
            var arr = appData.roleDesig || [];
            var ed = isEditingParams;
            var html = "<table class='data-table param-grid'><thead><tr><th width='18%' style='padding:10px 6px; text-align:center;'>Type</th><th style='padding:10px 6px; text-align:center;'>Responsable</th></tr></thead><tbody>";
            for (var i = 0; i < arr.length; i++) {
                var resp = arr[i].resp || "", type = arr[i].type || "";
                if (ed) {
                    html += "<tr>"
                        + "<td class='cell-input' style='text-align:center;'><div class='cell-wrap'><select class='excel-input' style='text-align:center; -ms-text-align-last:center; text-align-last:center; cursor:pointer;' onchange=\"UpdateRoleDesig(" + i + ",'type',this.value); this.blur();\"><option value=''" + (type === "" ? " selected" : "") + "></option><option value='int'" + (type === "int" ? " selected" : "") + ">Interne</option><option value='ext'" + (type === "ext" ? " selected" : "") + ">Externe</option></select></div></td>"
                        + "<td class='cell-input'><div class='cell-wrap'><select class='excel-input' style='cursor:pointer;' onchange=\"SetRoleResp(" + i + ", this.value)\">" + respOptionsHtml(resp, arr[i].nom || "") + "</select></div></td>"
                        + "</tr>";
                } else {
                    var badge = "";
                    if (resp && type === "int") badge = "<span class='badge' style='background:#dcfce3; color:#166534;'>Interne</span>";
                    else if (resp && type === "ext") badge = "<span class='badge' style='background:#f1f5f9; color:#475569;'>Externe</span>";
                    var full = resp + (arr[i].nom ? " - " + arr[i].nom : "");
                    html += "<tr><td style='text-align:center;'>" + badge + "</td>"
                        + "<td style='text-align:left; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;' title='" + escapeHtml(full) + "'>" + escapeHtml(full) + "</td></tr>";
                }
            }
            if (arr.length === 0) html += "<tr><td colspan='2' style='text-align:center; color:#94a3b8; font-style:italic; font-size:12px; padding:12px 10px;'>Utilise « Modifier » pour ajouter des responsables.</td></tr>";
            html += "</tbody></table>";
            cont.innerHTML = html;
        }
        function SetRoleResp(idx, code) {
            var m = gistRespMap(); code = NettoyerChaine(code);
            appData.roleDesig[idx].resp = code;
            if (code === "") appData.roleDesig[idx].nom = "";
            else if (m.hasOwnProperty(code)) appData.roleDesig[idx].nom = m[code];   // sinon (valeur héritée hors Gist) : on conserve le nom
            RenderRolesTable();
            clearFocusSelection();
        }
        function UpdateRoleDesig(idx, field, val) {
            appData.roleDesig[idx][field] = NettoyerChaine(val);
        }

        function teamArr(role) {
            if (role === "ST") return appData.teamST;
            if (role === "TL") return appData.teamTL;
            return appData.teamIQ;
        }
        function teamPeopleFor(role) {
            var out = [], eq = (window.gistCfg && gistCfg.equipe) || [];
            for (var i = 0; i < eq.length; i++) { if (eq[i].team === role) out.push(eq[i]); }
            return out;
        }
        function teamOptionsHtml(role, selUser) {
            var ppl = teamPeopleFor(role), h = "<option value=''></option>", seen = {}, found = false;
            for (var i = 0; i < ppl.length; i++) {
                var u = ppl[i].user; if (!u || seen[u]) continue; seen[u] = true;
                if (u === selUser) found = true;
                h += "<option value='" + escapeHtml(u) + "'" + (u === selUser ? " selected" : "") + ">" + escapeHtml(u) + "</option>";
            }
            if (selUser && !found) h += "<option value='" + escapeHtml(selUser) + "' selected>" + escapeHtml(selUser) + "</option>";
            return h;
        }
        function RenderTeam(role) {
            var cont = document.getElementById('team' + role);
            var arr = teamArr(role);
            var ed = isEditingParams;
            var html = "<table class='data-table param-grid'><thead><tr><th width='34%' style='padding:10px 6px; text-align:center;'>User</th><th style='padding:10px 6px; text-align:center;'>Nom</th></tr></thead><tbody>";
            for (var i = 0; i < arr.length; i++) {
                if (ed) {
                    html += "<tr>"
                        + "<td class='cell-input'><div class='cell-wrap'><select class='excel-input' style='text-align:center; -ms-text-align-last:center; text-align-last:center; cursor:pointer;' onchange=\"SetTeamUser('" + role + "'," + i + ",this.value)\">" + teamOptionsHtml(role, arr[i].user || "") + "</select></div></td>"
                        + "<td style='text-align:left; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; color:#475569;' title='" + escapeHtml(arr[i].nom || "") + "'>" + escapeHtml(arr[i].nom || "") + "</td>"
                        + "</tr>";
                } else {
                    html += "<tr><td style='font-weight:700; text-align:center;'>" + escapeHtml(arr[i].user || "") + "</td><td>" + escapeHtml(arr[i].nom || "") + "</td></tr>";
                }
            }
            if (arr.length === 0) {
                html += "<tr><td colspan='2' style='text-align:center; color:#94a3b8; font-style:italic; font-size:12px; padding:10px;'>Aucun membre</td></tr>";
            }
            html += "</tbody></table>";
            cont.innerHTML = html;
        }
        function clearFocusSelection() {
            try { if (document.activeElement && document.activeElement.blur) document.activeElement.blur(); } catch (e) {}
            try {
                if (window.getSelection) { var s = window.getSelection(); if (s && s.removeAllRanges) s.removeAllRanges(); }
                else if (document.selection && document.selection.empty) document.selection.empty();
            } catch (e2) {}
        }
        function SetTeamUser(role, idx, user) {
            user = NettoyerChaine(user).toUpperCase();
            var nom = "", ppl = teamPeopleFor(role);
            for (var i = 0; i < ppl.length; i++) { if (ppl[i].user === user) { nom = ppl[i].nom; break; } }
            var a = teamArr(role); if (!a[idx]) return;
            a[idx].user = user; a[idx].nom = nom;
            RenderTeam(role);
            clearFocusSelection();
        }

    // ==========================================================
    // PAGE : DASHBOARD
    // ==========================================================
        function RenderDashboard() {
            var elig = [];
            for (var i = 0; i < ncList.length; i++) { if (ncList[i].eligible) elig.push(ncList[i]); }
            var fbar = document.getElementById('dashFilterBar'); if (fbar) fbar.innerHTML = dashRespFilterBar();

            var eb = document.getElementById('dashExportNC');
            if (elig.length === 0) {
                var empNC = document.getElementById('dashEmpty');
                empNC.style.display = "block";
                document.getElementById('dashCharts').style.display = "none";
                if (eb) eb.style.display = 'none';
                var avNC = ComputeAvailHeight('dashEmpty'); if (avNC != null) empNC.style.height = avNC + "px";
                dashValid.NC = true;
                return;
            }
            document.getElementById('dashEmpty').style.display = "none";
            if (eb) eb.style.display = '';   // données présentes -> bouton d'export visible
            var dc = document.getElementById('dashCharts'); dc.style.display = "block";
            var ct = document.getElementById('content'); if (ct) ct.style.overflowY = 'hidden';   // dashboard = pas de scrollbar (au démarrage, RenderDashboard est appelé hors ShowPage)

            SetDashCardHeight('dashRowStyleNC', 'dashCardNC', 3, dc.getBoundingClientRect().top);
            var d3w = document.getElementById('dash3weeks');
            dashRow1Height = (d3w && d3w.clientHeight > 120) ? d3w.clientHeight : 220;   // hauteur réelle d'un conteneur (widget SVG "3 semaines")

            var eligF = [];
            for (var f = 0; f < elig.length; f++) { if (inSelectedPeriod(elig[f].end)) eligF.push(elig[f]); }

            RenderDash3Weeks(elig);    // 3 dernières semaines : NON filtré
            RenderWeeksChart(eligF);   // courbes par semaine : filtré
            RenderDashResp(eligF);
            RenderDashTeams(eligF);
            ReflowDashCharts(['hcWeeks', 'hcRespInt', 'hcRespExt', 'hcSeuilEquipe', 'hcSeuilGlobal', 'hcTeamST', 'hcTeamTL', 'hcTeamIQ']);
            dashValid.NC = true;       // rendu à jour : pas de re-rendu au retour sur l'onglet tant que rien ne change
        }
        function SetDashCardHeight(styleId, cardClass, rows, topPx) {
            var st = document.getElementById(styleId);
            if (!st) { st = document.createElement('style'); st.id = styleId; (document.getElementsByTagName('head')[0] || document.documentElement).appendChild(st); }
            var off = Math.max(0, Math.round(topPx)) + rows * 20;   // marges entre lignes (chaque ligne : margin-bottom 20px)
            var rule = '.' + cardClass + ' { height: calc((100vh - ' + off + 'px) / ' + rows + '); }';
            if (st.styleSheet) st.styleSheet.cssText = rule;   // IE
            else st.innerHTML = rule;
        }
        function ReflowDashCharts(ids) {
            for (var i = 0; i < ids.length; i++) { var c = window.hcRefs[ids[i]]; if (c) { try { c.reflow(); } catch (e) {} } }
        }
        var dashRow1Height = 280;
        function ComputeAvailHeight(containerId) {
            var charts = document.getElementById(containerId), contentEl = document.getElementById('content');
            if (!charts || !charts.offsetParent) return null;   // conteneur masqué (onglet inactif) -> pas de dimensionnement (top=0 -> cadre surdimensionné)
            if (contentEl) contentEl.scrollTop = 0;   // mesure toujours en haut (un #content défilé fausse la position -> cadre surdimensionné)
            var top = charts.getBoundingClientRect().top;   // position viewport du conteneur (base fiable en IE10, comme AjusterHauteurTables)
            var avail = window.innerHeight - top - 30;      // marge basse > padding bas de #content (25px)
            if (avail < 300) avail = 300;
            return avail;
        }

        function fmtDDMM(d) { var dd = d.getDate(), mm = d.getMonth() + 1; return (dd < 10 ? '0' + dd : '' + dd) + '/' + (mm < 10 ? '0' + mm : '' + mm); }
        function isoWeekMonday(year, week) {
            var jan4 = new Date(year, 0, 4), jan4Day = (jan4.getDay() + 6) % 7;   // lundi = 0
            var w1Mon = new Date(year, 0, 4 - jan4Day);                            // lundi de la semaine 1
            return new Date(w1Mon.getFullYear(), w1Mon.getMonth(), w1Mon.getDate() + (week - 1) * 7);
        }
        function selectedWeekDays() {
            var mon = isoWeekMonday(dashFilter.year, dashFilter.week), out = [];
            var nb = ((appData.calc && appData.calc.mode) === 'ouvre') ? 5 : 7;   // jours ouvrés : lun-ven
            for (var i = 0; i < nb; i++) { var d = new Date(mon.getFullYear(), mon.getMonth(), mon.getDate() + i); out.push(d.getTime()); }
            return out;
        }
        // === MODE MSN : buckets = valeurs de MSN (au lieu de semaines/jours) ===
        function msnBucketKey(v) { var s = NettoyerChaine(v); return s ? s : '-'; }   // '-' = sans MSN
        function msnSortKeys(keys) {
            keys.sort(function (a, b) {
                var na = parseInt(a, 10), nb = parseInt(b, 10);
                if (!isNaN(na) && !isNaN(nb)) return na - nb;
                return a < b ? -1 : (a > b ? 1 : 0);
            });
            return keys;
        }
        var MOIS_COURTS = ['Jan', 'Fév', 'Mar', 'Avr', 'Mai', 'Juin', 'Juil', 'Aoû', 'Sep', 'Oct', 'Nov', 'Déc'];
        function granBucketMode() {
            if (dashFilter.gran === 'week') return 'day';
            if (dashFilter.gran === 'year') return 'month';
            return 'week';
        }
        function granAxisNoun() {
            if (dashFilter.gran === 'msn') return "par MSN";
            if (dashFilter.gran === 'week') return "par jour";
            if (dashFilter.gran === 'year') return "par mois";
            return "par semaine";
        }
        function bucketTsForMode(d, mode) {
            if (mode === 'day') return new Date(d.getFullYear(), d.getMonth(), d.getDate()).getTime();
            if (mode === 'month') return new Date(d.getFullYear(), d.getMonth(), 1).getTime();
            return getWeekStart(d).getTime();
        }
        function bucketKeysForMode(mode, presentSet) {
            if (mode === 'day') return selectedWeekDays();
            if (mode === 'month') {
                var out = [], now = new Date();
                var lastM = (dashFilter.year === now.getFullYear()) ? now.getMonth() : 11;   // année en cours -> jusqu'au mois actuel
                for (var m = 0; m <= lastM; m++) out.push(new Date(dashFilter.year, m, 1).getTime());
                return out;
            }
            var keys = []; for (var w in presentSet) { if (presentSet.hasOwnProperty(w)) keys.push(parseInt(w, 10)); } keys.sort(function (a, b) { return a - b; }); return keys;
        }
        function bucketLabelForMode(ts, mode) {
            var dd = new Date(ts);
            if (mode === 'day') return fmtDDMM(dd);
            if (mode === 'month') return MOIS_COURTS[dd.getMonth()];
            return "S" + isoWeek(dd);
        }
        function msnSelected(key) { return !dashFilter.msnSel || dashFilter.msnSel[key]; }
        function dashAllMSN() {
            var set = {}, i;
            for (i = 0; i < ncList.length; i++) { if (ncList[i].eligible && ncList[i].end) set[msnBucketKey(ncList[i].msn)] = true; }
            var ofRows = getOFTeamRows('cree').concat(getOFTeamRows('clot'));
            for (i = 0; i < ofRows.length; i++) set[msnBucketKey(ofRows[i].msn)] = true;
            var ic = appData.icRows || [];
            for (i = 0; i < ic.length; i++) set[msnBucketKey(ic[i].msn)] = true;
            var pl = appData.planif || [];
            for (i = 0; i < pl.length; i++) { var pm = NettoyerChaine(pl[i].msn); if (pm) set[msnBucketKey(pm)] = true; }   // MSN du planning
            var out = []; for (var mm in set) { if (set.hasOwnProperty(mm)) out.push(mm); }
            return msnSortKeys(out);
        }
        function computeMSNPts(elig) {
            var agg = {};
            for (var i = 0; i < elig.length; i++) {
                var nc = elig[i]; if (!nc.end) continue;
                var key = msnBucketKey(nc.msn);
                if (!msnSelected(key)) continue;
                if (!agg[key]) agg[key] = { n: 0, sg: 0, ng: 0, st: 0, nt: 0 };
                agg[key].n++;
                if (nc.durMs != null) { agg[key].sg += nc.durMs; agg[key].ng++; }
                if (nc.chezMs != null) { agg[key].st += nc.chezMs; agg[key].nt++; }
            }
            var keys = []; for (var k in agg) { if (agg.hasOwnProperty(k)) keys.push(k); }
            msnSortKeys(keys);
            var pts = [];
            for (var m = 0; m < keys.length; m++) { var a = agg[keys[m]]; pts.push({ week: keys[m], label: keys[m], n: a.n, g: a.ng ? a.sg / a.ng : null, t: a.nt ? a.st / a.nt : null }); }
            return pts;
        }
        function computeWeekPts(elig) {
            if (dashFilter.gran === 'msn') return computeMSNPts(elig);
            return computeTimePts(elig, granBucketMode());
        }
        function computeTimePts(elig, mode) {
            var agg = {};
            for (var i = 0; i < elig.length; i++) {
                var nc = elig[i]; if (!nc.end) continue;
                var key = bucketTsForMode(nc.end, mode);
                if (!agg[key]) agg[key] = { n: 0, sg: 0, ng: 0, st: 0, nt: 0 };
                agg[key].n++;
                if (nc.durMs != null) { agg[key].sg += nc.durMs; agg[key].ng++; }
                if (nc.chezMs != null) { agg[key].st += nc.chezMs; agg[key].nt++; }
            }
            var keys = bucketKeysForMode(mode, agg);
            var pts = [];
            for (var k = 0; k < keys.length; k++) {
                var a = agg[keys[k]], dd = new Date(keys[k]);
                pts.push({ week: isoWeek(dd), label: bucketLabelForMode(keys[k], mode), n: a ? a.n : 0, g: (a && a.ng) ? a.sg / a.ng : null, t: (a && a.nt) ? a.st / a.nt : null });
            }
            return pts;
        }
        function RenderDash3Weeks(eligAll) {
            var pts = computeTimePts(eligAll, 'week');   // TOUJOURS par semaine (indépendant du mode/granularité)
            if (!pts.length) { document.getElementById('dash3weeks').innerHTML = "<div class='msg-box msg-info'>Aucune donnée.</div>"; return; }
            document.getElementById('dash3weeks').innerHTML = build3WeekSummary(pts.slice(Math.max(0, pts.length - 3)), dashRow1Height);
            EgaliserCards(document.querySelectorAll('#dash3weeks .wkbox'));   // les 3 cases (1 par semaine) à la même hauteur
        }
        function RenderWeeksChart(elig) {
            var wt = document.getElementById('dashWeeksTitle');
            if (wt) wt.innerHTML = "Évolution du traitement " + granAxisNoun();
            var pts = computeWeekPts(elig);
            var hasData = false;
            for (var i = 0; i < pts.length; i++) { if (pts[i].g != null || pts[i].t != null) { hasData = true; break; } }
            if (!hasData) { hcDestroy('hcWeeks'); document.getElementById('dashWeeks').innerHTML = emptyChartHtml(dashRow1Height); return; }
            renderWeeksLineChart(pts);
        }
        function build3WeekSummary(wk, targetHeight) {
            if (!wk.length) return "<div class='msg-box msg-info'>Aucune donnée.</div>";
            var n = wk.length, cw = 100 / n, colW = cw.toFixed(2);
            var l1 = "<div style='font-size:0;'>";
            for (var i = 0; i < n; i++) {
                l1 += "<div style='display:inline-block; vertical-align:top; width:" + colW + "%; box-sizing:border-box; padding:0 5px; text-align:center; font-size:14px; font-weight:700; color:#334155;'>Semaine " + wk[i].week + "</div>";
            }
            l1 += "</div>";
            var l2 = "<div style='font-size:0;'>";
            for (var j = 0; j < n; j++) {
                l2 += "<div style='display:inline-block; vertical-align:top; width:" + colW + "%; box-sizing:border-box; padding:0 5px;'>"
                    + "<div class='wkbox' style='background:#f8fafc; border:1px solid #e2e8f0; border-radius:8px; padding:14px 9px; box-sizing:border-box;'>"
                    + "<div style='font-size:13px; color:#475569; margin-bottom:6px; white-space:nowrap;'><span style='display:inline-block; width:9px; height:9px; background:#0C447C; border-radius:2px; margin-right:5px;'></span>Global : <b style='color:#0C447C;'>" + fmtDHM(wk[j].g) + "</b></div>"
                    + "<div style='font-size:13px; color:#475569; white-space:nowrap;'><span style='display:inline-block; width:9px; height:9px; background:#166534; border-radius:2px; margin-right:5px;'></span>Équipe : <b style='color:#166534;'>" + fmtDHM(wk[j].t) + "</b></div>"
                    + "</div></div>";
            }
            l2 += "</div>";
            var l3 = "";
            if (n >= 2) {
                l3 = "<div style='font-size:0;'>";
                var ew = (100 / (n - 1)).toFixed(2);
                for (var k = 0; k < n - 1; k++) {
                    l3 += "<div style='display:inline-block; vertical-align:top; width:" + ew + "%; box-sizing:border-box; padding:0 5px;'>"
                        + "<div style='font-size:13px; font-weight:600; color:#64748b; text-align:center; margin-bottom:6px;'>S" + wk[k].week + " &rarr; S" + wk[k + 1].week + "</div>"
                        + evoBox(wk[k], wk[k + 1]) + "</div>";
                }
                l3 += "</div>";
            }
            var h = targetHeight ? ("height:" + targetHeight + "px; ") : "";
            return "<div style='" + h + "display:-ms-flexbox; display:flex; -ms-flex-direction:column; flex-direction:column; -ms-flex-pack:justify; justify-content:space-between; box-sizing:border-box;'>" + l1 + l2 + l3 + "</div>";
        }
        function evoBox(a, b) {
            var dGlobal = b.g - a.g, boxAmelio = dGlobal < 0, boxDegr = dGlobal > 0;
            var boxBg = boxAmelio ? "#dcfce3" : (boxDegr ? "#fee2e2" : "#f8fafc");
            var boxBorder = boxAmelio ? "#86efac" : (boxDegr ? "#fca5a5" : "#e2e8f0");
            function line(label, fromV, toV, isLast) {
                var delta = toV - fromV, amelio = delta < 0, degr = delta > 0;
                var arrow = amelio ? "&#8600;" : (degr ? "&#8599;" : "&#8211;");
                var c = amelio ? "#166534" : (degr ? "#b91c1c" : "#64748b");
                var txt = (delta === 0) ? "Stable" : ((amelio ? "-" : "+") + fmtDHM(Math.abs(delta)));
                var mb = isLast ? "0" : "6px";
                return "<div style='font-size:14px; color:#475569; margin-bottom:" + mb + "; text-align:center;'>" + label + " <b style='color:" + c + ";'>" + arrow + " " + txt + "</b></div>";
            }
            return "<div style='background:" + boxBg + "; border:1px solid " + boxBorder + "; border-radius:8px; padding:14px 12px; text-align:center; box-sizing:border-box;'>"
                + line("Global", a.g, b.g, false) + line("Équipe", a.t, b.t, true)
                + "</div>";
        }
        // Config de base commune des graphiques Highcharts du tableau de bord (fond transparent, police héritée) + message d'erreur commun.
        function hcChart(type, spacing) { return { type: type, backgroundColor: 'transparent', spacing: spacing, style: { fontFamily: 'inherit' } }; }
        function hcErr(c) { if (c) c.innerHTML = "<div class='msg-box msg-error'>Erreur graphique.</div>"; }
        window.hcRefs = window.hcRefs || {};
        function hcDraw(id, config) {
            var el = document.getElementById(id);
            if (!el) return null;
            var ch = window.hcRefs[id];
            if (ch && ch.renderTo === el && ch.series) {
                try { ch.update(config, true, true); try { ch.reflow(); } catch (e3) {} return ch; }
                catch (e) { try { ch.destroy(); } catch (e2) {} window.hcRefs[id] = null; }
            }
            window.hcRefs[id] = Highcharts.chart(id, config);
            return window.hcRefs[id];
        }
        function hcDestroy(id) {
            if (window.hcRefs[id]) { try { window.hcRefs[id].destroy(); } catch (e) {} window.hcRefs[id] = null; }
        }
        function emptyChartHtml(h) {
            var hs = h ? ("height:" + h + "px;") : "height:100%; min-height:120px;";
            return "<div style='" + hs + " margin:0; border:2px dashed #cbd5e1; border-radius:8px; background:#f1f5f9; color:#64748b; font-style:italic; text-align:center; display:table; width:100%; box-sizing:border-box;'><span style='display:table-cell; vertical-align:middle;'>Aucune donnée</span></div>";
        }
        function renderWeeksLineChart(pts) {
            var cont = document.getElementById('dashWeeks');
            if (typeof Highcharts === 'undefined') { cont.innerHTML = buildWeeksLine(pts); return; }
            var hc = document.getElementById('hcWeeks');
            if (!hc) { cont.innerHTML = "<div id='hcWeeks' style='width:100%; height:100%;'></div>"; }
            var dMs = dayMs(), cats = [], gData = [], tData = [];
            for (var i = 0; i < pts.length; i++) {
                cats.push(pts[i].label);
                gData.push(pts[i].g == null ? null : { y: Math.round(pts[i].g / dMs * 100) / 100, ms: pts[i].g });
                tData.push(pts[i].t == null ? null : { y: Math.round(pts[i].t / dMs * 100) / 100, ms: pts[i].t });
            }
            try {
                window.hcWeeksChart = hcDraw('hcWeeks', {
                    chart: hcChart('line', [6, 2, 0, 2]),
                    title: { text: null },
                    credits: { enabled: false },
                    legend: { enabled: true, align: 'center', verticalAlign: 'bottom', layout: 'horizontal', itemStyle: { fontSize: '12px' }, margin: 4, padding: 4, itemMarginTop: 0, itemMarginBottom: 0 },
                    xAxis: { categories: cats, labels: { style: { color: '#334155', fontWeight: '600' } } },
                    yAxis: {
                        title: { text: null }, min: 0, tickInterval: 5,
                        plotLines: [{ value: 2, color: '#dc2626', dashStyle: 'Dash', width: 1.5, zIndex: 5 }]
                    },
                    tooltip: {
                        useHTML: true,
                        formatter: function () { return '<b>' + this.series.name + '</b><br/>' + this.key + ' : ' + fmtDHM(this.point.ms); }
                    },
                    plotOptions: { line: { animation: false, marker: { radius: 4 }, lineWidth: 2.5 }, series: { connectNulls: true } },
                    series: [
                        { name: 'Traitement global', data: gData, color: '#0C447C' },
                        { name: 'Traitement équipe', data: tData, color: '#166534' }
                    ]
                });
            } catch (e) { cont.innerHTML = buildWeeksLine(pts); }
        }
        function buildWeeksLine(pts) {
            var W = 760, H = 320, mL = 52, mR = 18, mT = 16, mB = 52;
            var plotW = W - mL - mR, plotH = H - mT - mB, n = pts.length;
            var maxV = 0;
            for (var i = 0; i < n; i++) { if (pts[i].g > maxV) maxV = pts[i].g; if (pts[i].t > maxV) maxV = pts[i].t; }
            var dMs = dayMs();
            var maxDays = Math.max(1, Math.ceil(maxV / dMs));
            var step = Math.max(1, Math.ceil(maxDays / 5));
            maxDays = Math.ceil(maxDays / step) * step;
            var maxScale = maxDays * dMs;
            function x(i2) { return mL + (n === 1 ? plotW / 2 : plotW * i2 / (n - 1)); }
            function y(v) { return mT + plotH - (v / maxScale) * plotH; }
            var svg = "<svg viewBox='0 0 " + W + " " + H + "' preserveAspectRatio='xMidYMid meet' style='position:absolute; top:0; left:0; width:100%; height:100%; font-family:inherit;'>";
            for (var d = 0; d <= maxDays; d += step) {
                var yy = y(d * dMs);
                svg += "<line x1='" + mL + "' y1='" + yy + "' x2='" + (W - mR) + "' y2='" + yy + "' stroke='#e2e8f0' stroke-width='1'/>";
                svg += "<text x='" + (mL - 8) + "' y='" + (yy + 4) + "' text-anchor='end' font-size='11' fill='#64748b'>" + d + " j</text>";
            }
            if (2 * dMs <= maxScale) {
                var yRed = y(2 * dMs);
                svg += "<line x1='" + mL + "' y1='" + yRed + "' x2='" + (W - mR) + "' y2='" + yRed + "' stroke='#dc2626' stroke-width='1.5' stroke-dasharray='5 4'/>";
                svg += "<text x='" + (W - mR) + "' y='" + (yRed - 5) + "' text-anchor='end' font-size='11' font-weight='700' fill='#dc2626'>2 j</text>";
            }
            for (var j = 0; j < n; j++) {
                var xx = x(j);
                svg += "<text x='" + xx + "' y='" + (H - mB + 24) + "' text-anchor='middle' font-size='12' fill='#334155' font-weight='600'>S" + pts[j].week + "</text>";
            }
            function poly(key, color, label) {
                var path = "";
                for (var p = 0; p < n; p++) { path += (p ? " L" : "M") + x(p).toFixed(1) + " " + y(pts[p][key]).toFixed(1); }
                var s = "<path d='" + path + "' fill='none' stroke='" + color + "' stroke-width='2.5'/>";
                for (var c = 0; c < n; c++) {
                    var tt = label + " · Semaine " + pts[c].week + " · " + pts[c].n + " NC · " + fmtDHM(pts[c][key]);
                    s += "<circle cx='" + x(c).toFixed(1) + "' cy='" + y(pts[c][key]).toFixed(1) + "' r='5' fill='" + color + "' style='cursor:pointer;'><title>" + escapeHtml(tt) + "</title></circle>";
                }
                return s;
            }
            svg += poly('g', '#0C447C', 'Traitement global') + poly('t', '#166534', 'Traitement équipe') + "</svg>";
            var legend = "<div style='text-align:center; margin-top:10px; font-size:12px; color:#334155;'>"
                + "<span style='display:inline-block; width:12px; height:12px; background:#0C447C; border-radius:2px; vertical-align:middle; margin-right:6px;'></span>Traitement global"
                + "<span style='display:inline-block; width:12px; height:12px; background:#166534; border-radius:2px; vertical-align:middle; margin:0 6px 0 18px;'></span>Traitement équipe</div>";
            return "<div style='position:relative; width:100%; height:0; padding-bottom:" + (H / W * 100).toFixed(1) + "%;'>" + svg + "</div>" + legend;
        }

        var dashFilter = { gran: 'month', year: new Date().getFullYear(), month: new Date().getMonth(), week: null, msnSel: null };
        function inSelectedPeriod(d) {
            if (dashFilter.gran === 'all' || dashFilter.gran === 'msn') return true;   // MSN : TOUTES les périodes (regroupement par MSN)
            if (!d) return false;
            if (d.getFullYear() !== dashFilter.year) return false;
            if (dashFilter.gran === 'year') return true;
            if (dashFilter.gran === 'week') return isoWeek(d) === dashFilter.week;
            return d.getMonth() === dashFilter.month;   // 'month' : filtre par mois
        }
        function dashAllDates() {
            var out = [];
            for (var i = 0; i < ncList.length; i++) { var nc = ncList[i]; if (nc.eligible && nc.end) out.push(nc.end); }
            var ofRows = getOFTeamRows('cree').concat(getOFTeamRows('clot'));
            for (var j = 0; j < ofRows.length; j++) { var d = parseOFDateObj(ofRows[j].date); if (d) out.push(d); }
            var ic = appData.icRows || [];
            for (var k = 0; k < ic.length; k++) { var dic = parseDT(ic[k].dc, ic[k].hc); if (dic) out.push(dic); }   // dates de clôture IC
            var pl = appData.planif || [];
            for (var p = 0; p < pl.length; p++) { var dpl = parseOFDateObj(pl[p].date); if (dpl) out.push(dpl); }   // dates du planning
            return out;
        }
        function dashYearsList() {
            var ds = dashAllDates(), ys = {}, out = [];
            for (var i = 0; i < ds.length; i++) ys[ds[i].getFullYear()] = true;
            for (var y in ys) { if (ys.hasOwnProperty(y)) out.push(parseInt(y, 10)); }
            out.sort(function (a, b) { return b - a; });
            if (!out.length) out.push(new Date().getFullYear());
            return out;
        }
        function dashMonthList() {
            var ds = dashAllDates(), seen = {}, out = [];
            for (var i = 0; i < ds.length; i++) { var k = ds[i].getFullYear() + '-' + ds[i].getMonth(); if (!seen[k]) { seen[k] = true; out.push({ year: ds[i].getFullYear(), month: ds[i].getMonth() }); } }
            out.sort(function (a, b) { return (b.year - a.year) || (b.month - a.month); });
            return out;
        }
        function dashWeekList() {
            var ds = dashAllDates(), seen = {}, out = [];
            for (var i = 0; i < ds.length; i++) { var w = isoWeek(ds[i]), k = ds[i].getFullYear() + '-' + w; if (!seen[k]) { seen[k] = true; out.push({ year: ds[i].getFullYear(), week: w }); } }
            out.sort(function (a, b) { return (b.year - a.year) || (b.week - a.week); });
            return out;
        }
        var MOIS_NOMS = ['Janvier', 'Février', 'Mars', 'Avril', 'Mai', 'Juin', 'Juillet', 'Août', 'Septembre', 'Octobre', 'Novembre', 'Décembre'];
        function dashPeriodState() {
            var g = dashFilter.gran;
            if (g === 'year') {
                var ys = dashYearsList();
                return { items: ys, idx: ys.indexOf(dashFilter.year),
                    val: function (x) { return "" + x; }, label: function (x) { return "" + x; },
                    set: function (x) { dashFilter.year = x; } };
            }
            if (g === 'month' || g === 'msn') {   // MSN : on garde le sélecteur de mois pour filtrer la période
                var ml = dashMonthList(), im = -1;
                for (var i = 0; i < ml.length; i++) { if (ml[i].year === dashFilter.year && ml[i].month === dashFilter.month) { im = i; break; } }
                return { items: ml, idx: im,
                    val: function (x) { return x.year + "-" + x.month; }, label: function (x) { return MOIS_NOMS[x.month] + " " + x.year; },
                    set: function (x) { dashFilter.year = x.year; dashFilter.month = x.month; } };
            }
            if (g === 'week') {
                var wl = dashWeekList(), iw = -1;
                for (var j = 0; j < wl.length; j++) { if (wl[j].year === dashFilter.year && wl[j].week === dashFilter.week) { iw = j; break; } }
                return { items: wl, idx: iw,
                    val: function (x) { return x.year + "W" + x.week; }, label: function (x) { return "S" + x.week + " · " + x.year; },
                    set: function (x) { dashFilter.year = x.year; dashFilter.week = x.week; } };
            }
            return null;
        }
        function StepDashPeriod(dir) {
            var s = dashPeriodState(); if (!s || s.idx < 0) return;
            var ni = s.idx - dir;
            if (ni < 0 || ni >= s.items.length) return;
            s.set(s.items[ni]);
            InvalidateDash(); RenderActiveDashboardSub();
        }
        function dashRespFilterBar() {
            if (dashFilter.gran === 'all') {   // 'all' n'est pas un mode supporté -> repli sur Mois
                dashFilter.gran = 'month';
                if (dashFilter.month == null) dashFilter.month = new Date().getMonth();
            }
            var grans = [['year', 'Année'], ['month', 'Mois'], ['week', 'Semaine'], ['msn', 'MSN']];
            var seg = "";
            for (var i = 0; i < grans.length; i++) {
                var g = grans[i][0], on = dashFilter.gran === g;
                var rad = (i === 0) ? "border-radius:6px 0 0 6px;" : ((i === grans.length - 1) ? "border-radius:0 6px 6px 0;" : "border-radius:0;");
                seg += "<button type='button' onclick=\"SetDashGran('" + g + "')\" style='font-size:13px; font-weight:600; padding:7px 14px; border:1px solid " + (on ? "#0C447C" : "#c5d5de") + "; " + (i > 0 ? "border-left:none; " : "") + rad + " cursor:pointer; vertical-align:middle; " + (on ? "background:#0C447C; color:#fff;" : "background:#fff; color:#475569;") + "'>" + grans[i][1] + "</button>";
            }

            var arw = function (dis) { return "font-size:12px; font-weight:700; padding:7px 0; width:36px; text-align:center; border:1px solid #c5d5de; background:" + (dis ? "#f1f5f9" : "#fff") + "; color:" + (dis ? "#cbd5e1" : "#0C447C") + "; cursor:" + (dis ? "default" : "pointer") + "; vertical-align:middle; height:34px; box-sizing:border-box;"; };
            var right;
            if (dashFilter.gran === 'msn') {
                right = dashMsnControlHtml();   // multi-sélection des MSN (au lieu du sélecteur de période)
            } else {
                var s = dashPeriodState();
                if (s.idx < 0 && s.items.length) { s.set(s.items[0]); s.idx = 0; }
                var opt = "";
                for (var k = 0; k < s.items.length; k++) { opt += "<option value='" + s.val(s.items[k]) + "'" + (k === s.idx ? " selected" : "") + ">" + s.label(s.items[k]) + "</option>"; }
                var atNewest = (s.idx <= 0), atOldest = (s.idx >= s.items.length - 1);
                var prev = "<button type='button'" + (atOldest ? " disabled" : "") + " onclick=\"StepDashPeriod(-1)\" title='Période précédente' style='" + arw(atOldest) + " border-radius:6px 0 0 6px;'>&#9664;</button>";
                var next = "<button type='button'" + (atNewest ? " disabled" : "") + " onclick=\"StepDashPeriod(1)\" title='Période suivante' style='" + arw(atNewest) + " border-left:none; border-radius:0 6px 6px 0;'>&#9654;</button>";
                var curLabel = (s.idx >= 0 && s.items.length) ? s.label(s.items[s.idx]) : "";
                var ddW = 160;   // largeur constante quel que soit le mode (Année/Mois/Semaine)
                var dd = "<span style='position:relative; display:inline-block; width:" + ddW + "px; height:34px; vertical-align:middle;'>"
                    + "<span style='position:absolute; top:0; left:0; width:100%; height:34px; line-height:32px; box-sizing:border-box; border:1px solid #c5d5de; border-left:none; background:#fff; color:#0C447C; font-size:13px; font-weight:700; text-align:center; overflow:hidden; white-space:nowrap;'>" + escapeHtml(curLabel) + "</span>"
                    + "<select class='dashPeriodSelect' onchange='SetDashPeriod(this.value)' style='position:absolute; top:0; left:0; width:100%; height:34px; opacity:0; cursor:pointer; font-size:13px;'>" + opt + "</select>"
                    + "</span>";
                right = prev + dd + next;
            }
            return "<span style='white-space:nowrap;'>" + seg + "<span style='margin-left:16px; vertical-align:middle;'>" + right + "</span></span>";
        }
        function dashMsnControlHtml() {
            var all = dashAllMSN();
            var selCount = 0, tous = !dashFilter.msnSel;
            if (!tous) { for (var kk in dashFilter.msnSel) { if (dashFilter.msnSel.hasOwnProperty(kk) && dashFilter.msnSel[kk]) selCount++; } }
            var lbl = tous ? "Tous les MSN" : (selCount + " MSN sélectionné" + (selCount > 1 ? "s" : ""));
            var btn = "<button type='button' id='msnBtn' onclick=\"ToggleMsnPanel(event)\" style='font-size:13px; font-weight:700; padding:7px 14px; border:1px solid #c5d5de; border-radius:6px; background:#fff; color:#0C447C; cursor:pointer; vertical-align:middle; height:34px; box-sizing:border-box; width:232px; text-align:center;'>" + escapeHtml(lbl) + " &#9662;</button>";
            var rows = "<label style='display:block; padding:6px 12px; font-weight:700; border-bottom:1px solid #e2e8f0; cursor:pointer;'><input type='checkbox'" + (tous ? " checked" : "") + " onclick=\"SetAllMsn(this.checked, event)\" style='margin-right:8px; vertical-align:middle;'>Tout sélectionner</label>";
            for (var i = 0; i < all.length; i++) {
                var key = all[i], on = msnSelected(key);
                var txt = (key === '-') ? '(Sans MSN)' : ('MSN ' + key);
                rows += "<label style='display:block; padding:6px 12px; cursor:pointer; white-space:nowrap;'><input type='checkbox'" + (on ? " checked" : "") + " onclick=\"ToggleMsnKey('" + escapeHtml(key) + "', this.checked, event)\" style='margin-right:8px; vertical-align:middle;'>" + escapeHtml(txt) + "</label>";
            }
            if (!all.length) rows += "<div style='padding:10px 12px; color:#94a3b8; font-style:italic;'>Aucun MSN</div>";
            var panel = "<div id='msnPanel' style='display:none; position:fixed; z-index:200; background:#fff; border:1px solid #c5d5de; border-radius:6px; box-shadow:0 6px 16px rgba(0,0,0,0.18); max-height:340px; overflow-y:auto; min-width:180px; text-align:left; font-size:13px; color:#334155;'>" + rows + "</div>";
            return "<span style='position:relative; display:inline-block; vertical-align:middle;'>" + btn + panel + "</span>";
        }
        function showMsnPanel() {
            var p = document.getElementById('msnPanel'), btn = document.getElementById('msnBtn');
            if (!p || !btn) return;
            p.style.display = 'block';
            var r = btn.getBoundingClientRect(), pw = p.offsetWidth;
            p.style.top = (r.bottom + 2) + 'px';
            p.style.left = Math.max(8, r.right - pw) + 'px';
        }
        function ToggleMsnPanel(ev) {
            var p = document.getElementById('msnPanel');
            if (p) { if (p.style.display === 'block') p.style.display = 'none'; else showMsnPanel(); }
            if (ev && ev.stopPropagation) ev.stopPropagation();
        }
        function updateMsnBtnLabel() {
            var btn = document.getElementById('msnBtn'); if (!btn) return;
            var tous = !dashFilter.msnSel, selCount = 0;
            if (!tous) { for (var kk in dashFilter.msnSel) { if (dashFilter.msnSel.hasOwnProperty(kk) && dashFilter.msnSel[kk]) selCount++; } }
            btn.innerHTML = escapeHtml(tous ? "Tous les MSN" : (selCount + " MSN sélectionné" + (selCount > 1 ? "s" : ""))) + " &#9662;";
        }
        var msnRerenderTimer = null;
        function scheduleDashRerender() {
            if (msnRerenderTimer) clearTimeout(msnRerenderTimer);
            msnRerenderTimer = setTimeout(function () {
                msnRerenderTimer = null;
                var p = document.getElementById('msnPanel'), wasOpen = !!(p && p.style.display === 'block');
                InvalidateDash(); RenderActiveDashboardSub();
                if (wasOpen) showMsnPanel();   // ne rouvre le panneau que s'il était ouvert
            }, 350);
        }
        function SetAllMsn(on, ev) {
            if (ev && ev.stopPropagation) ev.stopPropagation();   // le clic ne remonte pas -> ne ferme pas le panneau
            dashFilter.msnSel = on ? null : {};   // null = tous ; {} = aucun
            InvalidateDash(); RenderActiveDashboardSub(); showMsnPanel();   // 1 seul clic -> immédiat (met à jour toutes les cases)
        }
        function ToggleMsnKey(key, checked, ev) {
            if (ev && ev.stopPropagation) ev.stopPropagation();   // le clic ne remonte pas -> ne ferme pas le panneau
            var all = dashAllMSN();   // calculé une seule fois
            if (!dashFilter.msnSel) { dashFilter.msnSel = {}; for (var i = 0; i < all.length; i++) dashFilter.msnSel[all[i]] = true; }
            if (checked) dashFilter.msnSel[key] = true; else delete dashFilter.msnSel[key];
            var allOn = true;
            for (var j = 0; j < all.length; j++) { if (!dashFilter.msnSel[all[j]]) { allOn = false; break; } }
            if (allOn) dashFilter.msnSel = null;   // tout coché -> repasse en "Tous"
            updateMsnBtnLabel();   // libellé mis à jour tout de suite
            scheduleDashRerender();   // dashboard re-rendu une fois les cochages terminés (débounce)
        }
        function DocClickCloseMsn(e) {
            var p = document.getElementById('msnPanel');
            if (!p || p.style.display !== 'block') return;
            var t = e.target || e.srcElement, btn = document.getElementById('msnBtn');
            if ((p.contains && p.contains(t)) || (btn && btn.contains && btn.contains(t))) return;   // clic interne -> on garde ouvert
            p.style.display = 'none';
        }
        function SetDashGran(g) {
            dashFilter.gran = g;
            if (g === 'year') {
                var ys = dashYearsList();
                if (ys.indexOf(dashFilter.year) < 0 && ys.length) dashFilter.year = ys[0];
            } else if (g === 'month') {
                var ml = dashMonthList(), found = false;
                for (var i = 0; i < ml.length; i++) { if (ml[i].year === dashFilter.year && ml[i].month === dashFilter.month) { found = true; break; } }
                if (!found && ml.length) { dashFilter.year = ml[0].year; dashFilter.month = ml[0].month; }
            } else if (g === 'week') {
                var wl = dashWeekList(), f2 = false;
                for (var j = 0; j < wl.length; j++) { if (wl[j].year === dashFilter.year && wl[j].week === dashFilter.week) { f2 = true; break; } }
                if (!f2 && wl.length) { dashFilter.year = wl[0].year; dashFilter.week = wl[0].week; }
            }
            InvalidateDash(); RenderActiveDashboardSub();   // le filtre est commun aux 2 sous-onglets
        }
        function SetDashPeriod(val) {
            if (val === '') return;
            if (dashFilter.gran === 'week') { var p2 = val.split('W'); dashFilter.year = parseInt(p2[0], 10); dashFilter.week = parseInt(p2[1], 10); }
            else if (dashFilter.gran === 'year') { dashFilter.year = parseInt(val, 10); }
            else { var p = val.split('-'); dashFilter.year = parseInt(p[0], 10); dashFilter.month = parseInt(p[1], 10); }   // 'month'
            InvalidateDash(); RenderActiveDashboardSub();
        }

        // ==========================================================
        // TABLEAU DE BORD - sous-onglet ORDRE DE FABRICATION (filtre commun avec le sous-onglet NC : dashFilter)
        // ==========================================================
        var dashValid = { NC: false, OF: false, IC: false, PL: false };
        function InvalidateDash() { dashValid.NC = false; dashValid.OF = false; dashValid.IC = false; dashValid.PL = false; }
        function activeDashSub() {
            if (document.getElementById('dashSubOF') && document.getElementById('dashSubOF').style.display === 'block') return 'OF';
            if (document.getElementById('dashSubIC') && document.getElementById('dashSubIC').style.display === 'block') return 'IC';
            if (document.getElementById('dashSubPL') && document.getElementById('dashSubPL').style.display === 'block') return 'PL';
            return 'NC';
        }
        function RenderDashSub(sub) {
            if (sub === 'OF') RenderDashboardOF();
            else if (sub === 'IC') RenderDashboardIC();
            else if (sub === 'PL') RenderDashboardPL();
            else RenderDashboard();
        }
        // Groupes de statuts (planification). "Réalisé" côté coordination = statuts production ; "Finis" côté production = QARJ/CERT/ADMIN.
        var PLANIF_COORD_STATUTS = ['Non commencé', 'Blq accès', 'Blq AR', 'RETP', 'Mqt pièce', 'Retour CT', 'IC refusée'];
        var PLANIF_PROD_STATUTS = ['TFS', 'Dépose OK', 'QARJ', 'ADMIN', 'CERT'];
        var PLANIF_REALISE_COORD = ['TFS', 'Dépose OK', 'QARJ', 'CERT', 'ADMIN'];
        var PLANIF_FINIS_PROD = ['QARJ', 'CERT', 'ADMIN'];
        function planifStatutNorm(s) { return NettoyerChaine(s).toUpperCase(); }
        function planifInGroup(sU, group) { for (var i = 0; i < group.length; i++) { if (planifStatutNorm(group[i]) === sU) return true; } return false; }
        function planifFilteredRows() {
            var all = appData.planif || [], out = [], msnMode = (dashFilter.gran === 'msn');
            for (var i = 0; i < all.length; i++) {
                var d = parseOFDateObj(all[i].date);
                if (!inSelectedPeriod(d)) continue;   // filtre période (Année/Mois/Semaine ; MSN & all -> toutes)
                if (msnMode && !msnSelected(msnBucketKey(all[i].msn))) continue;   // filtre MSN
                out.push(all[i]);
            }
            return out;
        }
        function RenderDashboardPL() {
            var fbar = document.getElementById('dashFilterBar'); if (fbar) fbar.innerHTML = dashRespFilterBar();
            var emp = document.getElementById('dashPLEmpty'), charts = document.getElementById('dashPLCharts');
            if (!(appData.planif && appData.planif.length)) {
                if (emp) { emp.style.display = 'block'; var av = ComputeAvailHeight('dashPLEmpty'); if (av != null) emp.style.height = av + 'px'; }
                if (charts) charts.style.display = 'none';
                dashValid.PL = true;
                return;
            }
            if (emp) emp.style.display = 'none';
            if (charts) charts.style.display = 'block';
            var ct = document.getElementById('content'); if (ct) ct.style.overflowY = 'hidden';
            SetDashCardHeight('dashRowStylePL', 'dashCardPL', 2, charts.getBoundingClientRect().top);
            var data = planifFilteredRows();
            var coordCounts = {}, prodCounts = {}, total = data.length, realiseCoord = 0, finisProd = 0;
            for (var i = 0; i < data.length; i++) {
                var sU = planifStatutNorm(data[i].statut);
                if (!sU) continue;   // (sans statut) : compté dans le total mais dans aucun camembert
                for (var c = 0; c < PLANIF_COORD_STATUTS.length; c++) { if (planifStatutNorm(PLANIF_COORD_STATUTS[c]) === sU) { coordCounts[PLANIF_COORD_STATUTS[c]] = (coordCounts[PLANIF_COORD_STATUTS[c]] || 0) + 1; break; } }
                for (var p = 0; p < PLANIF_PROD_STATUTS.length; p++) { if (planifStatutNorm(PLANIF_PROD_STATUTS[p]) === sU) { prodCounts[PLANIF_PROD_STATUTS[p]] = (prodCounts[PLANIF_PROD_STATUTS[p]] || 0) + 1; break; } }
                if (planifInGroup(sU, PLANIF_REALISE_COORD)) realiseCoord++;
                if (planifInGroup(sU, PLANIF_FINIS_PROD)) finisProd++;
            }
            planifPie('hcPLCoordPie', PLANIF_COORD_STATUTS, coordCounts);
            planifPie('hcPLProdPie', PLANIF_PROD_STATUTS, prodCounts);
            planifBar('hcPLCoordBar', total, realiseCoord, 'Réalisé');
            planifBar('hcPLProdBar', total, finisProd, 'Finis');
            ReflowDashCharts(['hcPLCoordPie', 'hcPLCoordBar', 'hcPLProdPie', 'hcPLProdBar']);
            dashValid.PL = true;
        }
        function planifPie(id, order, counts) {
            var cont = document.getElementById(id); if (!cont) return;
            var data = [], hasData = false;
            for (var i = 0; i < order.length; i++) { var v = counts[order[i]] || 0; if (v > 0) { data.push({ name: order[i], y: v }); hasData = true; } }
            if (!hasData || typeof Highcharts === 'undefined') { hcDestroy(id); cont.innerHTML = emptyChartHtml(); return; }
            try {
                hcDraw(id, {
                    chart: hcChart('pie', [4, 2, 4, 2]),
                    title: { text: null }, credits: { enabled: false }, colors: PIE_COLORS,
                    tooltip: { formatter: function () { return '<b>' + this.point.name + '</b><br/>' + this.point.y + ' OF · ' + Highcharts.numberFormat(this.percentage, 0) + '%'; } },
                    legend: { enabled: true, align: 'center', verticalAlign: 'bottom', layout: 'horizontal', itemStyle: { fontSize: '11px', color: '#334155', fontWeight: 'normal' } },
                    plotOptions: { pie: { animation: false, showInLegend: true, size: '80%', dataLabels: { enabled: true, format: '{percentage:.0f}%', distance: -20, style: { color: '#ffffff', fontSize: '11px', fontWeight: 'bold', textOutline: 'none' } } } },
                    series: [{ name: 'Statut', data: data }]
                });
            } catch (e) { hcErr(cont); }
        }
        function planifBar(id, total, done, doneLabel) {
            var cont = document.getElementById(id); if (!cont) return;
            if (typeof Highcharts === 'undefined') { cont.innerHTML = "<div class='msg-box msg-info'>Graphique indisponible.</div>"; return; }
            var pct = total ? Math.round(done / total * 100) : 0;
            try {
                hcDraw(id, {
                    chart: hcChart('column', [10, 6, 2, 6]),
                    title: { text: null }, subtitle: { text: 'Réalisation : <b>' + pct + '%</b>', useHTML: true, style: { color: '#0C447C', fontSize: '13px' } },
                    credits: { enabled: false }, legend: { enabled: false },
                    xAxis: { categories: ['Planifié', doneLabel], labels: { style: { color: '#334155', fontWeight: '600', fontSize: '13px' } } },
                    yAxis: { title: { text: null }, min: 0, allowDecimals: false },
                    tooltip: { formatter: function () { return '<b>' + this.x + '</b> : ' + this.y + ' OF' + (this.point.index === 0 ? '' : '<br/>' + pct + '% du planifié'); } },
                    plotOptions: { column: { animation: false, borderRadius: 3, pointPadding: 0.08, groupPadding: 0.12, dataLabels: { enabled: true, style: { fontSize: '14px', fontWeight: 'bold', color: '#334155', textOutline: 'none' } } } },
                    series: [{ name: 'OF', data: [{ y: total, color: '#0C447C' }, { y: done, color: '#16a34a' }] }]
                });
            } catch (e) { hcErr(cont); }
        }
        function ShowDashSub(s) {
            var subs = { NC: 'dashSubNC', OF: 'dashSubOF', IC: 'dashSubIC', PL: 'dashSubPL' };
            var tabs = { NC: 'dashSubtabNC', OF: 'dashSubtabOF', IC: 'dashSubtabIC', PL: 'dashSubtabPL' };
            for (var kk in subs) {
                if (!subs.hasOwnProperty(kk)) continue;
                var pane = document.getElementById(subs[kk]); if (pane) pane.style.display = (kk === s) ? "block" : "none";
                var tab = document.getElementById(tabs[kk]); if (tab) tab.className = (kk === s) ? "subtab active" : "subtab";
            }
            var eb = document.getElementById('dashExportNC');   // bouton export NC : onglet NC actif et graphiques présents
            if (eb) { var dcv = document.getElementById('dashCharts'); eb.style.display = (s === 'NC' && dcv && dcv.style.display !== 'none') ? '' : 'none'; }
            var ebO = document.getElementById('dashExportOF');   // bouton export OF : onglet OF actif et graphiques présents
            if (ebO) { var dcvO = document.getElementById('dashOFCharts'); ebO.style.display = (s === 'OF' && dcvO && dcvO.style.display !== 'none') ? '' : 'none'; }
            var fb = document.getElementById('dashFilterBar'); if (fb) fb.style.display = '';   // barre de filtre visible sur tous les sous-onglets (Planification incluse)
            if (!dashValid[s]) RenderDashSub(s);
        }
        function RenderActiveDashboardSub() { RenderDashSub(activeDashSub()); }
        function RenderDashIfNeeded() { var s = activeDashSub(); if (!dashValid[s]) RenderDashSub(s); }
        function parseOFDateObj(s) {
            var p = NettoyerChaine(s).split(/[.\/\-]/); if (p.length < 3) return null;
            var d = parseInt(p[0], 10), m = parseInt(p[1], 10), y = parseInt(p[2], 10);
            if (isNaN(d) || isNaN(m) || isNaN(y)) return null;
            if (y < 100) y += 2000;
            return new Date(y, m - 1, d);
        }
        function RenderDashboardOF() {
            var fbar = document.getElementById('dashFilterBar'); if (fbar) fbar.innerHTML = dashRespFilterBar();
            var ebO = document.getElementById('dashExportOF');
            var rows = getOFTeamRows('cree').concat(getOFTeamRows('clot'));
            if (!rows.length) {
                var empOF = document.getElementById('dashOFEmpty');
                empOF.style.display = "block";
                document.getElementById('dashOFCharts').style.display = "none";
                if (ebO) ebO.style.display = 'none';
                var avOF = ComputeAvailHeight('dashOFEmpty'); if (avOF != null) empOF.style.height = avOF + "px";
                dashValid.OF = true;
                return;
            }
            document.getElementById('dashOFEmpty').style.display = "none";
            if (ebO) ebO.style.display = '';   // données présentes -> bouton d'export visible
            var dc = document.getElementById('dashOFCharts'); dc.style.display = "block";
            var ct = document.getElementById('content'); if (ct) ct.style.overflowY = 'hidden';
            SetDashCardHeight('dashRowStyleOF', 'dashCardOF', 2, dc.getBoundingClientRect().top);
            hcOFLineCharts('cree', '#0C447C');
            hcOFLineCharts('clot', '#16a34a');
            ReflowDashCharts(['hcOFCreeUser', 'hcOFCreeTotal', 'hcOFClotUser', 'hcOFClotTotal']);
            dashValid.OF = true;   // rendu à jour : pas de re-rendu au retour sur l'onglet tant que rien ne change
        }
        function EgaliserCards(cards) {
            var max = 0, i;
            for (i = 0; i < cards.length; i++) cards[i].style.height = "";
            for (i = 0; i < cards.length; i++) { if (cards[i].offsetHeight > max) max = cards[i].offsetHeight; }
            if (max > 0) { for (i = 0; i < cards.length; i++) cards[i].style.height = max + "px"; }
        }
        function ofBuckets(rows) {
            if (dashFilter.gran === 'msn') return ofMSNBuckets(rows);
            var mode = granBucketMode();
            var bucketSet = {}, perUser = {}, total = {};
            for (var i = 0; i < rows.length; i++) {
                var d = parseOFDateObj(rows[i].date);
                if (!d || !inSelectedPeriod(d)) continue;
                var ts = bucketTsForMode(d, mode);
                bucketSet[ts] = true;
                var u = NettoyerChaine(rows[i].user).toUpperCase();
                if (!perUser[u]) perUser[u] = {};
                perUser[u][ts] = (perUser[u][ts] || 0) + 1;
                total[ts] = (total[ts] || 0) + 1;
            }
            var buckets = bucketKeysForMode(mode, bucketSet);
            var cats = []; for (var k = 0; k < buckets.length; k++) cats.push(bucketLabelForMode(buckets[k], mode));
            return { buckets: buckets, cats: cats, perUser: perUser, total: total };
        }
        function ofMSNBuckets(rows) {
            var keySet = {}, perUser = {}, total = {};
            for (var i = 0; i < rows.length; i++) {
                var d = parseOFDateObj(rows[i].date);
                if (!d || !inSelectedPeriod(d)) continue;
                var key = msnBucketKey(rows[i].msn);
                if (!msnSelected(key)) continue;
                keySet[key] = true;
                var u = NettoyerChaine(rows[i].user).toUpperCase();
                if (!perUser[u]) perUser[u] = {};
                perUser[u][key] = (perUser[u][key] || 0) + 1;
                total[key] = (total[key] || 0) + 1;
            }
            var buckets = []; for (var w in keySet) { if (keySet.hasOwnProperty(w)) buckets.push(w); }
            msnSortKeys(buckets);
            return { buckets: buckets, cats: buckets.slice(0), perUser: perUser, total: total };
        }
        function hcOFLineCharts(type, color) {
            var teamArr = (type === 'cree') ? (appData.teamST || []) : (appData.teamIQ || []);
            var nomMap = {}; for (var t = 0; t < teamArr.length; t++) { var tu = NettoyerChaine(teamArr[t].user).toUpperCase(); if (tu) nomMap[tu] = nomSeul(teamArr[t].nom || teamArr[t].user); }
            var b = ofBuckets(getOFTeamRows(type));
            var ofHasData = false; for (var kk in b.total) { if (b.total.hasOwnProperty(kk)) { ofHasData = true; break; } }
            var userId = (type === 'cree') ? 'hcOFCreeUser' : 'hcOFClotUser';
            var totId = (type === 'cree') ? 'hcOFCreeTotal' : 'hcOFClotTotal';
            var contU = document.getElementById(userId);
            if (contU) {
                if (!Object.keys(nomMap).length) {
                    hcDestroy(userId);
                    contU.innerHTML = "<div style='height:100%; min-height:120px; border:2px dashed #cbd5e1; border-radius:8px; background:#f1f5f9; color:#64748b; font-style:italic; text-align:center; display:table; width:100%; box-sizing:border-box;'><span style='display:table-cell; vertical-align:middle;'>Aucun membre dans cette équipe</span></div>";
                } else if (typeof Highcharts === 'undefined') {
                    contU.innerHTML = "<div class='msg-box msg-info'>Graphique indisponible.</div>";
                } else if (!ofHasData) {
                    hcDestroy(userId); contU.innerHTML = emptyChartHtml();
                } else {
                    var series = [];
                    for (var u in nomMap) {
                        if (!nomMap.hasOwnProperty(u)) continue;
                        var data = [];
                        for (var k = 0; k < b.buckets.length; k++) { var c = b.perUser[u] && b.perUser[u][b.buckets[k]]; data.push(c || null); }
                        series.push({ name: nomMap[u], data: data });
                    }
                    try {
                        hcDraw(userId, {
                            chart: hcChart('line', [6, 2, 6, 2]),
                            title: { text: null }, credits: { enabled: false },
                            xAxis: { categories: b.cats, labels: { style: { color: '#334155', fontWeight: '600' } } },
                            yAxis: { title: { text: null }, min: 0, allowDecimals: false },
                            tooltip: { formatter: function () { return '<b>' + this.series.name + '</b><br/>' + this.x + ' : ' + this.y + ' OF'; } },
                            plotOptions: { line: { animation: false, lineWidth: 2, marker: { radius: 3 } }, series: { connectNulls: true } },
                            series: series
                        });
                    } catch (e) { hcErr(contU); }
                }
            }
            var contT = document.getElementById(totId);
            if (contT) {
                if (typeof Highcharts === 'undefined') {
                    contT.innerHTML = "<div class='msg-box msg-info'>Graphique indisponible.</div>";
                } else if (!ofHasData) {
                    hcDestroy(totId); contT.innerHTML = emptyChartHtml();
                } else {
                    var dataT = []; for (var k2 = 0; k2 < b.buckets.length; k2++) dataT.push(b.total[b.buckets[k2]] || 0);
                    try {
                        hcDraw(totId, {
                            chart: hcChart('line', [6, 2, 6, 2]),
                            title: { text: null }, credits: { enabled: false }, legend: { enabled: false },
                            xAxis: { categories: b.cats, labels: { style: { color: '#334155', fontWeight: '600' } } },
                            yAxis: { title: { text: null }, min: 0, allowDecimals: false },
                            tooltip: { formatter: function () { return '<b>' + this.x + '</b><br/>' + this.y + ' OF'; } },
                            plotOptions: { line: { animation: false, lineWidth: 2.5, marker: { radius: 4 }, color: color } },
                            series: [{ name: 'Total', data: dataT, color: color }]
                        });
                    } catch (e) { hcErr(contT); }
                }
            }
        }

        // ================= TABLEAU DE BORD - sous-onglet INTERVENTIONS CARDS =================
        function RenderDashboardIC() {
            var fbar = document.getElementById('dashFilterBar'); if (fbar) fbar.innerHTML = dashRespFilterBar();
            if (!(appData.icRows && appData.icRows.length)) {
                var emp = document.getElementById('dashICEmpty');
                emp.style.display = "block";
                document.getElementById('dashICCharts').style.display = "none";
                var av = ComputeAvailHeight('dashICEmpty'); if (av != null) emp.style.height = av + "px";   // remplit l'espace visible
                dashValid.IC = true; return;
            }
            document.getElementById('dashICEmpty').style.display = "none";
            var dc = document.getElementById('dashICCharts'); dc.style.display = "block";
            var ct = document.getElementById('content'); if (ct) ct.style.overflowY = 'hidden';
            SetDashCardHeight('dashRowStyleIC', 'dashCardIC', 2, dc.getBoundingClientRect().top);
            hcICTotalChart('hcICTotal');
            hcICUserChart('hcICST', getICTeamRows('ST'), teamNomMap('ST'));
            hcICUserChart('hcICTL', getICTeamRows('TL'), teamNomMap('TL'));
            hcICUserChart('hcICIQ', getICTeamRows('IQ'), teamNomMap('IQ'));
            ReflowDashCharts(['hcICTotal', 'hcICST', 'hcICTL', 'hcICIQ']);
            dashValid.IC = true;
        }
        function teamNomMap(team) {
            var arr = (team === 'ST') ? (appData.teamST || []) : (team === 'TL') ? (appData.teamTL || []) : (appData.teamIQ || []);
            var m = {};
            for (var t = 0; t < arr.length; t++) { var tu = NettoyerChaine(arr[t].user).toUpperCase(); if (tu) m[tu] = nomSeul(arr[t].nom || arr[t].user); }
            return m;
        }
        function getICTeamRows(team) {
            var m = teamNomMap(team), out = [], all = appData.icRows || [];
            for (var i = 0; i < all.length; i++) { if (m[NettoyerChaine(all[i].user).toUpperCase()]) out.push(all[i]); }
            return out;
        }
        function icEcartBuckets(rows) {
            if (dashFilter.gran === 'msn') return icEcartMSNBuckets(rows);
            var mode = granBucketMode();
            var bucketSet = {}, perUserSum = {}, perUserCnt = {};
            for (var i = 0; i < rows.length; i++) {
                var d = parseDT(rows[i].dfa, rows[i].hfa), ec = icEcartMs(rows[i]);   // regroupement/filtre par date de FIN AUTORISÉE
                if (!d || ec == null || !inSelectedPeriod(d)) continue;
                var ts = bucketTsForMode(d, mode);
                bucketSet[ts] = true;
                var u = NettoyerChaine(rows[i].user).toUpperCase();
                if (!perUserSum[u]) { perUserSum[u] = {}; perUserCnt[u] = {}; }
                perUserSum[u][ts] = (perUserSum[u][ts] || 0) + ec;
                perUserCnt[u][ts] = (perUserCnt[u][ts] || 0) + 1;
            }
            var buckets = bucketKeysForMode(mode, bucketSet);
            var cats = []; for (var k = 0; k < buckets.length; k++) cats.push(bucketLabelForMode(buckets[k], mode));
            return { buckets: buckets, cats: cats, perUserSum: perUserSum, perUserCnt: perUserCnt };
        }
        function icEcartMSNBuckets(rows) {
            var keySet = {}, perUserSum = {}, perUserCnt = {};
            for (var i = 0; i < rows.length; i++) {
                var d = parseDT(rows[i].dfa, rows[i].hfa), ec = icEcartMs(rows[i]);   // regroupement/filtre par date de FIN AUTORISÉE
                if (!d || ec == null || !inSelectedPeriod(d)) continue;
                var key = msnBucketKey(rows[i].msn);
                if (!msnSelected(key)) continue;
                keySet[key] = true;
                var u = NettoyerChaine(rows[i].user).toUpperCase();
                if (!perUserSum[u]) { perUserSum[u] = {}; perUserCnt[u] = {}; }
                perUserSum[u][key] = (perUserSum[u][key] || 0) + ec;
                perUserCnt[u][key] = (perUserCnt[u][key] || 0) + 1;
            }
            var buckets = []; for (var w in keySet) { if (keySet.hasOwnProperty(w)) buckets.push(w); }
            msnSortKeys(buckets);
            return { buckets: buckets, cats: buckets.slice(0), perUserSum: perUserSum, perUserCnt: perUserCnt };
        }
        function icYAxisBounds(points) {
            var mx = 0, mn = 0;
            for (var i = 0; i < points.length; i++) { var p = points[i]; if (p && p.y != null) { if (p.y > mx) mx = p.y; if (p.y < mn) mn = p.y; } }
            return { min: Math.min(0, Math.floor(mn)), max: Math.max(2, Math.ceil(mx)) };
        }
        function hcICUserChart(id, teamRows, nomMap) {
            var cont = document.getElementById(id); if (!cont) return;
            if (!Object.keys(nomMap).length) { hcDestroy(id); cont.innerHTML = "<div style='height:100%; min-height:120px; border:2px dashed #cbd5e1; border-radius:8px; background:#f1f5f9; color:#64748b; font-style:italic; text-align:center; display:table; width:100%; box-sizing:border-box;'><span style='display:table-cell; vertical-align:middle;'>Aucun membre dans cette équipe</span></div>"; return; }
            if (typeof Highcharts === 'undefined') { cont.innerHTML = "<div class='msg-box msg-info'>Graphique indisponible.</div>"; return; }
            var b = icEcartBuckets(teamRows), series = [], hMs = 3600000, icHasData = false;
            for (var kt in b.perUserCnt) { if (b.perUserCnt.hasOwnProperty(kt)) { icHasData = true; break; } }
            if (!icHasData) { hcDestroy(id); cont.innerHTML = emptyChartHtml(); return; }
            var allPts = [];
            for (var u in nomMap) {
                if (!nomMap.hasOwnProperty(u)) continue;
                var data = [];
                for (var k = 0; k < b.buckets.length; k++) {
                    var bk = b.buckets[k], c = b.perUserCnt[u] && b.perUserCnt[u][bk];
                    if (c) { var avg = b.perUserSum[u][bk] / c; data.push({ y: Math.round(avg / hMs * 100) / 100, ms: avg, n: c }); }
                    else data.push(null);
                }
                series.push({ name: nomMap[u], data: data });
                allPts = allPts.concat(data);
            }
            var icB = icYAxisBounds(allPts);
            try {
                hcDraw(id, {
                    chart: hcChart('line', [6, 2, 6, 2]),
                    title: { text: null }, credits: { enabled: false },
                    xAxis: { categories: b.cats, labels: { style: { color: '#334155', fontWeight: '600' } } },
                    yAxis: { title: { text: null }, allowDecimals: false, min: icB.min, max: icB.max, labels: { formatter: function () { return icAxisLabel(this.value); }, style: { color: '#334155' } }, plotLines: [{ value: 0, color: '#16a34a', dashStyle: 'Dash', width: 1.5, zIndex: 5 }] },
                    tooltip: { useHTML: true, formatter: function () { return '<b>' + this.series.name + '</b><br/>' + this.x + ' : ' + fmtEcartSigned(this.point.ms) + ' &middot; ' + this.point.n + ' IC'; } },
                    plotOptions: { line: { animation: false, lineWidth: 2, marker: { radius: 3 } }, series: { connectNulls: true } },
                    series: series
                });
            } catch (e) { hcErr(cont); }
        }
        function icTotalBuckets() {
            if (dashFilter.gran === 'msn') return icTotalMSNBuckets();
            var mode = granBucketMode();
            var all = appData.icRows || [], bucketSet = {}, sumB = {}, cntB = {}, team = teamUserSet();
            for (var i = 0; i < all.length; i++) {
                var r = all[i], d = parseDT(r.dfa, r.hfa), ec = icEcartMs(r);   // regroupement/filtre par date de FIN AUTORISÉE
                if (!d || ec == null || !inSelectedPeriod(d)) continue;
                if (!team[NettoyerChaine(r.user).toUpperCase()]) continue;   // restreint aux équipes ST/TL/IQ
                var ts = bucketTsForMode(d, mode);
                bucketSet[ts] = true;
                sumB[ts] = (sumB[ts] || 0) + ec; cntB[ts] = (cntB[ts] || 0) + 1;
            }
            var buckets = bucketKeysForMode(mode, bucketSet);
            var cats = []; for (var k = 0; k < buckets.length; k++) cats.push(bucketLabelForMode(buckets[k], mode));
            return { buckets: buckets, cats: cats, sum: sumB, cnt: cntB };
        }
        function icTotalMSNBuckets() {
            var all = appData.icRows || [], keySet = {}, sumB = {}, cntB = {}, team = teamUserSet();
            for (var i = 0; i < all.length; i++) {
                var r = all[i], d = parseDT(r.dfa, r.hfa), ec = icEcartMs(r);   // regroupement/filtre par date de FIN AUTORISÉE
                if (!d || ec == null || !inSelectedPeriod(d)) continue;
                if (!team[NettoyerChaine(r.user).toUpperCase()]) continue;   // restreint aux équipes ST/TL/IQ
                var key = msnBucketKey(r.msn);
                if (!msnSelected(key)) continue;
                keySet[key] = true;
                sumB[key] = (sumB[key] || 0) + ec; cntB[key] = (cntB[key] || 0) + 1;
            }
            var buckets = []; for (var w in keySet) { if (keySet.hasOwnProperty(w)) buckets.push(w); }
            msnSortKeys(buckets);
            return { buckets: buckets, cats: buckets.slice(0), sum: sumB, cnt: cntB };
        }
        function hcICTotalChart(id) {
            var cont = document.getElementById(id); if (!cont) return;
            if (typeof Highcharts === 'undefined') { cont.innerHTML = "<div class='msg-box msg-info'>Graphique indisponible.</div>"; return; }
            var b = icTotalBuckets(), data = [], hMs = 3600000, icTotHasData = false;
            for (var k = 0; k < b.buckets.length; k++) {
                var bk = b.buckets[k], c = b.cnt[bk];
                if (c) { icTotHasData = true; var avg = b.sum[bk] / c; data.push({ y: Math.round(avg / hMs * 100) / 100, ms: avg, n: c }); }
                else data.push(null);
            }
            if (!icTotHasData) { hcDestroy(id); cont.innerHTML = emptyChartHtml(); return; }
            var icB = icYAxisBounds(data);
            try {
                hcDraw(id, {
                    chart: hcChart('line', [6, 2, 0, 2]),
                    title: { text: null }, credits: { enabled: false },
                    legend: { enabled: false },
                    xAxis: { categories: b.cats, labels: { style: { color: '#334155', fontWeight: '600' } } },
                    yAxis: { title: { text: null }, allowDecimals: false, min: icB.min, max: icB.max, labels: { formatter: function () { return icAxisLabel(this.value); }, style: { color: '#334155' } }, plotLines: [{ value: 0, color: '#16a34a', dashStyle: 'Dash', width: 1.5, zIndex: 5 }] },
                    tooltip: { useHTML: true, formatter: function () { return '<b>' + this.x + '</b><br/>Temps de clôture moyen : ' + fmtEcartSigned(this.point.ms) + '<br/>' + this.point.n + ' IC'; } },
                    plotOptions: { line: { animation: false, lineWidth: 2.5, marker: { radius: 4 }, color: '#dc2626', negativeColor: '#16a34a' }, series: { connectNulls: true } },
                    series: [ { name: 'Temps de clôture moyen', data: data, color: '#dc2626', negativeColor: '#16a34a' } ]
                });
            } catch (e) { hcErr(cont); }
        }
        function RenderDashResp(elig) {
            var intNom = {}, extNom = {}, rd = appData.roleDesig || [];
            for (var i = 0; i < rd.length; i++) {
                var rc = NettoyerChaine(rd[i].resp).toUpperCase(), ty = NettoyerChaine(rd[i].type); if (!rc) continue;
                if (ty === "ext") extNom[rc] = rd[i].nom || rd[i].resp; else if (ty === "int") intNom[rc] = rd[i].nom || rd[i].resp;
            }
            var agg = {};
            for (var e = 0; e < elig.length; e++) {
                var gaps = ncGaps(elig[e]);
                for (var j = 0; j < gaps.length; j++) {
                    if (gaps[j].gap == null) continue;
                    var r = (gaps[j].r || "").toUpperCase();
                    if (!intNom[r] && !extNom[r]) continue;
                    if (!agg[r]) agg[r] = { sum: 0, n: 0 };
                    agg[r].sum += gaps[j].gap; agg[r].n++;
                }
            }
            hcRespPie('hcRespInt', intNom, agg);
            hcRespPie('hcRespExt', extNom, agg);
            var eq = { le: 0, gt: 0 }, gl = { le: 0, gt: 0 }, TWO_D = 2 * dayMs();
            for (var s = 0; s < elig.length; s++) {
                var nc = elig[s];
                if (nc.chezMs != null) { if (nc.chezMs <= TWO_D) eq.le++; else eq.gt++; }
                if (nc.durMs != null) { if (nc.durMs <= TWO_D) gl.le++; else gl.gt++; }
            }
            hcSeuilPie('hcSeuilEquipe', eq);
            hcSeuilPie('hcSeuilGlobal', gl);
        }
        function hcPie(id, data, tooltipFmt, seriesName, colors) {
            var cont = document.getElementById(id); if (!cont) return;
            if (!data.length) { hcDestroy(id); cont.innerHTML = emptyChartHtml(); return; }
            try {
                var cfg = {
                    chart: hcChart('pie', [4, 2, 4, 2]),
                    title: { text: null }, credits: { enabled: false },
                    tooltip: { useHTML: true, formatter: tooltipFmt },
                    legend: { enabled: false },
                    plotOptions: { pie: { animation: false, showInLegend: false, size: '92%', dataLabels: { enabled: true, format: '{percentage:.0f}%', distance: -26, style: { color: '#ffffff', fontSize: '12px', fontWeight: 'bold', textOutline: 'none' } } } },
                    series: [{ name: seriesName, data: data }]
                };
                if (colors) cfg.colors = colors;
                window.hcRespChartRefs = window.hcRespChartRefs || {};
                window.hcRespChartRefs[id] = hcDraw(id, cfg);
            } catch (e) { hcErr(cont); }
        }
        function hcSeuilPie(id, s) {
            var data = [];
            if (s.le) data.push({ name: '≤ 2 jours', y: s.le, color: '#16a34a' });
            if (s.gt) data.push({ name: '> 2 jours', y: s.gt, color: '#dc2626' });
            hcPie(id, data, function () { return '<b>' + this.point.name + '</b><br/>' + this.point.y + ' NC<br/>' + Highcharts.numberFormat(this.percentage, 0) + '%'; }, 'NC', null);
        }
        function hcRespPie(id, nomMap, agg) {
            var data = [];
            for (var r in nomMap) { if (nomMap.hasOwnProperty(r) && agg[r]) data.push({ name: nomMap[r], y: agg[r].sum / agg[r].n / dayMs(), ms: agg[r].sum / agg[r].n, ntasks: agg[r].n }); }
            data.sort(function (a, b) { return b.y - a.y; });
            hcPie(id, data, function () { return '<b>' + this.point.name + '</b><br/>Moy. ' + fmtDHM(this.point.ms) + '<br/>' + Highcharts.numberFormat(this.percentage, 0) + '% &middot; ' + this.point.ntasks + ' tâches'; }, 'Durée moyenne', PIE_COLORS);
        }
        var PIE_COLORS = ['#0C447C', '#0284c7', '#16a34a', '#f59e0b', '#dc2626', '#7c3aed', '#0891b2', '#65a30d', '#db2777', '#475569'];
        function RenderDashTeams(elig) {
            var umap = {};
            var teamDefs = [["ST", appData.teamST], ["TL", appData.teamTL], ["IQ", appData.teamIQ]];
            for (var t = 0; t < teamDefs.length; t++) {
                var arr = teamDefs[t][1] || [];
                for (var i = 0; i < arr.length; i++) { var u = NettoyerChaine(arr[i].user).toUpperCase(); if (u) umap[u] = { team: teamDefs[t][0], nom: nomSeul(arr[i].nom || u) }; }
            }
            var byMSN = dashFilter.gran === 'msn';
            var mode = granBucketMode();
            var weekSet = {}, agg = {};   // agg[user][bucket] = { sum, n } ; bucket = ts (temps) ou MSN
            for (var e = 0; e < elig.length; e++) {
                var nc = elig[e]; if (!nc.end) continue;
                var wts;
                if (byMSN) { wts = msnBucketKey(nc.msn); if (!msnSelected(wts)) continue; }
                else wts = bucketTsForMode(nc.end, mode);
                weekSet[wts] = true;
                var gaps = ncGaps(nc);
                for (var j = 0; j < gaps.length; j++) {
                    if (gaps[j].gap == null) continue;
                    var uu = (gaps[j].tp || "").toUpperCase();
                    if (!umap[uu]) continue;
                    if (!agg[uu]) agg[uu] = {};
                    if (!agg[uu][wts]) agg[uu][wts] = { sum: 0, n: 0 };
                    agg[uu][wts].sum += gaps[j].gap; agg[uu][wts].n++;
                }
            }
            var weeks, cats = [];
            if (byMSN) { weeks = []; for (var wM in weekSet) { if (weekSet.hasOwnProperty(wM)) weeks.push(wM); } msnSortKeys(weeks); cats = weeks.slice(0); }
            else {
                weeks = bucketKeysForMode(mode, weekSet);
                for (var z = 0; z < weeks.length; z++) cats.push(bucketLabelForMode(weeks[z], mode));
            }
            var order = ["ST", "TL", "IQ"];
            for (var o = 0; o < order.length; o++) {
                var team = order[o], us = [];
                for (var u2 in umap) { if (umap.hasOwnProperty(u2) && umap[u2].team === team) us.push(u2); }
                hcTeamChart('hcTeam' + team, us, umap, weeks, cats, agg);
            }
        }
        function hcTeamChart(id, users, umap, weeks, cats, agg) {
            var cont = document.getElementById(id); if (!cont) return;
            if (!users.length) { hcDestroy(id); cont.innerHTML = "<div style='height:100%; min-height:120px; border:2px dashed #cbd5e1; border-radius:8px; background:#f1f5f9; color:#64748b; font-style:italic; text-align:center; display:table; width:100%; box-sizing:border-box;'><span style='display:table-cell; vertical-align:middle;'>Aucun membre dans cette équipe</span></div>"; return; }
            if (typeof Highcharts === 'undefined') { cont.innerHTML = "<div class='msg-box msg-info'>Graphique indisponible.</div>"; return; }
            var dMs = dayMs(), series = [], hasData = false;
            for (var i = 0; i < users.length; i++) {
                var u = users[i], data = [];
                for (var k = 0; k < weeks.length; k++) {
                    var a = agg[u] && agg[u][weeks[k]];
                    if (a && a.n) { data.push({ y: a.sum / a.n / dMs, ms: a.sum / a.n }); hasData = true; } else data.push(null);
                }
                series.push({ name: umap[u].nom || u, data: data });
            }
            if (!hasData) { hcDestroy(id); cont.innerHTML = emptyChartHtml(); return; }
            try {
                window.hcTeamChartRefs = window.hcTeamChartRefs || {};
                window.hcTeamChartRefs[id] = hcDraw(id, {
                    chart: hcChart('line', [6, 2, 0, 2]),
                    title: { text: null }, credits: { enabled: false },
                    xAxis: { categories: cats, labels: { style: { color: '#334155', fontWeight: '600' } } },
                    yAxis: { title: { text: null }, min: 0 },
                    legend: { margin: 4, padding: 4, itemMarginTop: 0, itemMarginBottom: 0 },
                    tooltip: { useHTML: true, formatter: function () { return '<b>' + this.series.name + '</b><br/>' + this.key + ' : ' + fmtDHM(this.point.ms); } },
                    plotOptions: { line: { animation: false, lineWidth: 2, marker: { radius: 3 } }, series: { connectNulls: true } },
                    series: series
                });
            } catch (e) { hcErr(cont); }
        }

    // ==========================================================
    // PAGE : ANALYSE NC (liste détaillée + filtres)
    // ==========================================================
        function firstOfMonthStr() { var n = new Date(); return "01/" + (n.getMonth() + 1 < 10 ? "0" : "") + (n.getMonth() + 1) + "/" + n.getFullYear(); }
        function setDateIfEmpty(id, val) { var el = document.getElementById(id); if (el && !NettoyerChaine(el.value)) el.value = val; }
        function PrefillExtractDates() {
            var today = FormatDateString(new Date());
            var lastNC = appData.lastImport ? NettoyerChaine(appData.lastImport).split(' ')[0] : firstOfMonthStr();
            var lastOF = appData.lastOFImport ? NettoyerChaine(appData.lastOFImport).split(' ')[0] : firstOfMonthStr();
            var lastIC = appData.lastICImport ? NettoyerChaine(appData.lastICImport).split(' ')[0] : firstOfMonthStr();
            setDateIfEmpty('extractDate', lastNC);
            setDateIfEmpty('extractDateFin', today);
            setDateIfEmpty('ofDateDebut', lastOF);
            setDateIfEmpty('ofDateFin', today);
            setDateIfEmpty('icDateDebut', lastIC);
            setDateIfEmpty('icDateFin', today);
            RefreshDateClearButtons();
        }
        function RenderListe() {
            extractValid.NC = true;   // rendu à jour (cache)
            var lbl = document.getElementById('lastExtractDate');
            if (lbl) lbl.innerText = appData.lastImport ? appData.lastImport : "Jamais";
            PrefillExtractDates();
            var cont = document.getElementById('listeContainer');
            if (!ncList.length) { showEmptyExtract('listeContainer', "Aucune extraction réalisée", "Lance une extraction QM13 ci-dessus pour afficher les non-conformités."); return; }

            var d1 = parseFilterDate(document.getElementById('filtreDateDebut').value);
            var d2 = parseFilterDate(document.getElementById('filtreDateFin').value);
            if (d2) d2 = new Date(d2.getFullYear(), d2.getMonth(), d2.getDate(), 23, 59, 59);
            var q = NettoyerChaine(document.getElementById('filtreRecherche').value).toLowerCase();

            var filtered = [];
            for (var i = 0; i < ncList.length; i++) {
                var ncf = ncList[i];
                if (!ncf.eligible) continue;                          // NC non éligibles : totalement ignorées
                if (d1 && ncf.end && ncf.end < d1) continue;   // filtre sur la date de clôture
                if (d2 && ncf.end && ncf.end > d2) continue;
                if (q) {
                    var hay = (ncf.avis + " " + ncf.desc + " " + ncf.statut + " " + (ncf.msn || "")).toLowerCase();
                    if (hay.indexOf(q) === -1) continue;
                }
                filtered.push(ncf);
            }
            if (!filtered.length) { showEmptyExtract('listeContainer', "Aucune NC ne correspond aux filtres.", "Modifie ou réinitialise les filtres."); return; }
            if (listeSort.col) {
                var sc = listeSort.col, sd = listeSort.dir;
                filtered.sort(function (a, b) { var va = listeSortVal(a, sc), vb = listeSortVal(b, sc); return (va < vb ? -1 : (va > vb ? 1 : 0)) * sd; });
            }
            var cap = extractCap('nbLignesNC'), totalRows = filtered.length;
            var shown = (totalRows > cap) ? filtered.slice(0, cap) : filtered;
            var rows = "";
            for (var fi = 0; fi < shown.length; fi++) {
                var nc = shown[fi];
                var cmt = (appData.comments && appData.comments[nc.avis]) ? appData.comments[nc.avis] : "";
                var lateEq = (nc.chezMs != null && nc.chezMs > 2 * dayMs());   // traitement équipe > 2 jours -> ligne en rouge
                rows += "<tr" + (lateEq ? " style='background:#fef2f2;'" : "") + "><td style='text-align:center;'><button type='button' class='btn-view' onclick=\"OuvrirNCSap('" + escapeHtml(nc.avis) + "', this)\" title='Afficher la NC'></button></td>"
                    + "<td style='font-weight:700; text-align:center;'>" + escapeHtml(nc.avis) + "</td>"
                    + "<td style='text-align:center;'>" + (nc.msn ? escapeHtml(nc.msn) : "-") + "</td>"
                    + "<td>" + escapeHtml(nc.desc) + "</td>"
                    + "<td style='text-align:center;'>" + (nc.start ? FormatDateString(nc.start) : "-") + "</td>"
                    + "<td style='text-align:center;'>" + (nc.end ? FormatDateString(nc.end) : "-") + "</td>"
                    + "<td style='text-align:center; font-weight:700; color:#006698;'>" + fmtDHM(nc.durMs) + "</td>"
                    + "<td style='text-align:center; font-weight:700; color:" + (lateEq ? "#b91c1c" : "#166534") + ";'>" + fmtDHM(nc.chezMs) + "</td>"
                    + "<td>" + escapeHtml(cmt) + "</td>"
                    + "</tr>";
            }
            cont.innerHTML = "<div class='tbl-scroll' style='overflow-y:auto; padding-bottom:14px;'><table class='data-table'><thead><tr>"
                + "<th width='4%'></th>"
                + listeTh('avis', 'Avis', "width='8%'")
                + listeTh('msn', 'MSN', "width='6%'")
                + listeTh('desc', 'Descriptif', "width='20%'")
                + listeTh('start', 'Date création', "width='10%'")
                + listeTh('end', 'Date clôture', "width='10%'")
                + listeTh('dur', 'Traitement global', "width='10%'")
                + listeTh('chez', 'Traitement équipe', "width='10%'")
                + listeTh('cmt', 'Commentaire', "")
                + "</tr></thead><tbody>"
                + rows
                + "</tbody></table></div>";
            AjusterHauteurTables();
        }
        var listeSort = { col: 'end', dir: -1 };   // tri par défaut : date de clôture décroissante
        function listeTh(col, label, w) {
            var arrow = (listeSort.col === col) ? (listeSort.dir === 1 ? " &#9650;" : " &#9660;") : " <span style='color:#cbd5e1;'>&#8645;</span>";
            return "<th " + w + " style='cursor:pointer; -ms-user-select:none; user-select:none;' onclick=\"SortListe('" + col + "')\" title='Trier'>" + label + arrow + "</th>";
        }
        function SortListe(col) {
            if (listeSort.col === col) listeSort.dir = -listeSort.dir; else { listeSort.col = col; listeSort.dir = 1; }
            RenderListe();
        }
        function listeSortVal(nc, col) {
            if (col === 'avis') return parseInt(nc.avis, 10) || 0;
            if (col === 'msn') return parseInt(nc.msn, 10) || 0;
            if (col === 'desc') return (nc.desc || "").toLowerCase();
            if (col === 'start') return nc.start ? nc.start.getTime() : 0;
            if (col === 'end') return nc.end ? nc.end.getTime() : 0;
            if (col === 'dur') return nc.durMs || 0;
            if (col === 'chez') return nc.chezMs || 0;
            if (col === 'cmt') return ((appData.comments && appData.comments[nc.avis]) ? appData.comments[nc.avis] : "").toLowerCase();
            return 0;
        }
        function parseFilterDate(v) {
            v = NettoyerChaine(v); if (!v) return null;
            var p = v.split('/'); if (p.length < 3) return null;
            var dt = new Date(parseInt(p[2],10), parseInt(p[1],10)-1, parseInt(p[0],10));
            return isNaN(dt.getTime()) ? null : dt;
        }
        function EgaliserHauteursExtraction() {
            var c1 = document.getElementById('cardExtraction');
            var c2 = document.getElementById('cardFiltres');
            if (!c1 || !c2) return;
            c1.style.height = ""; c2.style.height = "";
            var h = Math.max(c1.offsetHeight, c2.offsetHeight);
            c1.style.height = h + "px"; c2.style.height = h + "px";
        }
        function AjusterHauteurTables() {
            var boxes = document.querySelectorAll('.tbl-scroll');
            for (var i = 0; i < boxes.length; i++) {
                boxes[i].onscroll = tblScrollHandler;   // bouton "remonter" quand on défile dans le tableau
                var r = boxes[i].getBoundingClientRect();
                if (r.top === 0 && r.height === 0) continue;   // masqué
                var h = window.innerHeight - r.top - 30;   // marge basse > padding bas de #content (25px) pour éviter une scrollbar
                if (h < 150) h = 150;
                var hpx = h + "px";
                if (boxes[i].style.maxHeight !== hpx) boxes[i].style.maxHeight = hpx;
            }
        }
        // Re-dimensionne les cadres d'état vide visibles (sinon un cadre dimensionné à une autre taille de fenêtre dépasse -> scrollbar).
        function ResizeEmptyCards() {
            var cards = document.querySelectorAll('.empty-extract');
            for (var i = 0; i < cards.length; i++) {
                var c = cards[i]; if (!c.offsetParent || !c.parentNode || !c.parentNode.id) continue;
                var av = ComputeAvailHeight(c.parentNode.id);
                if (av != null) c.style.height = av + "px";
            }
        }
        function ResetFiltres() {
            document.getElementById('filtreDateDebut').value = "";
            document.getElementById('filtreDateFin').value = "";
            document.getElementById('filtreRecherche').value = "";
            RefreshDateClearButtons();
            RenderListe();
        }

    // ==========================================================
    // PAGE : PARCOURS / GOULOTS
    // ==========================================================
        var parcoursWeek = null;   // timestamp (ms) du lundi de la semaine sélectionnée
        var parcoursMode = 'week'; // 'week' = filtrer par semaine, 'msn' = filtrer par MSN
        var parcoursMsn = null;    // MSN sélectionné (chaîne ; "" = NC sans MSN)
        function getWeekStart(d) { var x = new Date(d.getFullYear(), d.getMonth(), d.getDate()); var dy = x.getDay(); var diff = (dy === 0 ? -6 : 1 - dy); x.setDate(x.getDate() + diff); x.setHours(0, 0, 0, 0); return x; }
        function isoWeek(d) {
            var date = new Date(d.getFullYear(), d.getMonth(), d.getDate());
            var day = (date.getDay() + 6) % 7;           // lundi = 0 … dimanche = 6
            date.setDate(date.getDate() - day + 3);       // jeudi de la semaine
            var firstThu = new Date(date.getFullYear(), 0, 4);
            var firstDay = (firstThu.getDay() + 6) % 7;
            firstThu.setDate(firstThu.getDate() - firstDay + 3);
            return 1 + Math.round((date - firstThu) / (7 * 86400000));
        }
        function weekLabel(mon) { var sun = new Date(mon.getFullYear(), mon.getMonth(), mon.getDate() + 6); return "Semaine " + isoWeek(mon) + " - " + FormatDateString(mon) + " au " + FormatDateString(sun); }
        function SetParcoursWeek(v) { parcoursWeek = v ? parseInt(v, 10) : null; RenderParcours(); }
        function SetParcoursMsn(v) { parcoursMsn = (v == null) ? "" : ("" + v); RenderParcours(); }
        function SetParcoursMode(m) { if (m !== parcoursMode) { parcoursMode = m; RenderParcours(); } }
        function parcoursToggleHtml() {
            function b(val, txt, first) {
                var on = (parcoursMode === val);
                return "<button type='button' onclick=\"SetParcoursMode('" + val + "')\" style='vertical-align:middle; border:1px solid #c5d5de; background:" + (on ? "#006698" : "#fff") + "; color:" + (on ? "#fff" : "#475569") + "; padding:0 16px; height:38px; font-size:13px; font-weight:600; cursor:pointer; font-family:inherit; " + (first ? "border-radius:6px 0 0 6px;" : "border-radius:0 6px 6px 0; border-left:none;") + "'>" + txt + "</button>";
            }
            return b('week', 'Semaine', true) + b('msn', 'MSN', false);
        }
        function currentParcoursList() {
            var out = [];
            for (var i = 0; i < ncList.length; i++) {
                var nc = ncList[i];
                if (!(nc.eligRaw && nc.end)) continue;
                var keep = (parcoursMode === 'msn') ? (NettoyerChaine(nc.msn || "") === parcoursMsn) : (getWeekStart(nc.end).getTime() === parcoursWeek);
                if (keep) out.push(nc);
            }
            out.sort(function (a, b) { return (b.durMs || 0) - (a.durMs || 0); });
            return out;
        }
        function RenderParcours() {
            pageValid.parcours = true;   // rendu à jour (cache)
            var cont = document.getElementById('parcoursContainer');
            if (!cont) return;
            var selWeek = document.getElementById('weekSelect');
            var selMsn = document.getElementById('msnSelect');

            var closed = [];
            for (var i = 0; i < ncList.length; i++) { if (ncList[i].eligRaw && ncList[i].end) closed.push(ncList[i]); }
            var wc = document.getElementById('weekCount');
            var card = document.getElementById('weekSelectCard');
            if (!closed.length) {
                if (card) card.style.display = "none";
                cont.style.overflowY = ''; cont.style.maxHeight = ''; cont.style.paddingRight = '';   // pas de scroll pour le cadre vide
                showEmptyExtract('parcoursContainer', "Aucune NC à analyser", "Lance une extraction NC et renseigne les rôles ST/IQ dans les Paramètres.");
                return;
            }
            if (card) card.style.display = "block";
            var tog = document.getElementById('parcoursModeToggle'); if (tog) tog.innerHTML = parcoursToggleHtml();

            var list = [];
            if (parcoursMode === 'msn') {
                if (selWeek) selWeek.style.display = 'none';
                if (selMsn) selMsn.style.display = '';
                var msnMap = {};
                for (var im = 0; im < closed.length; im++) { var mk = NettoyerChaine(closed[im].msn || ""); msnMap[mk] = (msnMap[mk] || 0) + 1; }
                var msnKeys = []; for (var mkk in msnMap) { if (msnMap.hasOwnProperty(mkk)) msnKeys.push(mkk); }
                msnKeys.sort(function (a, b) {
                    if (a === "") return 1; if (b === "") return -1;   // "(Sans MSN)" en dernier
                    var na = parseInt(a, 10), nb = parseInt(b, 10);
                    if (!isNaN(na) && !isNaN(nb) && na !== nb) return na - nb;
                    return a < b ? -1 : (a > b ? 1 : 0);
                });
                if (parcoursMsn === null || msnMap[parcoursMsn] === undefined) parcoursMsn = msnKeys[0];
                if (selMsn) {
                    var ohm = "";
                    for (var zm = 0; zm < msnKeys.length; zm++) {
                        var mkey = msnKeys[zm], mlabel = (mkey === "") ? "(Sans MSN)" : ("MSN " + mkey);
                        ohm += "<option value='" + escapeHtml(mkey) + "'" + (mkey === parcoursMsn ? " selected" : "") + ">" + escapeHtml(mlabel) + " (" + msnMap[mkey] + ")</option>";
                    }
                    selMsn.innerHTML = ohm;
                }
            } else {
                if (selMsn) selMsn.style.display = 'none';
                if (selWeek) selWeek.style.display = '';
                var weeksMap = {};
                for (var i2 = 0; i2 < closed.length; i2++) { var ws = getWeekStart(closed[i2].end).getTime(); weeksMap[ws] = (weeksMap[ws] || 0) + 1; }
                var weeks = []; for (var w in weeksMap) { if (weeksMap.hasOwnProperty(w)) weeks.push(parseInt(w, 10)); }
                weeks.sort(function (a, b) { return b - a; });   // semaine la plus récente en premier
                if (parcoursWeek === null || weeksMap[parcoursWeek] === undefined) parcoursWeek = weeks[0];
                if (selWeek) {
                    var oh = "";
                    for (var z = 0; z < weeks.length; z++) {
                        var mon = new Date(weeks[z]);
                        oh += "<option value='" + weeks[z] + "'" + (weeks[z] === parcoursWeek ? " selected" : "") + ">" + weekLabel(mon) + "</option>";
                    }
                    selWeek.innerHTML = oh;
                }
            }

            list = currentParcoursList();
            if (wc) wc.innerText = list.length + (list.length > 1 ? " NC clôturées" : " NC clôturée");

            var html = "";
            for (var k = 0; k < list.length; k++) { html += renderParcoursCard(list[k]); }
            cont.innerHTML = html;
            AjusterHauteurParcours();   // la liste des NC défile en interne -> la carte du haut reste fixe
        }
        function AjusterHauteurParcours() {
            var cont = document.getElementById('parcoursContainer');
            if (!cont) return;
            cont.style.overflowY = 'auto';
            cont.style.paddingRight = '4px';
            cont.onscroll = tblScrollHandler;   // affiche le bouton "remonter" quand on défile la liste des NC
            var av = ComputeAvailHeight('parcoursContainer');
            if (av != null) cont.style.maxHeight = av + 'px';
        }
        function renderParcoursCard(nc) {
            var lines = nc.lines.slice(0).sort(function (a, b) { return (parseInt(NettoyerChaine(a.n), 10) || 0) - (parseInt(NettoyerChaine(b.n), 10) || 0); });
            var selIdx = effectiveSelIdx(nc.avis, lines);
            var rows = "", prevEnd = nc.start;   // réception de la 1re tâche = création NC
            for (var j = 0; j < lines.length; j++) {
                var LL = lines[j];
                var e = parseDT(LL.td, LL.tt);
                var rU = (LL.r || "").toUpperCase();
                var gap = (e && prevEnd && e > prevEnd) ? durBetween(prevEnd, e) : null;
                var gapTxt = (gap == null) ? "-" : fmtDHM(gap);
                var bg = "";
                if (rU === "70005847" || rU === "70009001") bg = "background:#FAEEDA;";   // orange-jaune (CT)
                else if (rU === "70005852") bg = "background:#DBEAFE;";                    // bleu (Prod)
                else if (rU === "70005848") bg = "background:#DCFCE3;";                    // vert (Qualité)
                rows += "<tr style='" + bg + "'><td style='text-align:center;'><input type='radio' name='sel_" + escapeHtml(nc.avis) + "'" + (j === selIdx ? " checked" : "") + " title='Calculer le traitement depuis cette ligne' onclick=\"RecalcGlobalFromLine('" + escapeHtml(nc.avis) + "', " + j + ")\"></td>"
                    + "<td style='font-weight:700; text-align:center;'>" + escapeHtml(LL.c) + "</td>"
                    + "<td style='text-align:center;'>" + escapeHtml(LL.r) + "</td>"
                    + "<td>" + escapeHtml(LL.dg) + "</td>"
                    + "<td style='text-align:center;'>" + escapeHtml(LL.tp || "") + "</td>"
                    + "<td style='text-align:center;'>" + (e ? FormatDateString(e) + " " + fmtHM(e) : "-") + "</td>"
                    + "<td style='text-align:center; font-weight:600;'>" + gapTxt + "</td></tr>";
                if (e) prevEnd = e;
            }
            var comment = (appData.comments && appData.comments[nc.avis]) ? appData.comments[nc.avis] : "";
            var exclBtn = "<span class='nc-switch" + (nc.excluded ? " off" : "") + "' onclick=\"ToggleExcludeNC('" + escapeHtml(nc.avis) + "')\"><span class='knob'></span></span>";
            return "<div class='card' style='padding:16px 25px;" + (nc.excluded ? " opacity:0.55; border-left:4px solid #dc2626;" : "") + "'>"
                + "<div style='overflow:hidden; margin-bottom:16px;'>"
                + "<div style='float:left;'><span style='font-weight:700; font-size:16px; color:#1e293b;'>NC " + escapeHtml(nc.avis) + "</span>" + (nc.msn ? " <span style='color:#0C447C; font-size:13px; font-weight:700;'>· MSN " + escapeHtml(nc.msn) + "</span>" : "") + " <span style='color:#1e293b; font-size:13px;'>· " + escapeHtml(nc.desc) + "</span></div>"
                + "<div style='float:right;'>"
                + "<span style='display:inline-block; vertical-align:middle; font-size:12px; font-weight:700; padding:5px 12px; border-radius:6px; background:#E6F1FB; color:#0C447C;'>Traitement global : <span id='gbadge_" + escapeHtml(nc.avis) + "'>" + fmtDHM(nc.durMs) + "</span></span>"
                + "<span style='display:inline-block; vertical-align:middle; font-size:12px; font-weight:700; padding:5px 12px; border-radius:6px; background:#dcfce3; color:#166534; margin-left:8px;'>Traitement équipe : <span id='tbadge_" + escapeHtml(nc.avis) + "'>" + fmtDHM(nc.chezMs) + "</span></span>"
                + "<button type='button' onclick=\"OuvrirNCSap('" + escapeHtml(nc.avis) + "', this)\" title='Afficher la NC' style='display:inline-block; vertical-align:middle; padding:6px 10px; border-radius:6px; background:#0C447C; color:#fff; border:none; cursor:pointer; margin-left:8px;'>"
                + "<svg width='15' height='15' viewBox='0 0 24 24' style='vertical-align:middle; display:block;' fill='none' stroke='#ffffff' stroke-width='2'><path d='M1 12s4-7 11-7 11 7 11 7-4 7-11 7-11-7-11-7z'/><circle cx='12' cy='12' r='3'/></svg>"
                + "</button>"
                + exclBtn
                + "</div>"
                + "</div>"
                + "<div style='margin-bottom:14px;'>"
                + "<input type='text' value='" + escapeHtml(comment) + "' onchange=\"SetNCComment('" + escapeHtml(nc.avis) + "', this.value)\" placeholder='Saisir un commentaire' style='width:100%; height:34px; border:1px solid #c5d5de; border-radius:6px; padding:6px 10px; font-family:inherit; font-size:13px; color:#1e293b; box-sizing:border-box;'>"
                + "</div>"
                + "<table class='data-table'><thead><tr><th width='5%'></th><th width='14%' style='text-align:center;'>Code</th><th width='14%' style='text-align:center;'>Responsable</th><th width='25%'>Désignation</th><th width='14%' style='text-align:center;'>Terminé par</th><th width='14%' style='text-align:center;'>Date et Heure</th><th width='14%' style='text-align:center;'>Durée</th></tr></thead><tbody>"
                + rows + "</tbody></table></div>";
        }
        // Suffixe de nom de fichier pour l'export Analyse NC (selon le filtre semaine / MSN).
        function parcoursExportTag() {
            if (parcoursMode === 'msn') return (parcoursMsn === "" ? "sans-MSN" : parcoursMsn);
            if (parcoursWeek) { var mon = new Date(parcoursWeek); return "S" + isoWeek(mon) + "-" + mon.getFullYear(); }
            return "export";
        }
        function ExportParcoursPDF() {
            if (pdfExporting) return;
            var list = currentParcoursList();
            if (!list.length) { AfficherErreur("Aucune NC à exporter pour la sélection actuelle."); return; }
            var filterLabel = (parcoursMode === 'msn')
                ? ("MSN " + (parcoursMsn === "" ? "(sans MSN)" : parcoursMsn))
                : weekLabel(new Date(parcoursWeek));
            var sumG = 0, nG = 0, sumT = 0, nT = 0;
            for (var i = 0; i < list.length; i++) {
                if (list[i].durMs != null) { sumG += list[i].durMs; nG++; }
                if (list[i].chezMs != null) { sumT += list[i].chezMs; nT++; }
            }
            var html = buildParcoursReportHtml(list, filterLabel, nG ? sumG / nG : null, nT ? sumT / nT : null);
            startPdfExport(html, "KPI-PERFO_AnalyseNC_" + parcoursExportTag());   // génération directe (Edge) comme le tableau de bord
        }
        function parcoursReportCard(nc) {
            var lines = nc.lines.slice(0).sort(function (a, b) { return (parseInt(NettoyerChaine(a.n), 10) || 0) - (parseInt(NettoyerChaine(b.n), 10) || 0); });
            var rows = "", prevEnd = nc.start;
            for (var j = 0; j < lines.length; j++) {
                var LL = lines[j], e = parseDT(LL.td, LL.tt);
                var gap = (e && prevEnd && e > prevEnd) ? durBetween(prevEnd, e) : null;
                rows += "<tr><td class='c'>" + escapeHtml(LL.c) + "</td><td class='c'>" + escapeHtml(LL.r) + "</td><td>" + escapeHtml(LL.dg) + "</td><td class='c'>" + escapeHtml(LL.tp || "") + "</td><td class='c'>" + (e ? FormatDateString(e) + " " + fmtHM(e) : "-") + "</td><td class='c b'>" + (gap == null ? "-" : fmtDHM(gap)) + "</td></tr>";
                if (e) prevEnd = e;
            }
            var comment = (appData.comments && appData.comments[nc.avis]) ? appData.comments[nc.avis] : "";
            return "<div class='nc'>"
                + "<div class='nchead'><span class='ncttl'>NC " + escapeHtml(nc.avis) + "</span>" + (nc.msn ? " &middot; MSN " + escapeHtml(nc.msn) : "") + " &middot; " + escapeHtml(nc.desc) + "</div>"
                + "<div class='badges'><span class='bg1'>Traitement global : " + fmtDHM(nc.durMs) + "</span> <span class='bg2'>Traitement équipe : " + fmtDHM(nc.chezMs) + "</span></div>"
                + (comment ? "<div class='cmt'>Commentaire : " + escapeHtml(comment) + "</div>" : "")
                + "<table class='tbl'><thead><tr><th>Code</th><th>Responsable</th><th>Désignation</th><th>Terminé par</th><th>Date et Heure</th><th>Durée</th></tr></thead><tbody>" + rows + "</tbody></table>"
                + "</div>";
        }
        function buildParcoursReportHtml(list, filterLabel, avgG, avgT) {
            var now = new Date(), body = "";
            for (var i = 0; i < list.length; i++) body += parcoursReportCard(list[i]);
            var css = "*{box-sizing:border-box;} body{font-family:'Segoe UI',Arial,sans-serif;color:#1e293b;margin:8px;font-size:12px;}"
                + ".rpt-head{display:flex;justify-content:space-between;align-items:flex-end;border-bottom:2px solid #0C447C;padding-bottom:6px;margin-bottom:6px;}"
                + ".rpt-title{font-size:16px;font-weight:700;color:#0C447C;} .rpt-sub{font-size:11px;color:#475569;text-align:right;line-height:1.4;} .rpt-stats{font-size:12px;margin-bottom:12px;}"
                + ".nc{border:1px solid #c5d5de;border-radius:6px;padding:10px 12px;margin-bottom:12px;page-break-inside:avoid;}"
                + ".nchead{font-weight:700;font-size:13px;margin-bottom:6px;} .ncttl{color:#0C447C;}"
                + ".badges{margin-bottom:8px;} .badges span{display:inline-block;font-size:11px;font-weight:700;padding:3px 8px;border-radius:4px;margin-right:6px;}"
                + ".bg1{background:#E6F1FB;color:#0C447C;} .bg2{background:#dcfce3;color:#166534;}"
                + ".cmt{font-size:11px;font-style:italic;color:#475569;margin-bottom:8px;}"
                + "table.tbl{width:100%;border-collapse:collapse;} table.tbl th,table.tbl td{border:1px solid #c5d5de;padding:4px 6px;font-size:11px;} table.tbl th{background:#f0f4f7;text-align:center;}"
                + "td.c{text-align:center;} td.b{font-weight:600;} @page{margin:7mm;} @media print{body{margin:0;}}";
            return "<!DOCTYPE html><html><head><meta charset='utf-8'><title>KPI-PERFO_AnalyseNC_" + parcoursExportTag() + "</title><style>" + css + "</style></head><body>"
                + "<div class='rpt-head'><div class='rpt-title'>KPI PERFO - Récapitulatif Analyse NC</div>"
                + "<div class='rpt-sub'>" + escapeHtml(filterLabel) + " &middot; " + list.length + " NC" + (list.length > 1 ? "s" : "") + "<br>Généré le " + FormatDateString(now) + " " + fmtHM(now) + "</div></div>"
                + "<div class='rpt-stats'>Traitement global moyen : <b>" + (avgG == null ? "-" : fmtDHM(avgG)) + "</b> &nbsp;|&nbsp; Traitement équipe moyen : <b>" + (avgT == null ? "-" : fmtDHM(avgT)) + "</b></div>"
                + body + "</body></html>";
        }
        // ================= EXPORT PDF DU TABLEAU DE BORD NC =================
        // Sérialise un <svg> en ajoutant un viewBox (sur un clone) pour qu'il se mette à l'échelle proprement à l'impression.
        function serializeSVG(s) {
            if (!s) return "";
            var c = s.cloneNode(true);
            if (!c.getAttribute('viewBox')) {
                var w = parseFloat(s.getAttribute('width')) || 0, h = parseFloat(s.getAttribute('height')) || 0;
                if (w && h) c.setAttribute('viewBox', '0 0 ' + w + ' ' + h);
            }
            try { return new XMLSerializer().serializeToString(c); } catch (e) { return s.outerHTML || ""; }
        }
        // Re-rend le graphe "évolution par semaine" (données du graphique vivant) à une taille contrôlée, spacing serré (pas de vide sous la légende).
        function weeksExportSVG(w, h) {
            var live = window.hcRefs['hcWeeks'];
            if (!live || !live.series || !live.series.length) return "";
            var cats = (live.xAxis && live.xAxis[0] && live.xAxis[0].categories) ? live.xAxis[0].categories : [];
            var series = [];
            for (var i = 0; i < live.series.length; i++) {
                var s = live.series[i], od = (s.options && s.options.data) ? s.options.data : [], data = [];
                for (var k = 0; k < od.length; k++) { var d = od[k]; data.push((d && typeof d === 'object') ? d.y : d); }
                series.push({ name: s.name, data: data, color: s.color });
            }
            var tmp = document.createElement('div');
            tmp.style.position = 'absolute'; tmp.style.left = '-10000px'; tmp.style.top = '0'; tmp.style.width = w + 'px'; tmp.style.height = h + 'px';
            document.body.appendChild(tmp);
            var out = "";
            try {
                var ch = Highcharts.chart(tmp, {
                    chart: { type: 'line', width: w, height: h, backgroundColor: '#ffffff', spacing: [6, 4, 2, 2], style: { fontFamily: "'Segoe UI',Arial,sans-serif" } },
                    title: { text: null }, credits: { enabled: false }, tooltip: { enabled: false },
                    legend: { enabled: true, align: 'center', verticalAlign: 'bottom', layout: 'horizontal', margin: 2, padding: 0, itemMarginTop: 0, itemMarginBottom: 0, itemStyle: { fontSize: '10px' } },
                    xAxis: { categories: cats, labels: { style: { color: '#334155', fontWeight: '600' } } },
                    yAxis: { title: { text: null }, min: 0, tickInterval: 5, plotLines: [{ value: 2, color: '#dc2626', dashStyle: 'Dash', width: 1.5, zIndex: 5 }] },
                    plotOptions: { line: { animation: false, marker: { radius: 3 }, lineWidth: 2 }, series: { connectNulls: true } },
                    series: series
                });
                out = serializeSVG(tmp.getElementsByTagName('svg')[0]);
                ch.destroy();
            } catch (e) {}
            if (tmp.parentNode) tmp.parentNode.removeChild(tmp);
            return out;
        }
        // Re-rend un camembert (données du graphique vivant) dans un conteneur caché, AVEC légende (titre géré à l'extérieur), renvoie le SVG.
        // legendRight=true -> légende verticale à droite ; sinon légende horizontale en bas.
        function pieExportSVG(id, w, h, legendRight) {
            var live = window.hcRefs[id];
            if (!live || !live.series || !live.series[0] || !live.series[0].data.length) return "";
            var sd = live.series[0].data, pts = [];
            for (var i = 0; i < sd.length; i++) pts.push({ name: sd[i].name, y: sd[i].y, color: sd[i].color });
            var tmp = document.createElement('div');
            tmp.style.position = 'absolute'; tmp.style.left = '-10000px'; tmp.style.top = '0'; tmp.style.width = w + 'px'; tmp.style.height = h + 'px';
            document.body.appendChild(tmp);
            var out = "";
            try {
                var leg = legendRight
                    ? { enabled: true, align: 'right', verticalAlign: 'middle', layout: 'vertical', itemMarginBottom: 1, itemStyle: { fontSize: '10px', color: '#334155', fontWeight: 'normal' } }
                    : { enabled: true, align: 'center', verticalAlign: 'bottom', layout: 'horizontal', itemStyle: { fontSize: '10px', color: '#334155', fontWeight: 'normal' } };
                var ch = Highcharts.chart(tmp, {
                    chart: { type: 'pie', width: w, height: h, backgroundColor: '#ffffff', spacing: [4, 4, 4, 4], style: { fontFamily: "'Segoe UI',Arial,sans-serif" } },
                    title: { text: null }, credits: { enabled: false }, tooltip: { enabled: false },
                    legend: leg,
                    plotOptions: { pie: { animation: false, showInLegend: true, size: '86%', dataLabels: { enabled: true, format: '{percentage:.0f}%', distance: -20, style: { color: '#ffffff', fontSize: '10px', fontWeight: 'bold', textOutline: 'none' } } } },
                    series: [{ name: 'x', data: pts }]
                });
                out = serializeSVG(tmp.getElementsByTagName('svg')[0]);
                ch.destroy();
            } catch (e) {}
            if (tmp.parentNode) tmp.parentNode.removeChild(tmp);
            return out;
        }
        // Re-rend un graphique ligne OF (données du graphique vivant) à une taille contrôlée, renvoie le SVG. showLegend=false pour les courbes "Total".
        function ofLineExportSVG(id, w, h, showLegend) {
            var live = window.hcRefs[id];
            if (!live || !live.series || !live.series.length) return "";
            var cats = (live.xAxis && live.xAxis[0] && live.xAxis[0].categories) ? live.xAxis[0].categories : [];
            var series = [];
            for (var i = 0; i < live.series.length; i++) {
                var s = live.series[i], od = (s.options && s.options.data) ? s.options.data : [], data = [];
                for (var k = 0; k < od.length; k++) { var d = od[k]; data.push((d && typeof d === 'object') ? d.y : d); }
                series.push({ name: s.name, data: data, color: s.color });
            }
            var tmp = document.createElement('div');
            tmp.style.position = 'absolute'; tmp.style.left = '-10000px'; tmp.style.top = '0'; tmp.style.width = w + 'px'; tmp.style.height = h + 'px';
            document.body.appendChild(tmp);
            var out = "";
            try {
                var ch = Highcharts.chart(tmp, {
                    chart: { type: 'line', width: w, height: h, backgroundColor: '#ffffff', spacing: [6, 4, 2, 2], style: { fontFamily: "'Segoe UI',Arial,sans-serif" } },
                    title: { text: null }, credits: { enabled: false }, tooltip: { enabled: false },
                    legend: showLegend ? { enabled: true, align: 'center', verticalAlign: 'bottom', layout: 'horizontal', margin: 2, padding: 0, itemMarginTop: 0, itemMarginBottom: 0, itemStyle: { fontSize: '10px' } } : { enabled: false },
                    xAxis: { categories: cats, labels: { style: { color: '#334155', fontWeight: '600' } } },
                    yAxis: { title: { text: null }, min: 0, allowDecimals: false },
                    plotOptions: { line: { animation: false, marker: { radius: 3 }, lineWidth: 2 }, series: { connectNulls: true } },
                    series: series
                });
                out = serializeSVG(tmp.getElementsByTagName('svg')[0]);
                ch.destroy();
            } catch (e) {}
            if (tmp.parentNode) tmp.parentNode.removeChild(tmp);
            return out;
        }
        function dashExportPeriodLabel() {
            var s = dashPeriodState(), lbl = (s && s.idx >= 0) ? s.label(s.items[s.idx]) : "";
            var g = dashFilter.gran;
            if (g === 'year') return "Année " + lbl;
            if (g === 'week') return "Semaine " + lbl;
            if (g === 'msn') return "Par MSN · " + lbl;
            return "Mois : " + lbl;
        }
        // Nom du document d'export selon le filtre : S<sem>-<an> / M<mois>-<an> / <an> / <msnMin>-<msnMax>.
        function dashExportFileTag() {
            var g = dashFilter.gran, y = dashFilter.year;
            if (g === 'year') return "" + y;
            if (g === 'week') return "S" + dashFilter.week + "-" + y;
            if (g === 'msn') {
                var all = dashAllMSN(), list = [];
                if (!dashFilter.msnSel) list = all.slice(0);
                else { for (var i = 0; i < all.length; i++) { if (dashFilter.msnSel[all[i]]) list.push(all[i]); } }
                if (!list.length) return "MSN";
                list.sort(function (a, b) { return (parseInt(a, 10) || 0) - (parseInt(b, 10) || 0); });
                var joined = list.join("-");
                return (joined.length > 100) ? (list[0] + "-" + list[list.length - 1]) : joined;   // filet de sécurité : nom de fichier trop long

            }
            var m = dashFilter.month + 1;   // mois 0-based -> 1-based, sur 2 chiffres
            return "M" + (m < 10 ? "0" : "") + m + "-" + y;
        }
        // Réduit les tailles de police du widget "3 semaines" via le DOM (fiable - le regex sur innerHTML échoue car IE réécrit les styles) et fixe sa hauteur.
        // Widget "3 dernières semaines" dédié à l'export : compact, texte centré, espacements réguliers (tables -> colonnes alignées).
        function buildExportWeeks3(pts) {
            var wk = pts.slice(Math.max(0, pts.length - 3));
            if (!wk.length) return "<div class='nodata'>Aucune donnée</div>";
            var n = wk.length, h = "<table style='width:100%;border-collapse:collapse;table-layout:fixed;'><tr>";
            for (var i = 0; i < n; i++) h += "<td style='text-align:center;font-size:11px;font-weight:700;color:#334155;padding:0 4px 4px 4px;'>Semaine " + wk[i].week + "</td>";
            h += "</tr><tr>";
            for (var j = 0; j < n; j++) {
                h += "<td style='padding:0 4px;vertical-align:top;'><div style='background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;padding:8px 5px;text-align:center;'>"
                    + "<div style='font-size:10px;color:#475569;white-space:nowrap;margin-bottom:4px;'><span style='display:inline-block;width:8px;height:8px;background:#0C447C;border-radius:2px;margin-right:4px;'></span>Global : <b style='color:#0C447C;'>" + fmtDHM(wk[j].g) + "</b></div>"
                    + "<div style='font-size:10px;color:#475569;white-space:nowrap;'><span style='display:inline-block;width:8px;height:8px;background:#166534;border-radius:2px;margin-right:4px;'></span>Équipe : <b style='color:#166534;'>" + fmtDHM(wk[j].t) + "</b></div>"
                    + "</div></td>";
            }
            h += "</tr></table>";
            if (n >= 2) {
                h += "<table style='width:100%;border-collapse:collapse;table-layout:fixed;margin-top:10px;'><tr>";
                for (var k = 0; k < n - 1; k++) h += "<td style='text-align:center;font-size:10px;font-weight:600;color:#64748b;padding:0 4px 4px 4px;'>S" + wk[k].week + " &rarr; S" + wk[k + 1].week + "</td>";
                h += "</tr><tr>";
                for (var m = 0; m < n - 1; m++) h += "<td style='padding:0 4px;vertical-align:top;'>" + exportEvoBox(wk[m], wk[m + 1]) + "</td>";
                h += "</tr></table>";
            }
            return "<div style='width:100%;'>" + h + "</div>";
        }
        function exportEvoBox(a, b) {
            var dG = b.g - a.g, am = dG < 0, dg = dG > 0;
            var bg = am ? "#dcfce3" : (dg ? "#fee2e2" : "#f8fafc"), bd = am ? "#86efac" : (dg ? "#fca5a5" : "#e2e8f0");
            function line(label, fromV, toV, last) {
                var d = toV - fromV, a2 = d < 0, d2 = d > 0;
                var ar = a2 ? "&#8600;" : (d2 ? "&#8599;" : "&#8211;"), c = a2 ? "#166534" : (d2 ? "#b91c1c" : "#64748b");
                var t = (d === 0) ? "Stable" : ((a2 ? "-" : "+") + fmtDHM(Math.abs(d)));
                return "<div style='font-size:10px;color:#475569;text-align:center;margin-bottom:" + (last ? "0" : "4px") + ";'>" + label + " <b style='color:" + c + ";'>" + ar + " " + t + "</b></div>";
            }
            return "<div style='background:" + bg + ";border:1px solid " + bd + ";border-radius:8px;padding:8px 6px;text-align:center;'>" + line("Global", a.g, b.g, false) + line("Équipe", a.t, b.t, true) + "</div>";
        }
        function buildDashboardNCReportHtml() {
            var dc = document.getElementById('dashCharts');
            if (!dc || dc.style.display === 'none') return null;
            var GH = 185;   // hauteur commune des graphiques (px)
            var elig = [];
            for (var e = 0; e < ncList.length; e++) { if (ncList[e].eligible) elig.push(ncList[e]); }
            var w3html = buildExportWeeks3(computeTimePts(elig, 'week'));   // widget 3 semaines dédié à l'export (propre, centré)
            var weeksSVG = weeksExportSVG(560, GH) || "<div class='nodata'>Aucune donnée</div>";
            function pie(id, w, h, lr) { var s = pieExportSVG(id, w, h, lr); return s || "<div class='nodata'>Aucune donnée</div>"; }
            var pInt = pie('hcRespInt', 440, GH, true);
            var pExt = pie('hcRespExt', 440, GH, true);
            var pEq = pie('hcSeuilEquipe', 380, GH, true);
            var pGl = pie('hcSeuilGlobal', 380, GH, true);
            var now = new Date();
            var css = "*{box-sizing:border-box;} body{font-family:'Segoe UI',Arial,sans-serif;color:#1e293b;margin:8px;font-size:11px;}"
                + ".hd{display:flex;justify-content:space-between;align-items:flex-end;border-bottom:2px solid #0C447C;padding-bottom:5px;margin-bottom:8px;}"
                + ".ttl{font-size:15px;font-weight:700;color:#0C447C;} .sub{font-size:11px;color:#475569;text-align:right;line-height:1.4;}"
                + ".row{display:flex;align-items:stretch;margin-bottom:8px;} .cell{padding:0 4px;}"
                + ".box{border:1px solid #e2e8f0;border-radius:6px;padding:5px 7px;height:100%;display:flex;flex-direction:column;text-align:center;}"
                + ".secttl{font-size:12px;font-weight:700;color:#0C447C;margin-bottom:4px;text-align:left;flex:0 0 auto;}"
                + ".content{flex:1 1 auto;display:flex;flex-direction:column;align-items:center;justify-content:center;}"
                + ".wk svg,.pie svg{height:" + GH + "px;width:auto;max-width:100%;}"
                + ".nodata{color:#94a3b8;font-style:italic;padding:70px 0;}"
                + "@page{size:A4 landscape;margin:7mm;} @media print{body{margin:0;}}";
            function cell(w, title, content) { return "<div class='cell' style='width:" + w + "'><div class='box'><div class='secttl'>" + title + "</div><div class='content'>" + content + "</div></div></div>"; }
            return "<!DOCTYPE html><html><head><meta charset='utf-8'><title>KPI-PERFO_NC_" + dashExportFileTag() + "</title><style>" + css + "</style></head><body>"
                + "<div class='hd'><div class='ttl'>KPI PERFO - Tableau de bord (Non-conformité)</div>"
                + "<div class='sub'>" + escapeHtml(dashExportPeriodLabel()) + "<br>Généré le " + FormatDateString(now) + " " + fmtHM(now) + "</div></div>"
                + "<div class='row'>" + cell("40%", "Évolution sur les 3 dernières semaines", w3html) + cell("60%", "Évolution du traitement par semaine", "<div class='wk'>" + weeksSVG + "</div>") + "</div>"
                + "<div class='row'>" + cell("50%", "Durée moyenne - Responsables internes", "<div class='pie'>" + pInt + "</div>") + cell("50%", "Répartition - Traitement équipe", "<div class='pie'>" + pEq + "</div>") + "</div>"
                + "<div class='row'>" + cell("50%", "Durée moyenne - Responsables externes", "<div class='pie'>" + pExt + "</div>") + cell("50%", "Répartition - Traitement global", "<div class='pie'>" + pGl + "</div>") + "</div>"
                + "</body></html>";
        }
        // Chemin de msedge.exe (génération PDF headless). "" si introuvable.
        function findEdgePath() {
            try {
                var fso = new ActiveXObject("Scripting.FileSystemObject"), sh = new ActiveXObject("WScript.Shell");
                var c = [sh.ExpandEnvironmentStrings("%ProgramFiles(x86)%") + "\\Microsoft\\Edge\\Application\\msedge.exe",
                    sh.ExpandEnvironmentStrings("%ProgramFiles%") + "\\Microsoft\\Edge\\Application\\msedge.exe",
                    sh.ExpandEnvironmentStrings("%LOCALAPPDATA%") + "\\Microsoft\\Edge\\Application\\msedge.exe"];
                for (var i = 0; i < c.length; i++) { if (fso.FileExists(c[i])) return c[i]; }
                try { var p = sh.RegRead("HKLM\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\App Paths\\msedge.exe\\"); if (p && fso.FileExists(p)) return p; } catch (e) {}
            } catch (e2) {}
            return "";
        }
        function nowStamp() {
            var d = new Date(), p = function (n) { return (n < 10 ? "0" : "") + n; };
            return d.getFullYear() + p(d.getMonth() + 1) + p(d.getDate()) + "_" + p(d.getHours()) + p(d.getMinutes()) + p(d.getSeconds());
        }
        // Écrit un fichier texte : essai UTF-8 via ADODB.Stream, repli UTF-16+BOM via FileSystemObject (si ADODB bloqué). false si échec.
        function writeReportFile(path, text) {
            try { var st = new ActiveXObject("ADODB.Stream"); st.Type = 2; st.Charset = "UTF-8"; st.Open(); st.WriteText(text); st.SaveToFile(path, 2); st.Close(); return true; } catch (e) {}
            try { var fso = new ActiveXObject("Scripting.FileSystemObject"); var f = fso.CreateTextFile(path, true, true); f.Write(text); f.Close(); return true; } catch (e2) {}
            return false;
        }
        var pdfExporting = false;   // anti double-clic : une seule génération PDF à la fois
        // Lance la génération directe (Edge) ; repli impression si échec. pollDashPdf remet pdfExporting=false à la fin.
        function startPdfExport(html, base) {
            pdfExporting = true;
            var reason = tryDirectPdf(html, base);
            if (reason === "") return;   // génération en cours
            pdfExporting = false;
            AfficherErreur("Génération directe du PDF impossible : " + reason + ".\n\nRepli sur la boîte d'impression - choisis « Microsoft Print to PDF ».");
            PrintHtmlReport(html);
        }
        // Purge les temporaires d'export (kpi_dash_nc_*.html + dossiers kpi_edge_*) laissés dans %TEMP% par des générations interrompues.
        function CleanExportTemp() {
            try {
                var fso = new ActiveXObject("Scripting.FileSystemObject"), tmp = fso.GetFolder(fso.GetSpecialFolder(2));
                var ef = new Enumerator(tmp.Files);
                for (; !ef.atEnd(); ef.moveNext()) { var f = ef.item(); if (/^kpi_dash_nc_.*\.html$/i.test(f.Name)) { try { f.Delete(true); } catch (x) {} } }
                var ed = new Enumerator(tmp.SubFolders);
                for (; !ed.atEnd(); ed.moveNext()) { var d = ed.item(); if (/^kpi_edge_/i.test(d.Name)) { try { d.Delete(true); } catch (x2) {} } }
            } catch (e) {}
        }
        function ExportDashboardNC() {
            if (pdfExporting) return;
            var html = buildDashboardNCReportHtml();
            if (html == null) { AfficherErreur("Aucune donnée à exporter. Lance une extraction NC."); return; }
            startPdfExport(html, "KPI-PERFO_NC_" + dashExportFileTag());
        }
        // Rapport PDF du tableau de bord OF : 4 courbes (créés/clôturés, par membre + total) en grille 2x2, paysage A4.
        function buildDashboardOFReportHtml() {
            var dc = document.getElementById('dashOFCharts');
            if (!dc || dc.style.display === 'none') return null;
            var GH = 240;   // hauteur commune des graphiques (px)
            function chart(id, showLegend) { var s = ofLineExportSVG(id, 580, GH, showLegend); return s || "<div class='nodata'>Aucune donnée</div>"; }
            var cCreeUser = chart('hcOFCreeUser', true), cCreeTot = chart('hcOFCreeTotal', false);
            var cClotUser = chart('hcOFClotUser', true), cClotTot = chart('hcOFClotTotal', false);
            var now = new Date();
            var css = "*{box-sizing:border-box;} body{font-family:'Segoe UI',Arial,sans-serif;color:#1e293b;margin:8px;font-size:11px;}"
                + ".hd{display:flex;justify-content:space-between;align-items:flex-end;border-bottom:2px solid #0C447C;padding-bottom:5px;margin-bottom:8px;}"
                + ".ttl{font-size:15px;font-weight:700;color:#0C447C;} .sub{font-size:11px;color:#475569;text-align:right;line-height:1.4;}"
                + ".row{display:flex;align-items:stretch;margin-bottom:8px;} .cell{padding:0 4px;}"
                + ".box{border:1px solid #e2e8f0;border-radius:6px;padding:5px 7px;height:100%;display:flex;flex-direction:column;text-align:center;}"
                + ".secttl{font-size:12px;font-weight:700;color:#0C447C;margin-bottom:4px;text-align:left;flex:0 0 auto;}"
                + ".content{flex:1 1 auto;display:flex;flex-direction:column;align-items:center;justify-content:center;}"
                + ".ofc svg{height:" + GH + "px;width:auto;max-width:100%;}"
                + ".nodata{color:#94a3b8;font-style:italic;padding:90px 0;}"
                + "@page{size:A4 landscape;margin:7mm;} @media print{body{margin:0;}}";
            function cell(w, title, content) { return "<div class='cell' style='width:" + w + "'><div class='box'><div class='secttl'>" + title + "</div><div class='content'>" + content + "</div></div></div>"; }
            return "<!DOCTYPE html><html><head><meta charset='utf-8'><title>KPI-PERFO_OF_" + dashExportFileTag() + "</title><style>" + css + "</style></head><body>"
                + "<div class='hd'><div class='ttl'>KPI PERFO - Tableau de bord (Ordre de Fabrication)</div>"
                + "<div class='sub'>" + escapeHtml(dashExportPeriodLabel()) + "<br>Généré le " + FormatDateString(now) + " " + fmtHM(now) + "</div></div>"
                + "<div class='row'>" + cell("50%", "OF créés - Équipe ST", "<div class='ofc'>" + cCreeUser + "</div>") + cell("50%", "Total du nombre OF créés", "<div class='ofc'>" + cCreeTot + "</div>") + "</div>"
                + "<div class='row'>" + cell("50%", "OF clôturés - Équipe IQ", "<div class='ofc'>" + cClotUser + "</div>") + cell("50%", "Total du nombre OF clôturés", "<div class='ofc'>" + cClotTot + "</div>") + "</div>"
                + "</body></html>";
        }
        function ExportDashboardOF() {
            if (pdfExporting) return;
            var html = buildDashboardOFReportHtml();
            if (html == null) { AfficherErreur("Aucune donnée à exporter. Lance une extraction OF."); return; }
            startPdfExport(html, "KPI-PERFO_OF_" + dashExportFileTag());
        }
        // Tente de générer le PDF via Edge headless. Renvoie "" si lancé, sinon le motif d'échec (pour diagnostic).
        function tryDirectPdf(html, base) {
            var edge = findEdgePath();
            if (!edge) return "Microsoft Edge introuvable";
            var fso, sh;
            try { fso = new ActiveXObject("Scripting.FileSystemObject"); sh = new ActiveXObject("WScript.Shell"); } catch (e) { return "Scripting.FileSystemObject / WScript.Shell indisponible"; }
            var stamp = nowStamp(), tmp;
            try { tmp = fso.GetSpecialFolder(2); } catch (e) { return "dossier temporaire inaccessible"; }
            var tmpHtml = tmp + "\\kpi_dash_nc_" + stamp + ".html", udd = tmp + "\\kpi_edge_" + stamp;
            if (!writeReportFile(tmpHtml, html)) return "écriture du fichier temporaire bloquée";
            var dl; try { dl = sh.ExpandEnvironmentStrings("%USERPROFILE%") + "\\Downloads"; if (!fso.FolderExists(dl)) dl = sh.ExpandEnvironmentStrings("%USERPROFILE%"); } catch (e) { dl = tmp; }
            var pdf = dl + "\\" + base + ".pdf";
            try { if (fso.FileExists(pdf)) fso.DeleteFile(pdf); } catch (e) {}                       // écrase l'ancien export du même filtre
            if (fso.FileExists(pdf)) pdf = dl + "\\" + base + "_" + stamp + ".pdf";                   // ancien fichier verrouillé (ouvert) -> nom unique
            var url = "file:///" + tmpHtml.replace(/\\/g, "/").replace(/ /g, "%20");
            var cmd = '"' + edge + '" --headless=new --disable-gpu --no-first-run --user-data-dir="' + udd + '" --no-pdf-header-footer --print-to-pdf="' + pdf + '" "' + url + '"';
            try { sh.Run(cmd, 0, false); } catch (e) { return "lancement d'Edge bloqué (" + e.message + ")"; }
            document.body.style.cursor = 'wait';
            pollDashPdf(pdf, tmpHtml, udd, html, 0, 0);
            return "";
        }
        // Attend l'apparition (stable) du PDF généré par Edge, ouvre l'Explorateur dessus ; repli impression si échec.
        function pollDashPdf(pdf, tmpHtml, udd, html, tries, stable) {
            var fso; try { fso = new ActiveXObject("Scripting.FileSystemObject"); } catch (e) { pdfExporting = false; document.body.style.cursor = ''; PrintHtmlReport(html); return; }
            var sz = -1; try { if (fso.FileExists(pdf)) sz = fso.GetFile(pdf).Size; } catch (e2) {}
            if (sz > 0 && stable >= 1) {   // fichier présent et stable (2 relevés) -> terminé
                pdfExporting = false; document.body.style.cursor = '';
                try { fso.DeleteFile(tmpHtml); } catch (e3) {}
                try { fso.DeleteFolder(udd, true); } catch (e4) {}
                try { new ActiveXObject("Shell.Application").ShellExecute(pdf); }   // ouvre directement le PDF (appli par défaut)
                catch (e5) { try { new ActiveXObject("WScript.Shell").Run('explorer.exe "' + pdf + '"', 1, false); } catch (e5b) {} }
                return;
            }
            if (tries >= 40) {   // ~16 s sans résultat -> repli impression
                pdfExporting = false; document.body.style.cursor = '';
                try { fso.DeleteFile(tmpHtml); } catch (e6) {}
                try { fso.DeleteFolder(udd, true); } catch (e7) {}
                AfficherErreur("Edge a été lancé mais aucun PDF n'est apparu (Edge probablement bloqué par la politique de sécurité, ou l'option --headless est indisponible).\n\nRepli sur la boîte d'impression.");
                PrintHtmlReport(html);
                return;
            }
            setTimeout(function () { pollDashPdf(pdf, tmpHtml, udd, html, tries + 1, sz > 0 ? stable + 1 : 0); }, 400);
        }
        function stripPrintHeaders() {
            var base = "HKEY_CURRENT_USER\\Software\\Microsoft\\Internet Explorer\\PageSetup\\";
            var st = { sh: null, hKey: base + "header", fKey: base + "footer", hOld: "", fOld: "", hHad: false, fHad: false };
            try {
                st.sh = new ActiveXObject("WScript.Shell");
                try { st.hOld = st.sh.RegRead(st.hKey); st.hHad = true; } catch (e) {}
                try { st.fOld = st.sh.RegRead(st.fKey); st.fHad = true; } catch (e) {}
                st.sh.RegWrite(st.hKey, "", "REG_SZ");
                st.sh.RegWrite(st.fKey, "", "REG_SZ");
            } catch (e2) {}
            return st;
        }
        function restorePrintHeaders(st) {
            if (!st || !st.sh) return;
            try { if (st.hHad) st.sh.RegWrite(st.hKey, st.hOld, "REG_SZ"); else st.sh.RegDelete(st.hKey); } catch (e) {}
            try { if (st.fHad) st.sh.RegWrite(st.fKey, st.fOld, "REG_SZ"); else st.sh.RegDelete(st.fKey); } catch (e2) {}
        }
        function PrintHtmlReport(html) {
            var old = document.getElementById('printFrame'); if (old && old.parentNode) old.parentNode.removeChild(old);
            var ifr = document.createElement('iframe');
            ifr.id = 'printFrame';
            ifr.style.position = 'fixed'; ifr.style.right = '0'; ifr.style.bottom = '0'; ifr.style.width = '0'; ifr.style.height = '0'; ifr.style.border = '0';
            document.body.appendChild(ifr);
            try {
                var doc = ifr.contentWindow.document;
                doc.open(); doc.write(html); doc.close();
                setTimeout(function () {
                    var st = stripPrintHeaders();
                    try { ifr.contentWindow.focus(); ifr.contentWindow.print(); }
                    catch (e) { AfficherErreur("Impression impossible : " + e.message); restorePrintHeaders(st); return; }
                    setTimeout(function () { restorePrintHeaders(st); }, 30000);
                }, 250);
            } catch (e2) { AfficherErreur("Erreur lors de la génération du rapport : " + e2.message); }
        }
        function SetNCComment(avis, val) {
            if (!appData.comments) appData.comments = {};
            appData.comments[avis] = NettoyerChaine(val);
            extractValid.NC = false;   // la colonne Commentaire du tableau NC doit refléter la modif
            SaveData();
            shareQueueComment(avis, appData.comments[avis]);   // base partagée
        }
        function ToggleExcludeNC(avis) {
            if (!appData.excluded) appData.excluded = {};
            if (appData.excluded[avis]) { delete appData.excluded[avis]; } else { appData.excluded[avis] = true; }
            RecomputeAll();
            SaveData();
            RenderParcours();
        }
        function internalRespSet() { var s = {}, rd = appData.roleDesig || []; for (var i = 0; i < rd.length; i++) { if (NettoyerChaine(rd[i].type) === "int") { var rc = NettoyerChaine(rd[i].resp).toUpperCase(); if (rc) s[rc] = true; } } return s; }
        function teamUserSet() { var s = {}, ts = [appData.teamST, appData.teamTL, appData.teamIQ]; for (var t = 0; t < ts.length; t++) { var a = ts[t] || []; for (var i = 0; i < a.length; i++) { var u = NettoyerChaine(a[i].user).toUpperCase(); if (u) s[u] = true; } } return s; }
        function stUserSet() { var s = {}, a = appData.teamST || []; for (var i = 0; i < a.length; i++) { var u = NettoyerChaine(a[i].user).toUpperCase(); if (u) s[u] = true; } return s; }
        function defaultSelIdx(sortedLines) {
            var st = stUserSet();
            for (var k = 0; k < sortedLines.length; k++) {
                var r = (sortedLines[k].r || "").toUpperCase(), tp = (sortedLines[k].tp || "").toUpperCase();
                if ((r === "70005847" || r === "70009001") && st[tp]) return k;
            }
            return -1;
        }
        function effectiveSelIdx(avis, sortedLines) {
            if (appData.selLine && appData.selLine[avis] != null && NettoyerChaine(appData.selLine[avis]) !== "") {
                var selN = NettoyerChaine(appData.selLine[avis]);
                for (var k = 0; k < sortedLines.length; k++) { if (NettoyerChaine(sortedLines[k].n) === selN) return k; }
            }
            return defaultSelIdx(sortedLines);
        }
        function parcoursTotals(nc, lines, selIdx) {
            if (selIdx == null || selIdx < 0) return { g: nc.durMs, e: nc.chezMs };
            var clot = nc.end;
            var prev = (selIdx > 0) ? parseDT(lines[selIdx - 1].td, lines[selIdx - 1].tt) : nc.start;
            if (!prev || !clot || clot <= prev) return { g: 0, e: 0 };
            var selRecept = prev, intS = internalRespSet(), usr = teamUserSet(), e = 0;
            for (var k = selIdx; k < lines.length; k++) {   // k commence à la tâche sélectionnée
                var end = parseDT(lines[k].td, lines[k].tt);
                if (!end || end <= prev) continue;
                if (end > clot) break;
                var r = (lines[k].r || "").toUpperCase(), tp = (lines[k].tp || "").toUpperCase();
                if (intS[r] && usr[tp]) e += durBetween(prev, end);
                prev = end;
            }
            return { g: durBetween(selRecept, clot), e: e };
        }
        function RecalcGlobalFromLine(avis, idx) {
            var nc = null;
            for (var i = 0; i < ncList.length; i++) { if (ncList[i].avis === avis) { nc = ncList[i]; break; } }
            if (!nc) return;
            var lines = nc.lines.slice(0).sort(function (a, b) { return (parseInt(NettoyerChaine(a.n), 10) || 0) - (parseInt(NettoyerChaine(b.n), 10) || 0); });
            if (idx < 0 || idx >= lines.length) return;
            if (!appData.selLine) appData.selLine = {};
            appData.selLine[avis] = NettoyerChaine(lines[idx].n);   // sauvegarde du Nº de la ligne
            RecomputeAll();   // applique l'override sur nc.durMs/chezMs pour TOUTE l'appli
            SaveData();
            shareQueueSel(avis, appData.selLine[avis]);   // base partagée
            var nc2 = null;
            for (var k = 0; k < ncList.length; k++) { if (ncList[k].avis === avis) { nc2 = ncList[k]; break; } }
            if (nc2) {
                var g = document.getElementById('gbadge_' + avis), t = document.getElementById('tbadge_' + avis);
                if (g) g.innerHTML = fmtDHM(nc2.durMs);
                if (t) t.innerHTML = fmtDHM(nc2.chezMs);
            }
        }
        function OuvrirNCSap(avis, btn) {
            if (btn) btn.style.cursor = 'wait';
            document.body.style.cursor = 'wait';
            setTimeout(function () {   // 80 ms : laisse le curseur se rafraîchir avant l'appel SAP bloquant
                try {
                    var res = VBS_OuvrirQM03(avis);
                    if (!res || res.indexOf("ERREUR") !== -1) AfficherErreur(res || "Erreur inconnue lors de l'ouverture SAP.");
                } catch (e) {
                    AfficherErreur("Erreur : " + e.message);
                }
                document.body.style.cursor = '';
                if (btn) btn.style.cursor = 'pointer';
            }, 80);
        }
        function OuvrirOFSap(of, btn) {
            if (btn) btn.style.cursor = 'wait';
            document.body.style.cursor = 'wait';
            setTimeout(function () {
                try {
                    var res = VBS_OuvrirCO03(of);
                    if (!res || res.indexOf("ERREUR") !== -1) AfficherErreur(res || "Erreur inconnue lors de l'ouverture SAP.");
                } catch (e) { AfficherErreur("Erreur : " + e.message); }
                document.body.style.cursor = '';
                if (btn) btn.style.cursor = 'pointer';
            }, 80);
        }

    // ==========================================================
    // INITIALISATION
    // ==========================================================
        window.onload = function () {
            setTimeout(MaximiserFenetre, 0);
            document.getElementById("appLogo").innerText = APP_NAME;
            document.getElementById("appSub").innerText = APP_SOUS_TITRE;
            LoadData();
            UpdateSyncIndicator();   // pied de barre : état de la synchro (après LoadData pour connaître le token)
            DemarrerVerificationSysteme();
            setTimeout(CleanExportTemp, 4000);   // purge des fichiers temporaires d'export laissés par des générations interrompues
            var c = document.getElementById('content');
            if (c) {
                c.onscroll = function () {
                    var b = document.getElementById('btnScrollTop');
                    if (b) b.style.display = (c.scrollTop > 200) ? 'block' : 'none';
                };
            }
            if (document.addEventListener) document.addEventListener('click', DocClickCloseMsn, false);
            else if (document.attachEvent) document.attachEvent('onclick', DocClickCloseMsn);
        };
        var resizeTimer = null;
        window.onresize = function () {
            if (resizeTimer) clearTimeout(resizeTimer);
            resizeTimer = setTimeout(function () {
                if (dashSuppressLaunchResize) return;   // ignore le resize dû à la maximisation au lancement (rendu déjà planifié)
                InvalidateDash();   // les graphiques doivent être redimensionnés à la nouvelle taille de fenêtre
                InvalidatePages();  // Analyse NC / Paramètres non visibles : à re-fitter à la prochaine ouverture
                var pg = document.getElementById('pageAnalyse');
                if (pg && pg.className.indexOf('active') !== -1) { EgaliserHauteursExtraction(); AjusterHauteurTables(); ResizeEmptyCards(); }
                var pd = document.getElementById('pageDashboard');
                if (pd && pd.className.indexOf('active') !== -1) RenderActiveDashboardSub();
                var pp = document.getElementById('pageParcours');
                if (pp && pp.className.indexOf('active') !== -1) AjusterHauteurParcours();
            }, 150);
        };
    </script>
</head>

<body>
    <!-- ====================== ECRAN DE CONNEXION ====================== -->
    <div id="loginScreen">
        <div class="login-center"><div class="login-cell">
            <div class="login-box">
                <div class="login-accent"></div>
                <h1 id="appLogoLogin">KPI PERFO</h1>
                <div class="login-sub">Analyse NC, OF et IC</div>
                <div class="login-divider"></div>

                <div id="loginCheckView">
                    <div class="spinner-lg"></div>
                    <p id="loginStatus" class="login-status">Initialisation…</p>
                </div>

                <div id="loginSuccess" style="display:none;">
                    <div class="login-icon login-icon-ok">
                        <svg width="34" height="34" viewBox="0 0 24 24" style="vertical-align:middle;"><path d="M5 12.5l4 4 10-10.5" fill="none" stroke="#059669" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </div>
                    <p id="loginTitleOk" class="login-title-ok">Acc&egrave;s autoris&eacute;</p>
                    <button id="btnEntrer" class="login-btn" onclick="EntrerApplication()">Acc&eacute;der &agrave; l'application</button>
                    <div id="newVersionAlert" style="display:none; margin: 20px auto 0 auto; width: 85%; padding: 15px; background: #fffbeb; border: 1px solid #fde68a; border-radius: 8px; text-align: left;">
                        <p style="margin: 0 0 10px 0; font-size: 13px; color: #b45309; font-weight: 700; text-align: center;">
                            Une nouvelle version (v<span id="nvVersionNum"></span>) est disponible.<br>
                            Mise &agrave; jour obligatoire pour acc&eacute;der &agrave; l'application.
                        </p>
                        <div style="white-space: nowrap;">
                            <input type="text" id="nvUrlInput" readonly style="width: calc(100% - 45px); padding: 8px; font-size: 11px; border: 1px solid #fcd34d; border-radius: 4px; background: #fff; color: #78350f; vertical-align: middle; box-sizing: border-box;">
                            <button type="button" title="Copier le lien" onclick="CopierLienDrive(this)" style="width: 38px; height: 31px; padding: 0; background: #f59e0b; color: #fff; border: none; border-radius: 4px; font-size: 16px; cursor: pointer; vertical-align: middle; margin-left: 5px;">📋</button>
                        </div>
                    </div>
                </div>

                <div id="loginErrorView" style="display:none;">
                    <div class="login-icon login-icon-ko">
                        <svg width="34" height="34" viewBox="0 0 24 24" style="vertical-align:middle;"><path d="M12 3L1.5 21h21L12 3z" fill="none" stroke="#dc2626" stroke-width="2" stroke-linejoin="round"/><path d="M12 10v5" stroke="#dc2626" stroke-width="2" stroke-linecap="round"/><circle cx="12" cy="17.6" r="1.1" fill="#dc2626"/></svg>
                    </div>
                    <p id="loginErrorTitle" class="login-title-ko">Acc&egrave;s refus&eacute;</p>
                    <p id="loginError" class="login-status" style="padding:0 40px;"></p>
                    <div class="login-contact">Pour toute demande d'acc&egrave;s, contactez<br><span class="lc-name">Adrien Truc</span><br><span class="lc-mail">adrien.a.truc.external@airbus.com</span></div>
                </div>
            </div>
        </div></div>
    </div>

    <div id="custom-datepicker" class="datepicker-popup" style="display:none;"></div>

    <!-- ====================== APPLICATION ====================== -->
    <div id="mainApp" style="display:none;">
        <button id="btnScrollTop" onclick="ScrollHautTableau()"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:middle;"><path d="M12 19V6"/><path d="M6 12l6-6 6 6"/></svg></button>
        <div id="sidebar">
            <div id="sidebar-header">
                <div class="app-logo" id="appLogo">KPI PERFO</div>
                <div class="app-sub" id="appSub">ANALYSE NC - QM13</div>
            </div>
            <div id="navDashboard" class="nav-item active" onclick="ShowPage('pageDashboard')">Tableau de bord</div>
            <div id="navAnalyse" class="nav-item" onclick="ShowPage('pageAnalyse')">Extraction</div>
            <div id="navParcours" class="nav-item" onclick="ShowPage('pageParcours')">Analyse NC</div>
            <div id="navParametres" class="nav-item" onclick="ShowPage('pageParametres')">Paramètres</div>
            <div id="sidebar-footer"></div>
        </div>

        <div id="content">

            <div id="pageDashboard" class="page active">
                <div style="border-bottom:2px solid #e2e8f0; margin:0 0 18px 0; overflow:hidden;">
                    <button id="dashSubtabNC" class="subtab active" onclick="ShowDashSub('NC')">Non-conformité</button>
                    <button id="dashSubtabOF" class="subtab" onclick="ShowDashSub('OF')">Ordre de Fabrication</button>
                    <button id="dashSubtabIC" class="subtab" onclick="ShowDashSub('IC')">Intervention Card</button>
                    <button id="dashSubtabPL" class="subtab" onclick="ShowDashSub('PL')">Planification</button>
                    <button id="dashExportNC" onclick="ExportDashboardNC()" title="Exporter le tableau de bord NC en PDF" style="display:none; float:right; margin:4px 0 4px 12px; height:34px; padding:0 14px; border:none; border-radius:6px; background:#0C447C; color:#fff; font-size:13px; font-weight:600; cursor:pointer; box-sizing:border-box;"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:middle; margin-right:6px;"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><path d="M7 10l5 5 5-5"/><path d="M12 15V3"/></svg>Exporter PDF</button>
                    <button id="dashExportOF" onclick="ExportDashboardOF()" title="Exporter le tableau de bord OF en PDF" style="display:none; float:right; margin:4px 0 4px 12px; height:34px; padding:0 14px; border:none; border-radius:6px; background:#0C447C; color:#fff; font-size:13px; font-weight:600; cursor:pointer; box-sizing:border-box;"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:middle; margin-right:6px;"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><path d="M7 10l5 5 5-5"/><path d="M12 15V3"/></svg>Exporter PDF</button>
                    <span id="dashFilterBar" style="float:right; margin:4px 0;"></span>
                </div>

                <div id="dashSubNC">

                <div id="dashEmpty" class="card" style="display:none; margin-bottom:0; box-sizing:border-box;">
                    <div style="display:table; width:100%; height:100%;">
                        <div style="display:table-cell; vertical-align:middle; text-align:center; padding:20px;">
                            <div style="width:64px; height:64px; margin:0 auto 18px auto; border-radius:50%; background:#eef2f5; display:table;">
                                <span style="display:table-cell; vertical-align:middle; text-align:center;">
                                    <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="2"/><path d="M3 9h18M8 4v16"/></svg>
                                </span>
                            </div>
                            <div style="font-size:17px; font-weight:700; color:#334155; margin-bottom:8px;">Aucune non-conformité à analyser</div>
                            <div style="font-size:14px; color:#64748b; margin-bottom:22px;">Lance une extraction des non-conformités (QM13) pour afficher les graphiques.</div>
                            <button class="btn-toolbar" onclick="ShowPage('pageAnalyse'); ShowExtractSub('NC');">Aller à l'extraction</button>
                        </div>
                    </div>
                </div>

                <div id="dashCharts" style="display:none;">
                    <div style="display:table; width:100%; table-layout:fixed; margin-bottom:20px;">
                        <div style="display:table-cell; width:40%; padding-right:8px; vertical-align:top;">
                            <div id="cardEvo3w" class="card dashCardNC">
                                <h3>Évolution sur les 3 dernières semaines</h3>
                                <div id="dash3weeks" class="dashChartNC"></div>
                            </div>
                        </div>
                        <div style="display:table-cell; width:60%; padding-left:8px; vertical-align:top;">
                            <div id="cardEvoWeek" class="card dashCardNC">
                                <h3 id="dashWeeksTitle">Évolution du traitement par semaine</h3>
                                <div id="dashWeeks" class="dashChartNC"></div>
                            </div>
                        </div>
